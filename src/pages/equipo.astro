---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabaseClient.js";

const { data: roles } = await supabase
    .from("user_roles")
    .select("id, user_id, role, name, email, temp_password, created_at")
    .eq("role", "employee");
---

<Layout>
    <div class="min-h-screen bg-slate-50 px-4 sm:px-6 py-6 sm:py-8 pt-20 lg:pt-8">
        <div class="max-w-3xl mx-auto">

            <!-- Header -->
            <div class="flex items-center justify-between gap-3 mb-6 sm:mb-8">
                <div class="flex items-center gap-3 sm:gap-4 min-w-0">
                    <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-indigo-600 flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <div class="min-w-0">
                        <h1 class="text-xl sm:text-2xl font-bold text-slate-800 leading-tight">Equipo</h1>
                        <p class="text-xs sm:text-sm text-slate-500">Gestioná tus empleados</p>
                    </div>
                </div>
                <button
                    id="open-employee-modal"
                    class="inline-flex items-center gap-1.5 sm:gap-2 bg-indigo-600 hover:bg-indigo-700 active:scale-95 text-white text-xs sm:text-sm font-semibold px-3 sm:px-4 py-2 sm:py-2.5 rounded-xl transition-all shrink-0"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    <span class="hidden xs:inline">Nuevo empleado</span>
                    <span class="xs:hidden">Nuevo</span>
                </button>
            </div>

            <!-- Lista empleados -->
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">
                {roles && roles.length > 0 ? (
                    <ul class="divide-y divide-slate-100">
                        {roles.map((r: any) => (
                            <li class="flex items-center gap-3 sm:gap-4 px-4 sm:px-5 py-4">
                                <div class="w-10 h-10 rounded-full bg-indigo-100 flex items-center justify-center shrink-0">
                                    <span class="text-sm font-bold text-indigo-700">
                                        {(r.name?.[0] ?? "?").toUpperCase()}
                                    </span>
                                </div>
                                <div class="flex-1 min-w-0">
                                    <p class="text-sm font-semibold text-slate-800 truncate">{r.name ?? "Sin nombre"}</p>
                                    <p class="text-xs text-slate-500 truncate mt-0.5">{r.email ?? "—"}</p>
                                    <span class="inline-block px-2 py-0.5 rounded-full text-xs font-medium bg-indigo-50 text-indigo-600 mt-0.5">
                                        Empleado
                                    </span>
                                </div>
                                <button
                                    class="delete-employee-btn text-xs text-slate-400 hover:text-red-500 transition-colors font-medium shrink-0 px-2 py-1 rounded-lg hover:bg-red-50"
                                    data-user-id={r.user_id}
                                >
                                    Eliminar
                                </button>
                            </li>
                        ))}
                    </ul>
                ) : (
                    <div class="flex flex-col items-center justify-center py-14 sm:py-16 text-center px-4">
                        <div class="w-12 h-12 rounded-2xl bg-slate-100 flex items-center justify-center mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <p class="text-slate-500 text-sm">No hay empleados registrados</p>
                        <p class="text-slate-400 text-xs mt-1">Hacé click en "Nuevo empleado" para agregar uno</p>
                    </div>
                )}
            </div>

        </div>
    </div>

    <!-- Modal nuevo empleado -->
    <div id="employee-modal-overlay" class="hidden fixed inset-0 bg-black/40 z-50 flex items-end sm:items-center justify-center sm:px-4">
        <div class="bg-white rounded-t-2xl sm:rounded-2xl shadow-xl w-full sm:max-w-md">

            <div class="flex items-center justify-between px-5 sm:px-6 py-4 border-b border-slate-100">
                <h2 class="text-base font-semibold text-slate-800">Nuevo empleado</h2>
                <button id="close-employee-modal" class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>

            <div class="px-5 sm:px-6 py-5 space-y-4">

                <div id="employee-error" class="hidden px-3 py-2 rounded-xl bg-red-50 border border-red-200 text-red-700 text-xs"></div>
                <div id="employee-success" class="hidden px-3 py-2 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-700 text-xs font-medium"></div>

                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Nombre</label>
                    <input id="emp-name" type="text" placeholder="Nombre del empleado"
                        autocomplete="off"
                        class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                    />
                </div>

                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Email *</label>
                    <input id="emp-email" type="email" placeholder="empleado@email.com"
                        autocomplete="off"
                        inputmode="email"
                        class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                    />
                </div>

                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Contraseña *</label>
                    <div class="relative">
                        <input id="emp-password" type="password" placeholder="Mínimo 8 caracteres"
                            autocomplete="new-password"
                            class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition pr-10"
                        />
                        <button type="button" id="toggle-password" class="absolute inset-y-0 right-3 flex items-center text-slate-400 hover:text-slate-600 transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                            </svg>
                        </button>
                    </div>
                </div>

            </div>

            <div class="px-5 sm:px-6 py-4 border-t border-slate-100 flex gap-3">
                <button id="cancel-employee-modal"
                    class="flex-1 py-2.5 rounded-xl text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors"
                >
                    Cancelar
                </button>
                <button id="save-employee-btn"
                    class="flex-1 py-2.5 rounded-xl text-sm font-semibold bg-indigo-600 hover:bg-indigo-700 text-white transition-colors flex items-center justify-center gap-2 disabled:bg-indigo-300 disabled:cursor-not-allowed"
                >
                    <span id="save-employee-text">Crear empleado</span>
                    <svg id="save-employee-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 0v4a8 8 0 00-8 8H0z"></path>
                    </svg>
                </button>
            </div>

        </div>
    </div>
</Layout>

<script>
    import { supabase } from "../lib/supabaseClient.js";

    const overlay     = document.getElementById("employee-modal-overlay")!;
    const empName     = document.getElementById("emp-name")      as HTMLInputElement;
    const empEmail    = document.getElementById("emp-email")     as HTMLInputElement;
    const empPass     = document.getElementById("emp-password")  as HTMLInputElement;
    const saveBtn     = document.getElementById("save-employee-btn")    as HTMLButtonElement;
    const saveText    = document.getElementById("save-employee-text")!;
    const saveSpinner = document.getElementById("save-employee-spinner")!;
    const errorEl     = document.getElementById("employee-error")!;
    const successEl   = document.getElementById("employee-success")!;

    document.getElementById("toggle-password")?.addEventListener("click", () => {
        empPass.type = empPass.type === "password" ? "text" : "password";
    });

    function openModal() {
        empName.value = "";
        empEmail.value = "";
        empPass.value = "";
        empPass.type = "password";
        errorEl.classList.add("hidden");
        successEl.classList.add("hidden");
        overlay.classList.remove("hidden");
        setTimeout(() => empName.focus(), 100);
    }

    function closeModal() {
        overlay.classList.add("hidden");
    }

    function setLoading(loading: boolean) {
        saveBtn.disabled = loading;
        saveText.textContent = loading ? "Creando..." : "Crear empleado";
        saveSpinner.classList.toggle("hidden", !loading);
    }

    document.getElementById("open-employee-modal")?.addEventListener("click", openModal);
    document.getElementById("close-employee-modal")?.addEventListener("click", closeModal);
    document.getElementById("cancel-employee-modal")?.addEventListener("click", closeModal);
    overlay.addEventListener("click", (e) => { if (e.target === overlay) closeModal(); });

    saveBtn.addEventListener("click", async () => {
        errorEl.classList.add("hidden");
        successEl.classList.add("hidden");

        const name     = empName.value.trim();
        const email    = empEmail.value.trim();
        const password = empPass.value;

        if (!email) {
            errorEl.textContent = "El email es obligatorio.";
            errorEl.classList.remove("hidden");
            return;
        }
        if (password.length < 8) {
            errorEl.textContent = "La contraseña debe tener al menos 8 caracteres.";
            errorEl.classList.remove("hidden");
            return;
        }

        setLoading(true);

        try {
            const { data: sessionData } = await supabase.auth.getSession();
            const token = sessionData?.session?.access_token;

            const res = await fetch(`${import.meta.env.PUBLIC_SUPABASE_URL}/functions/v1/create-employee`, {
                method: "POST",
                headers: {
                    "Content-Type": "application/json",
                    "Authorization": `Bearer ${token}`,
                },
                body: JSON.stringify({ email, password, name }),
            });

            const result = await res.json();
            if (!res.ok) throw new Error(result.error ?? "Error al crear el empleado");

            successEl.textContent = `Empleado ${name ? name + " (" + email + ")" : email} creado correctamente ✓`;
            successEl.classList.remove("hidden");
            setTimeout(() => { closeModal(); window.location.reload(); }, 1500);

        } catch (err: any) {
            errorEl.textContent = err?.message ?? "Error al crear el empleado.";
            errorEl.classList.remove("hidden");
        } finally {
            setLoading(false);
        }
    });

    document.querySelectorAll<HTMLButtonElement>(".delete-employee-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
            if (!confirm("¿Eliminar este empleado?")) return;

            const userId = btn.dataset.userId!;
            btn.disabled = true;
            btn.textContent = "Eliminando...";

            try {
                await supabase.from("user_roles").delete().eq("user_id", userId);
                window.location.reload();
            } catch (err: any) {
                alert("Error: " + err.message);
                btn.disabled = false;
                btn.textContent = "Eliminar";
            }
        });
    });
</script>