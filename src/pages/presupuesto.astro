---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabaseClient.js";

const { data: products } = await supabase.from("products").select("*").eq("active", true);
const { data: allDiscounts } = await supabase.from("product_discounts").select("*");
const { data: clients } = await supabase
    .from("clients")
    .select("id, name, special_discount")
    .order("name");

const discountsByProduct: Record<string, any[]> = {};
allDiscounts?.forEach((d) => {
    if (!discountsByProduct[d.product_id]) discountsByProduct[d.product_id] = [];
    discountsByProduct[d.product_id].push(d);
});
Object.values(discountsByProduct).forEach((arr) =>
    arr.sort((a, b) => b.min_qty - a.min_qty)
);

const formatMoney = (amount: number | null) => {
    if (amount == null) return "—";
    return "$ " + new Intl.NumberFormat("es-AR", {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
    }).format(amount);
};

const clientsJSON = JSON.stringify(
    (clients ?? []).map((c) => ({
        id: c.id,
        name: c.name,
        special_discount: c.special_discount ?? null,
    }))
);

const categoryNames = [...new Set((products ?? []).map((p: any) => p.category).filter(Boolean))].sort();
---

<Layout>
    <div class="min-h-screen bg-slate-50 px-4 sm:px-6 py-6 sm:py-8 pt-20 lg:pt-8">
        <div class="max-w-5xl mx-auto">

            <!-- Header -->
            <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4 mb-6 sm:mb-8">
                <div class="flex items-center gap-3 sm:gap-4 flex-1">
                    <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-violet-600 flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-xl sm:text-2xl font-bold text-slate-800 leading-tight">Presupuesto</h1>
                        <p class="text-xs sm:text-sm text-slate-500">Seleccioná productos para generar un presupuesto</p>
                    </div>
                </div>
            </div>

            <div class="flex gap-6">

                <!-- Productos -->
                <div class="flex-1 min-w-0">

                    <!-- Buscador -->
                    <div class="relative mb-3 sm:mb-4">
                        <span class="absolute inset-y-0 left-3 flex items-center text-slate-400 pointer-events-none">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </span>
                        <input id="search" type="text" placeholder="Buscar por nombre o código..."
                            class="w-full pl-9 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
                        />
                    </div>

                    <!-- Filtros por categoría -->
                    {categoryNames.length > 0 && (
                        <div id="category-filters" class="flex flex-wrap gap-2 mb-4 sm:mb-5">
                            <button
                                class="category-filter-btn text-xs font-semibold px-3 py-1.5 rounded-xl border border-transparent bg-violet-600 text-white transition-all"
                                data-category=""
                            >
                                Todos
                            </button>
                            {categoryNames.map((cat) => (
                                <button
                                    class="category-filter-btn text-xs font-semibold px-3 py-1.5 rounded-xl border border-slate-200 bg-white text-slate-600 hover:border-violet-400 transition-all"
                                    data-category={cat}
                                >
                                    {cat}
                                </button>
                            ))}
                        </div>
                    )}

                    {products && products.length > 0 ? (
                        <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-3 gap-2 sm:gap-3">
                            {products.map((p) => {
                                const discounts = discountsByProduct[p.id] ?? [];
                                const isPricePerKg = !!p.price_per_kg;
                                return (
                                    <button type="button"
                                        class="product-card text-left bg-white border border-slate-200 rounded-2xl p-3 sm:p-4 hover:border-violet-400 hover:shadow-md active:scale-95 transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-violet-500"
                                        data-id={p.id}
                                        data-name={p.name}
                                        data-price={p.price}
                                        data-price-per-kg={isPricePerKg ? "true" : "false"}
                                        data-category={p.category ?? ""}
                                        data-code={(p.code ?? "").toLowerCase()}
                                        data-discounts={JSON.stringify(discounts)}>
                                        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-violet-50 flex items-center justify-center mb-2 sm:mb-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-violet-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                            </svg>
                                        </div>
                                        <p class="text-xs sm:text-sm font-semibold text-slate-800 leading-tight mb-1 truncate">{p.name}</p>
                                        <p class="text-xs sm:text-sm font-bold text-violet-600">
                                            {formatMoney(p.price)}{isPricePerKg ? <span class="text-xs font-medium text-violet-400">/kg</span> : ""}
                                        </p>
                                        {p.stock != null && (
                                            <p class={`text-xs mt-1.5 font-medium ${p.stock <= 5 ? "text-red-500" : "text-slate-400"}`}>
                                                Stock: {p.stock}
                                            </p>
                                        )}
                                        {isPricePerKg && (
                                            <span class="inline-flex items-center gap-1 mt-1.5 text-xs px-1.5 py-0.5 rounded-md bg-amber-50 border border-amber-200 text-amber-700 font-semibold">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
                                                </svg>
                                                Por kilo
                                            </span>
                                        )}
                                        {p.category && (
                                            <span class="inline-block mt-1.5 text-xs px-1.5 py-0.5 rounded-md bg-slate-100 text-slate-500 font-medium truncate max-w-full">
                                                {p.category}
                                            </span>
                                        )}
                                        {discounts.length > 0 && (
                                            <div class="flex flex-wrap gap-1 mt-2">
                                                {discounts.slice().reverse().map((d: any) => (
                                                    <span class="text-xs px-1.5 py-0.5 rounded-md bg-violet-50 text-violet-600 font-medium">
                                                        {d.label || `x${d.min_qty}${isPricePerKg ? 'kg' : ''}`} -{d.discount_pct}%
                                                    </span>
                                                ))}
                                            </div>
                                        )}
                                    </button>
                                );
                            })}
                        </div>

                        <div id="no-results" class="hidden flex flex-col items-center justify-center py-12 text-center">
                            <div class="w-10 h-10 rounded-2xl bg-slate-100 flex items-center justify-center mb-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <p class="text-slate-400 text-sm">No hay productos en esta categoría</p>
                        </div>
                    ) : (
                        <div class="flex flex-col items-center justify-center py-16 text-center bg-white border border-slate-200 rounded-2xl">
                            <p class="text-slate-400 text-sm">No hay productos disponibles</p>
                        </div>
                    )}
                    <div class="h-24 lg:hidden"></div>
                </div>

                <!-- Carrito desktop -->
                <div class="hidden lg:block w-72 shrink-0">
                    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm sticky top-6">
                        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
                            <h2 class="font-semibold text-slate-800 text-sm">Presupuesto actual</h2>
                            <button id="clear-cart-desktop" class="text-xs text-slate-400 hover:text-red-500 transition-colors">Limpiar</button>
                        </div>
                        <div class="px-5 pt-4 pb-3 border-b border-slate-100 space-y-2" id="client-section-desktop"></div>
                        <div id="cart-items-desktop" class="divide-y divide-slate-100 min-h-[120px]">
                            <p id="cart-empty-desktop" class="text-sm text-slate-400 text-center py-8">El presupuesto está vacío</p>
                        </div>
                        <div class="px-5 py-4 border-t border-slate-100 space-y-2" id="cart-footer-desktop"></div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- FAB mobile -->
    <button id="open-cart-mobile"
        class="lg:hidden fixed bottom-6 right-4 z-40 flex items-center gap-2 bg-violet-600 hover:bg-violet-700 active:scale-95 text-white font-semibold text-sm px-4 py-3 rounded-2xl shadow-lg transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
        </svg>
        <span>Presupuesto</span>
        <span id="cart-badge" class="hidden bg-white text-violet-600 text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span>
    </button>

    <!-- Overlay mobile -->
    <div id="cart-mobile-overlay" class="lg:hidden fixed inset-0 z-40 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-200"></div>

    <!-- Drawer mobile -->
    <div id="cart-mobile-drawer"
        class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-white rounded-t-2xl shadow-2xl translate-y-full transition-transform duration-300 ease-in-out max-h-[85vh] flex flex-col">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100 shrink-0">
            <h2 class="font-semibold text-slate-800 text-sm">Presupuesto actual</h2>
            <div class="flex items-center gap-3">
                <button id="clear-cart-mobile" class="text-xs text-slate-400 hover:text-red-500 transition-colors">Limpiar</button>
                <button id="close-cart-mobile" class="w-7 h-7 rounded-lg bg-slate-100 hover:bg-slate-200 flex items-center justify-center transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="overflow-y-auto flex-1">
            <div class="px-5 pt-4 pb-3 border-b border-slate-100 space-y-2" id="client-section-mobile"></div>
            <div id="cart-items-mobile" class="divide-y divide-slate-100 min-h-[80px]">
                <p id="cart-empty-mobile" class="text-sm text-slate-400 text-center py-8">El presupuesto está vacío</p>
            </div>
        </div>
        <div class="px-5 py-4 border-t border-slate-100 space-y-2 shrink-0 bg-white" id="cart-footer-mobile"></div>
    </div>

    <!-- Modal peso -->
    <div id="weight-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm px-4">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-xs p-6 space-y-5">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-amber-50 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-amber-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 6l3 1m0 0l-3 9a5.002 5.002 0 006.001 0M6 7l3 9M6 7l6-2m6 2l3-1m-3 1l-3 9a5.002 5.002 0 006.001 0M18 7l3 9m-3-9l-6-2m0-2v2m0 16V5m0 16H9m3 0h3" />
                    </svg>
                </div>
                <div>
                    <p id="weight-modal-title" class="text-sm font-bold text-slate-800">Ingresar peso</p>
                    <p class="text-xs text-amber-600 font-medium">Precio por kilo</p>
                </div>
            </div>
            <div class="grid grid-cols-2 gap-3">
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Kilos</label>
                    <div class="relative">
                        <input id="weight-kg" type="number" min="0" step="1" placeholder="0"
                            class="w-full px-3 py-3 border border-slate-200 rounded-xl text-lg font-bold text-slate-800 placeholder-slate-300 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition text-center"/>
                        <span class="absolute right-2.5 bottom-2 text-xs text-slate-400 font-semibold">kg</span>
                    </div>
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Gramos</label>
                    <div class="relative">
                        <input id="weight-g" type="number" min="0" max="999" step="1" placeholder="0"
                            class="w-full px-3 py-3 border border-slate-200 rounded-xl text-lg font-bold text-slate-800 placeholder-slate-300 focus:outline-none focus:ring-2 focus:ring-amber-500 focus:border-transparent transition text-center"/>
                        <span class="absolute right-2.5 bottom-2 text-xs text-slate-400 font-semibold">g</span>
                    </div>
                </div>
            </div>
            <div class="flex items-center justify-between px-3 py-2.5 bg-violet-50 rounded-xl">
                <span class="text-xs text-violet-500 font-medium">Total estimado</span>
                <span id="weight-price-value" class="text-sm font-bold text-violet-700">$ 0,00</span>
            </div>
            <div class="flex gap-2">
                <button id="weight-modal-cancel" type="button"
                    class="flex-1 py-2.5 rounded-xl text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors">
                    Cancelar
                </button>
                <button id="weight-modal-ok" type="button"
                    class="flex-1 py-2.5 rounded-xl text-sm font-semibold bg-amber-500 hover:bg-amber-600 text-white transition-colors">
                    Agregar
                </button>
            </div>
        </div>
    </div>

    <!-- Modal confirmación de presupuesto -->
    <div id="confirm-budget-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm px-4">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 space-y-4">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-violet-50 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-bold text-slate-800">Confirmar presupuesto</p>
                    <p class="text-xs text-slate-400">Elegí qué hacer con el presupuesto</p>
                </div>
            </div>

            <div class="bg-slate-50 rounded-xl px-4 py-3 space-y-2">
                <div class="flex justify-between items-center">
                    <span class="text-xs text-slate-500">Cliente</span>
                    <span id="modal-client-name" class="text-xs font-semibold text-slate-700">Sin cliente</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-xs text-slate-500">Productos</span>
                    <span id="modal-items-count" class="text-xs font-semibold text-slate-700">—</span>
                </div>
                <div class="border-t border-slate-200 pt-2 flex justify-between items-center">
                    <span class="text-sm font-medium text-slate-600">Total</span>
                    <span id="modal-total" class="text-base font-bold text-violet-600">$ 0,00</span>
                </div>
            </div>

            <div class="flex gap-2 pt-1">
                <button id="confirm-budget-cancel" type="button"
                    class="flex-none px-4 py-2.5 rounded-xl text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors">
                    Cancelar
                </button>
                <button id="confirm-print-btn" type="button"
                    class="flex-1 py-2.5 rounded-xl text-sm font-semibold border border-violet-200 text-violet-700 hover:bg-violet-50 transition-colors flex items-center justify-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4H9v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/>
                    </svg>
                    Imprimir
                </button>
                <button id="confirm-send-btn" type="button"
                    class="flex-1 py-2.5 rounded-xl text-sm font-semibold bg-violet-600 hover:bg-violet-700 text-white transition-colors flex items-center justify-center gap-1.5">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                    <span id="send-btn-text">Enviar a caja</span>
                    <svg id="send-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 0v4a8 8 0 00-8 8H0z"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <script type="application/json" id="clients-data" set:html={clientsJSON}></script>
</Layout>

<script>
    import { supabase } from "../lib/supabaseClient.js";

    const EMPRESA_NOMBRE   = "El Mundo Del Descartable";
    const EMPRESA_TELEFONO = "5493572549909";

    interface Client   { id: string; name: string; special_discount: number | null; }
    interface Discount { id: string; min_qty: number; discount_pct: number; label?: string; }
    interface CartItem {
        id: string; name: string; basePrice: number; discounts: Discount[];
        qty: number; pricePerKg: boolean; weightKg: number; weightLabel: string; appliedDiscount: number;
    }

    const cart: CartItem[] = [];
    let activeClientId:        string | null = null;
    let activeClientName:      string | null = null;
    let activeSpecialDiscount: number        = 0;
    let activeCategoryFilter:  string        = "";
    let activeSearchQuery:     string        = "";

    const clientsRaw: Client[] = JSON.parse(document.getElementById("clients-data")!.textContent ?? "[]");

    const formatARS = (n: number) =>
        "$ " + new Intl.NumberFormat("es-AR", { minimumFractionDigits: 2, maximumFractionDigits: 2 }).format(n);

    function formatWeight(kg: number): string {
        const wholeKg = Math.floor(kg);
        const grams   = Math.round((kg - wholeKg) * 1000);
        if (wholeKg === 0) return `${grams} g`;
        if (grams === 0)   return `${wholeKg} kg`;
        return `${wholeKg} kg ${grams} g`;
    }

    function getApplicableDiscount(discounts: Discount[], value: number): number {
        for (const d of discounts) { if (value >= d.min_qty) return d.discount_pct; }
        return 0;
    }

    function effectiveUnitPrice(item: CartItem): number {
        if (activeSpecialDiscount > 0) return item.basePrice;
        return item.basePrice * (1 - item.appliedDiscount / 100);
    }

    function itemTotal(item: CartItem): number {
        const ep = effectiveUnitPrice(item);
        return item.pricePerKg ? ep * item.weightKg : ep * item.qty;
    }

    function calcSubtotal() { return cart.reduce((acc, c) => acc + itemTotal(c), 0); }
    function calcTotal() {
        const sub = calcSubtotal();
        return activeSpecialDiscount > 0 ? sub * (1 - activeSpecialDiscount / 100) : sub;
    }

    // ── Modal de peso ──────────────────────────────────────────────
    const weightModal       = document.getElementById("weight-modal")!;
    const weightModalTitle  = document.getElementById("weight-modal-title")!;
    const weightKgInput     = document.getElementById("weight-kg")     as HTMLInputElement;
    const weightGInput      = document.getElementById("weight-g")      as HTMLInputElement;
    const weightPriceValue  = document.getElementById("weight-price-value")!;
    const weightModalCancel = document.getElementById("weight-modal-cancel")!;
    const weightModalOk     = document.getElementById("weight-modal-ok")! as HTMLButtonElement;

    let pendingWeightProduct: { id: string; name: string; basePrice: number; discounts: Discount[] } | null = null;

    function updateWeightPreview() {
        if (!pendingWeightProduct) return;
        const kg = parseInt(weightKgInput.value) || 0;
        const g  = parseInt(weightGInput.value)  || 0;
        const totalKg = kg + g / 1000;
        const discount = getApplicableDiscount(pendingWeightProduct.discounts, totalKg);
        weightPriceValue.textContent = formatARS(pendingWeightProduct.basePrice * (1 - discount / 100) * totalKg);
    }

    weightKgInput.addEventListener("input", updateWeightPreview);
    weightGInput.addEventListener("input", updateWeightPreview);

    function openWeightModal(product: { id: string; name: string; basePrice: number; discounts: Discount[] }) {
        pendingWeightProduct = product;
        weightModalTitle.textContent = product.name;
        weightKgInput.value = ""; weightGInput.value = "";
        weightPriceValue.textContent = formatARS(0);
        weightModal.classList.remove("hidden");
        setTimeout(() => weightKgInput.focus(), 80);
    }
    function closeWeightModal() { weightModal.classList.add("hidden"); pendingWeightProduct = null; }

    weightModalCancel.addEventListener("click", closeWeightModal);
    weightModal.addEventListener("click", (e) => { if (e.target === weightModal) closeWeightModal(); });

    weightModalOk.addEventListener("click", () => {
        if (!pendingWeightProduct) return;
        const kg = parseInt(weightKgInput.value) || 0;
        const g  = parseInt(weightGInput.value)  || 0;
        const totalKg = kg + g / 1000;
        if (totalKg <= 0) { weightKgInput.classList.add("border-red-400"); setTimeout(() => weightKgInput.classList.remove("border-red-400"), 1200); return; }

        const { id, name, basePrice, discounts } = pendingWeightProduct;
        const existing = cart.find(c => c.id === id && c.pricePerKg);
        if (existing) {
            existing.weightKg += totalKg;
            existing.weightLabel = formatWeight(existing.weightKg);
            existing.appliedDiscount = getApplicableDiscount(discounts, existing.weightKg);
            refreshCartRow(existing); updateTotal();
        } else {
            const newItem: CartItem = { id, name, basePrice, discounts, qty: 1, pricePerKg: true, weightKg: totalKg, weightLabel: formatWeight(totalKg), appliedDiscount: getApplicableDiscount(discounts, totalKg) };
            cart.push(newItem); addToCart(newItem); updateTotal();
        }
        closeWeightModal();
    });

    [weightKgInput, weightGInput].forEach(input => input.addEventListener("keydown", (e) => { if (e.key === "Enter") weightModalOk.click(); }));

    // ── Filtros ────────────────────────────────────────────────────
    function applyFilters() {
        let visibleCount = 0;
        document.querySelectorAll<HTMLElement>(".product-card").forEach(card => {
            const matchesCategory = !activeCategoryFilter || card.dataset.category === activeCategoryFilter;
            const matchesSearch   = !activeSearchQuery || (card.dataset.name ?? "").toLowerCase().includes(activeSearchQuery) || (card.dataset.code ?? "").includes(activeSearchQuery);
            const visible = matchesCategory && matchesSearch;
            card.style.display = visible ? "" : "none";
            if (visible) visibleCount++;
        });
        const noResults = document.getElementById("no-results");
        if (noResults) { noResults.classList.toggle("hidden", visibleCount > 0); noResults.classList.toggle("flex", visibleCount === 0); }
    }

    document.getElementById("category-filters")?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".category-filter-btn") as HTMLElement | null;
        if (!btn) return;
        document.querySelectorAll(".category-filter-btn").forEach(b => {
            b.classList.remove("bg-violet-600", "text-white", "border-violet-600");
            b.classList.add("bg-white", "text-slate-600", "border-slate-200");
        });
        btn.classList.add("bg-violet-600", "text-white", "border-violet-600");
        btn.classList.remove("bg-white", "text-slate-600", "border-slate-200");
        activeCategoryFilter = btn.dataset.category ?? "";
        applyFilters();
    });

    document.getElementById("search")?.addEventListener("input", (e) => {
        activeSearchQuery = (e.target as HTMLInputElement).value.toLowerCase();
        applyFilters();
    });

    // ── Cart UI ────────────────────────────────────────────────────
    function buildClientSectionHTML(): string {
        const opts = clientsRaw.map(c =>
            `<option value="${c.id}" data-name="${c.name}" data-special-discount="${c.special_discount ?? ''}">${c.name}${c.special_discount ? ` (−${c.special_discount}%)` : ''}</option>`
        ).join('');
        return `
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Cliente</label>
        <div class="client-select-wrapper">
            <div class="relative">
                <select class="client-select w-full py-2 pl-3 pr-8 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-violet-400 transition appearance-none">
                    <option value="">— Sin cliente —</option>${opts}
                </select>
            </div>
            <button class="switch-to-manual mt-1.5 text-xs text-violet-500 hover:text-violet-700 font-medium transition-colors">+ Escribir nombre nuevo</button>
        </div>
        <div class="client-manual-mode hidden">
            <div class="relative">
                <input type="text" class="client-manual-input w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-violet-400 transition" placeholder="Nombre del cliente..." />
                <button class="clear-manual-btn absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-300 hover:text-slate-500 transition-colors hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <button class="switch-to-select mt-1.5 text-xs text-violet-500 hover:text-violet-700 font-medium transition-colors">← Elegir de la lista</button>
        </div>
        <div class="special-discount-badge hidden items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-violet-50 border border-violet-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-violet-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>
            <span class="special-discount-text text-xs font-semibold text-violet-700"></span>
        </div>`;
    }

    function buildFooterHTML(): string {
        return `
        <div class="subtotal-row hidden items-center justify-between">
            <span class="text-xs text-slate-400">Subtotal</span>
            <span class="cart-subtotal text-xs font-medium text-slate-600">$ 0,00</span>
        </div>
        <div class="special-discount-row hidden items-center justify-between">
            <span class="special-discount-label text-xs text-violet-600 font-medium">Descuento especial</span>
            <span class="cart-discount-amount text-xs font-semibold text-violet-600"></span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-sm text-slate-500">Total</span>
            <span class="cart-total text-lg font-bold text-slate-800">$ 0,00</span>
        </div>
        <button class="confirm-budget-btn w-full bg-violet-600 hover:bg-violet-700 disabled:bg-slate-200 disabled:text-slate-400 disabled:cursor-not-allowed text-white font-semibold py-2.5 rounded-xl transition-all text-sm flex items-center justify-center gap-2" disabled>
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
            Generar presupuesto
        </button>`;
    }

    document.getElementById("client-section-desktop")!.innerHTML = buildClientSectionHTML();
    document.getElementById("client-section-mobile")!.innerHTML  = buildClientSectionHTML();
    document.getElementById("cart-footer-desktop")!.innerHTML    = buildFooterHTML();
    document.getElementById("cart-footer-mobile")!.innerHTML     = buildFooterHTML();

    // Mobile drawer
    const fabBtn         = document.getElementById("open-cart-mobile")!;
    const closeDrawerBtn = document.getElementById("close-cart-mobile")!;
    const mobileOverlay  = document.getElementById("cart-mobile-overlay")!;
    const mobileDrawer   = document.getElementById("cart-mobile-drawer")!;
    const cartBadge      = document.getElementById("cart-badge")!;

    function openMobileCart()  { mobileDrawer.classList.remove("translate-y-full"); mobileOverlay.classList.remove("opacity-0","pointer-events-none"); mobileOverlay.classList.add("opacity-100"); document.body.style.overflow = "hidden"; }
    function closeMobileCart() { mobileDrawer.classList.add("translate-y-full"); mobileOverlay.classList.add("opacity-0","pointer-events-none"); mobileOverlay.classList.remove("opacity-100"); document.body.style.overflow = ""; }

    fabBtn.addEventListener("click", openMobileCart);
    closeDrawerBtn.addEventListener("click", closeMobileCart);
    mobileOverlay.addEventListener("click", closeMobileCart);

    function updateBadge() {
        const total = cart.length;
        if (total > 0) { cartBadge.textContent = String(total); cartBadge.classList.remove("hidden"); cartBadge.classList.add("flex"); }
        else { cartBadge.classList.add("hidden"); cartBadge.classList.remove("flex"); }
    }

    function updateTotal() {
        const subtotal   = calcSubtotal();
        const total      = calcTotal();
        const hasSpecial = activeSpecialDiscount > 0 && cart.length > 0;
        document.querySelectorAll<HTMLElement>(".cart-total").forEach(el => el.textContent = formatARS(total));
        document.querySelectorAll<HTMLElement>(".cart-subtotal").forEach(el => el.textContent = formatARS(subtotal));
        document.querySelectorAll<HTMLElement>(".cart-discount-amount").forEach(el => el.textContent = `−${formatARS(subtotal - total)}`);
        document.querySelectorAll<HTMLElement>(".special-discount-label").forEach(el => el.textContent = `Desc. especial (${activeSpecialDiscount}%)`);
        document.querySelectorAll<HTMLElement>(".subtotal-row").forEach(el => { el.classList.toggle("hidden", !hasSpecial); el.classList.toggle("flex", hasSpecial); });
        document.querySelectorAll<HTMLElement>(".special-discount-row").forEach(el => { el.classList.toggle("hidden", !hasSpecial); el.classList.toggle("flex", hasSpecial); });
        document.querySelectorAll<HTMLButtonElement>(".confirm-budget-btn").forEach(btn => { btn.disabled = cart.length === 0; });
        updateBadge();
    }

    function refreshCartRow(item: CartItem) {
        document.querySelectorAll<HTMLElement>(`[data-row-id="${item.id}"]`).forEach(row => {
            const total = itemTotal(item);
            if (item.pricePerKg) {
                const wd = row.querySelector<HTMLElement>(".weight-display"); if (wd) wd.textContent = item.weightLabel;
                const ul = row.querySelector<HTMLElement>(".unit-price-label")!;
                if (item.appliedDiscount > 0 && activeSpecialDiscount === 0) {
                    const dp = item.basePrice * (1 - item.appliedDiscount / 100);
                    ul.innerHTML = `<span class="line-through text-slate-300">${formatARS(item.basePrice)}</span><span class="text-emerald-600 font-semibold">${formatARS(dp)}/kg</span><span class="ml-1 px-1.5 py-0.5 rounded-md bg-emerald-50 text-emerald-600 text-xs font-bold">-${item.appliedDiscount}%</span>`;
                } else { ul.innerHTML = `<span class="text-slate-400">${formatARS(item.basePrice)}/kg</span>`; }
            } else {
                const ul = row.querySelector<HTMLElement>(".unit-price-label")!;
                if (item.appliedDiscount > 0 && activeSpecialDiscount === 0) {
                    ul.innerHTML = `<span class="line-through text-slate-300">${formatARS(item.basePrice)}</span><span class="text-emerald-600 font-semibold">${formatARS(effectiveUnitPrice(item))}</span><span class="ml-1 px-1.5 py-0.5 rounded-md bg-emerald-50 text-emerald-600 text-xs font-bold">-${item.appliedDiscount}%</span>`;
                } else { ul.innerHTML = `<span class="text-slate-400">${formatARS(item.basePrice)} c/u</span>`; }
                const input = row.querySelector<HTMLInputElement>(".qty-input");
                if (input && input.value !== String(item.qty)) input.value = String(item.qty);
            }
            row.querySelector<HTMLElement>(".subtotal-label")!.textContent = formatARS(total);
        });
    }

    function refreshAllCartRows() { cart.forEach(refreshCartRow); }

    function buildCartRowHTML(item: CartItem): string {
        if (item.pricePerKg) return `
            <div class="flex items-center justify-between mb-1.5">
                <div class="flex items-center gap-1.5 min-w-0">
                    <p class="text-xs font-semibold text-slate-700 truncate">${item.name}</p>
                    <span class="shrink-0 text-xs px-1.5 py-0.5 rounded-md bg-amber-50 border border-amber-200 text-amber-600 font-semibold">/kg</span>
                </div>
                <button class="remove-btn w-5 h-5 rounded-md bg-red-50 hover:bg-red-100 text-red-400 hover:text-red-600 text-xs flex items-center justify-center transition-colors shrink-0">✕</button>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
                <div class="unit-price-label flex items-center gap-1 text-xs shrink-0"><span class="text-slate-400">${formatARS(item.basePrice)}/kg</span></div>
                <div class="flex-1"></div>
                <button class="edit-weight-btn flex items-center gap-1 text-xs text-violet-500 hover:text-violet-700 font-medium bg-violet-50 hover:bg-violet-100 px-2 py-1 rounded-lg transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" /></svg>
                    <span class="weight-display">${item.weightLabel}</span>
                </button>
                <span class="text-xs font-bold text-violet-600 w-20 text-right subtotal-label">${formatARS(itemTotal(item))}</span>
            </div>`;

        return `
            <div class="flex items-center justify-between mb-1.5">
                <p class="text-xs font-semibold text-slate-700 truncate flex-1 pr-2">${item.name}</p>
                <button class="remove-btn w-5 h-5 rounded-md bg-red-50 hover:bg-red-100 text-red-400 hover:text-red-600 text-xs flex items-center justify-center transition-colors shrink-0">✕</button>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
                <div class="unit-price-label flex items-center gap-1 text-xs shrink-0"><span class="text-slate-400">${formatARS(item.basePrice)} c/u</span></div>
                <div class="flex-1"></div>
                <input type="number" min="1" value="${item.qty}" class="qty-input w-16 text-center py-1 px-1 border border-slate-200 rounded-lg text-xs font-semibold text-slate-800 focus:outline-none focus:ring-2 focus:ring-violet-400 transition"/>
                <span class="text-xs font-bold text-violet-600 w-20 text-right subtotal-label">${formatARS(itemTotal(item))}</span>
            </div>`;
    }

    function addCartRowToPanel(item: CartItem, containerId: string, emptyId: string) {
        const container = document.getElementById(containerId)!;
        const emptyEl   = document.getElementById(emptyId);
        if (emptyEl) emptyEl.style.display = "none";

        const row = document.createElement("div");
        row.className = "px-5 py-3"; row.dataset.rowId = item.id;
        row.innerHTML = buildCartRowHTML(item);

        if (item.pricePerKg) {
            row.querySelector<HTMLButtonElement>(".edit-weight-btn")?.addEventListener("click", () => {
                const ci = cart.find(c => c.id === item.id && c.pricePerKg);
                if (!ci) return;
                pendingWeightProduct = { id: ci.id, name: ci.name, basePrice: ci.basePrice, discounts: ci.discounts };
                weightModalTitle.textContent = ci.name;
                weightKgInput.value = String(Math.floor(ci.weightKg) || "");
                weightGInput.value  = String(Math.round((ci.weightKg - Math.floor(ci.weightKg)) * 1000) || "");
                weightPriceValue.textContent = formatARS(itemTotal(ci));
                weightModal.classList.remove("hidden");
                weightModalOk.onclick = () => {
                    if (!pendingWeightProduct) return;
                    const kg = parseInt(weightKgInput.value) || 0, g = parseInt(weightGInput.value) || 0;
                    const totalKg = kg + g / 1000; if (totalKg <= 0) { weightKgInput.focus(); return; }
                    ci.weightKg = totalKg; ci.weightLabel = formatWeight(totalKg);
                    ci.appliedDiscount = getApplicableDiscount(ci.discounts, totalKg);
                    refreshCartRow(ci); updateTotal(); closeWeightModal(); weightModalOk.onclick = null;
                };
            });
        } else {
            row.querySelector<HTMLInputElement>(".qty-input")!.addEventListener("input", (e) => {
                const val = parseInt((e.target as HTMLInputElement).value);
                if (isNaN(val) || val < 1) return;
                const ci = cart.find(c => c.id === item.id); if (!ci) return;
                ci.qty = val; ci.appliedDiscount = getApplicableDiscount(ci.discounts, val);
                refreshCartRow(ci); updateTotal();
            });
        }

        row.querySelector<HTMLButtonElement>(".remove-btn")!.addEventListener("click", () => {
            const idx = cart.findIndex(c => c.id === item.id);
            if (idx !== -1) cart.splice(idx, 1);
            document.querySelectorAll<HTMLElement>(`[data-row-id="${item.id}"]`).forEach(r => r.remove());
            if (cart.length === 0) { ["cart-empty-desktop","cart-empty-mobile"].forEach(id => { const el = document.getElementById(id); if (el) el.style.display = "block"; }); }
            updateTotal();
        });

        container.appendChild(row);
    }

    function addToCart(item: CartItem) {
        addCartRowToPanel(item, "cart-items-desktop", "cart-empty-desktop");
        addCartRowToPanel(item, "cart-items-mobile",  "cart-empty-mobile");
    }

    function clearCart() {
        cart.length = 0;
        ["cart-items-desktop","cart-items-mobile"].forEach(id => {
            const suffix = id === "cart-items-desktop" ? "desktop" : "mobile";
            document.getElementById(id)!.innerHTML = `<p id="cart-empty-${suffix}" class="text-sm text-slate-400 text-center py-8">El presupuesto está vacío</p>`;
        });
        document.querySelectorAll<HTMLElement>(".cart-total").forEach(el => el.textContent = "$ 0,00");
        document.querySelectorAll<HTMLElement>(".subtotal-row").forEach(el => el.classList.add("hidden"));
        document.querySelectorAll<HTMLElement>(".special-discount-row").forEach(el => el.classList.add("hidden"));
        document.querySelectorAll<HTMLButtonElement>(".confirm-budget-btn").forEach(btn => btn.disabled = true);
        updateBadge();
    }

    function initClientSection(container: HTMLElement) {
        const selectWrapper = container.querySelector<HTMLElement>(".client-select-wrapper")!;
        const clientSelect  = container.querySelector<HTMLSelectElement>(".client-select")!;
        const manualMode    = container.querySelector<HTMLElement>(".client-manual-mode")!;
        const manualInput   = container.querySelector<HTMLInputElement>(".client-manual-input")!;
        const clearBtn      = container.querySelector<HTMLButtonElement>(".clear-manual-btn")!;
        const switchManual  = container.querySelector<HTMLButtonElement>(".switch-to-manual")!;
        const switchSelect  = container.querySelector<HTMLButtonElement>(".switch-to-select")!;

        function showBadge(pct: number) {
            document.querySelectorAll<HTMLElement>(".special-discount-badge").forEach(b => { if (pct > 0) { b.classList.remove("hidden"); b.classList.add("flex"); } else { b.classList.add("hidden"); b.classList.remove("flex"); } });
            document.querySelectorAll<HTMLElement>(".special-discount-text").forEach(t => { t.textContent = pct > 0 ? `−${pct}% sobre el total` : ""; });
        }
        function setDiscount(pct: number) { activeSpecialDiscount = pct; showBadge(pct); refreshAllCartRows(); updateTotal(); }
        function resetClient() { activeClientId = null; activeClientName = null; activeSpecialDiscount = 0; showBadge(0); refreshAllCartRows(); updateTotal(); }

        switchManual?.addEventListener("click", () => {
            selectWrapper.classList.add("hidden"); manualMode.classList.remove("hidden"); clientSelect.value = ""; resetClient();
            setTimeout(() => manualInput.focus(), 50);
            document.querySelectorAll<HTMLElement>(".client-manual-mode").forEach(m => m.classList.remove("hidden"));
            document.querySelectorAll<HTMLElement>(".client-select-wrapper").forEach(w => w.classList.add("hidden"));
        });
        switchSelect?.addEventListener("click", () => {
            selectWrapper.classList.remove("hidden"); manualMode.classList.add("hidden"); manualInput.value = ""; clearBtn.classList.add("hidden"); resetClient();
            document.querySelectorAll<HTMLElement>(".client-manual-mode").forEach(m => m.classList.add("hidden"));
            document.querySelectorAll<HTMLElement>(".client-select-wrapper").forEach(w => w.classList.remove("hidden"));
        });
        clientSelect.addEventListener("change", () => {
            const sel = clientSelect.options[clientSelect.selectedIndex];
            activeClientId = clientSelect.value || null;
            activeClientName = activeClientId ? (sel.dataset.name ?? sel.text.split(" (")[0]) : null;
            const raw = sel.dataset.specialDiscount ?? "";
            document.querySelectorAll<HTMLSelectElement>(".client-select").forEach(s => s.value = clientSelect.value);
            setDiscount(raw !== "" ? parseFloat(raw) : 0);
        });
        manualInput.addEventListener("input", () => {
            const val = manualInput.value.trim(); activeClientId = null; activeClientName = val || null;
            clearBtn.classList.toggle("hidden", !val);
            document.querySelectorAll<HTMLInputElement>(".client-manual-input").forEach(i => { if (i !== manualInput) i.value = manualInput.value; });
            setDiscount(0);
        });
        clearBtn.addEventListener("click", () => {
            manualInput.value = "";
            document.querySelectorAll<HTMLInputElement>(".client-manual-input").forEach(i => i.value = "");
            clearBtn.classList.add("hidden");
            document.querySelectorAll<HTMLButtonElement>(".clear-manual-btn").forEach(b => b.classList.add("hidden"));
            activeClientName = null; setDiscount(0);
        });
    }

    initClientSection(document.getElementById("client-section-desktop")!);
    initClientSection(document.getElementById("client-section-mobile")!);
    document.getElementById("clear-cart-desktop")?.addEventListener("click", clearCart);
    document.getElementById("clear-cart-mobile")?.addEventListener("click", clearCart);

    document.getElementById("products-grid")?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".product-card") as HTMLElement | null;
        if (!btn) return;
        const id = btn.dataset.id!, name = btn.dataset.name!, basePrice = Number(btn.dataset.price);
        const pricePerKg = btn.dataset.pricePerKg === "true";
        let discounts: Discount[] = [];
        try { discounts = JSON.parse(btn.dataset.discounts ?? "[]"); } catch {}

        if (pricePerKg) { openWeightModal({ id, name, basePrice, discounts }); return; }

        const existing = cart.find(c => c.id === id && !c.pricePerKg);
        if (existing) { existing.qty++; existing.appliedDiscount = getApplicableDiscount(existing.discounts, existing.qty); refreshCartRow(existing); updateTotal(); }
        else { const ni: CartItem = { id, name, basePrice, discounts, qty: 1, pricePerKg: false, weightKg: 0, weightLabel: "", appliedDiscount: getApplicableDiscount(discounts, 1) }; cart.push(ni); addToCart(ni); updateTotal(); }
    });

    // ── Modal de confirmación ──────────────────────────────────────
    const confirmModal  = document.getElementById("confirm-budget-modal")!;
    const confirmCancel = document.getElementById("confirm-budget-cancel")!;
    const confirmPrint  = document.getElementById("confirm-print-btn") as HTMLButtonElement;
    const confirmSend   = document.getElementById("confirm-send-btn")  as HTMLButtonElement;
    const sendBtnText   = document.getElementById("send-btn-text")!;
    const sendSpinner   = document.getElementById("send-spinner")!;

    function openConfirmModal() {
        const totalItems = cart.reduce((a, c) => a + (c.pricePerKg ? 1 : c.qty), 0);
        document.getElementById("modal-client-name")!.textContent  = activeClientName || "Sin cliente";
        document.getElementById("modal-items-count")!.textContent  = `${totalItems} ítem${totalItems !== 1 ? "s" : ""}`;
        document.getElementById("modal-total")!.textContent        = formatARS(calcTotal());
        confirmModal.classList.remove("hidden");
    }
    function closeConfirmModal() { confirmModal.classList.add("hidden"); }

    confirmCancel.addEventListener("click", closeConfirmModal);
    confirmModal.addEventListener("click", (e) => { if (e.target === confirmModal) closeConfirmModal(); });
    document.querySelectorAll<HTMLButtonElement>(".confirm-budget-btn").forEach(btn => {
        btn.addEventListener("click", () => { if (cart.length > 0) openConfirmModal(); });
    });

    // ── Ticket HTML (igual estructura que ventas.astro, encabezado PRESUPUESTO) ──
    function buildTicketHTML(): string {
        const total    = calcTotal();
        const subtotal = calcSubtotal();
        const fecha    = new Date().toLocaleString("es-AR", { day: "2-digit", month: "2-digit", year: "numeric", hour: "2-digit", minute: "2-digit" });

        const rows = cart.map(it => {
            const label = it.pricePerKg ? it.weightLabel : `x${it.qty}`;
            return `<tr>
                <td style="padding:4px 0;font-size:12px;color:#111;vertical-align:top;">${it.name}</td>
                <td style="padding:4px 8px;font-size:12px;color:#111;text-align:center;">${label}</td>
                <td style="padding:4px 0;font-size:12px;color:#111;text-align:right;white-space:nowrap;">${formatARS(itemTotal(it))}</td>
            </tr>`;
        }).join("");

        const discountRow = activeSpecialDiscount > 0 ? `
            <tr>
                <td colspan="2" style="padding:3px 0;font-size:11px;color:#7c3aed;">Desc. especial ${activeSpecialDiscount}%</td>
                <td style="padding:3px 0;font-size:11px;color:#7c3aed;text-align:right;">−${formatARS(subtotal - total)}</td>
            </tr>` : "";

        return `<!DOCTYPE html>
        <html lang="es"><head><meta charset="utf-8"><title>Presupuesto</title>
        <style>*{margin:0;padding:0;box-sizing:border-box;}body{font-family:"Courier New",Courier,monospace;background:#fff;}@page{margin:0;size:80mm auto;}@media print{html,body{width:80mm;}.no-print{display:none!important;}}</style>
        </head><body>
        <div style="width:300px;max-width:100%;padding:14px 12px;margin:0 auto;">
            <div style="text-align:center;margin-bottom:10px;">
                <div style="display:inline-block;background:#7c3aed;color:#fff;font-size:10px;font-weight:bold;padding:5px 14px;border-radius:5px;letter-spacing:0.6px;font-family:Arial,sans-serif;">${EMPRESA_NOMBRE.toUpperCase()}</div>
                <p style="margin-top:6px;font-size:11px;color:#555;font-family:Arial,sans-serif;">Tel: +${EMPRESA_TELEFONO}</p>
                <p style="font-size:11px;color:#555;font-family:Arial,sans-serif;">${fecha}</p>
                <p style="margin-top:5px;font-size:13px;font-weight:bold;letter-spacing:2px;color:#7c3aed;font-family:Arial,sans-serif;">PRESUPUESTO</p>
            </div>
            <div style="border-top:1px dashed #bbb;margin-bottom:8px;"></div>
            ${activeClientName ? `<p style="font-size:11px;color:#555;margin-bottom:6px;font-family:Arial,sans-serif;">Cliente: <strong>${activeClientName}</strong></p>` : ""}
            <table style="width:100%;border-collapse:collapse;">
                <thead><tr style="border-bottom:1px solid #ddd;">
                    <th style="padding:2px 0;font-size:10px;color:#888;text-align:left;font-family:Arial,sans-serif;">PRODUCTO</th>
                    <th style="padding:2px 8px;font-size:10px;color:#888;text-align:center;font-family:Arial,sans-serif;">CANT</th>
                    <th style="padding:2px 0;font-size:10px;color:#888;text-align:right;font-family:Arial,sans-serif;">IMPORTE</th>
                </tr></thead>
                <tbody>${rows}${discountRow}</tbody>
            </table>
            <div style="border-top:1px dashed #bbb;margin:8px 0;"></div>
            <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
                <span style="font-size:14px;font-weight:bold;font-family:Arial,sans-serif;">TOTAL</span>
                <span style="font-size:16px;font-weight:bold;color:#7c3aed;font-family:Arial,sans-serif;">${formatARS(total)}</span>
            </div>
            <div style="border-top:1px dashed #bbb;margin:10px 0 8px;"></div>
            <p style="text-align:center;font-size:10px;color:#aaa;font-style:italic;font-family:Arial,sans-serif;">Este presupuesto no constituye una factura</p>
            <p style="text-align:center;font-size:11px;color:#aaa;font-style:italic;font-family:Arial,sans-serif;">¡Gracias por consultarnos!</p>
            <div class="no-print" style="margin-top:18px;text-align:center;display:flex;gap:8px;justify-content:center;">
                <button onclick="window.print()" style="background:#7c3aed;color:#fff;border:none;padding:9px 22px;border-radius:8px;font-size:13px;cursor:pointer;font-family:Arial,sans-serif;font-weight:600;">🖨️ Imprimir</button>
                <button onclick="window.close()" style="background:#e2e8f0;color:#475569;border:none;padding:9px 18px;border-radius:8px;font-size:13px;cursor:pointer;font-family:Arial,sans-serif;">Cerrar</button>
            </div>
        </div></body></html>`;
    }

    // ── Imprimir ───────────────────────────────────────────────────
    confirmPrint.addEventListener("click", () => {
        const win = window.open("", "_blank", "width=400,height=600");
        if (!win) return;
        win.document.write(buildTicketHTML());
        win.document.close();
        setTimeout(() => win.print(), 500);
    });

    // ── Enviar a caja ──────────────────────────────────────────────
    confirmSend.addEventListener("click", async () => {
        confirmSend.disabled = true; sendBtnText.textContent = "Enviando..."; sendSpinner.classList.remove("hidden");
        try {
            const total = calcTotal(), subtotal = calcSubtotal();
            const { data: sessionData } = await supabase.auth.getSession();
            const userId = sessionData?.session?.user?.id;

            const { data: budget, error: budgetErr } = await supabase
                .from("budgets")
                .insert([{
                    items: cart.map(c => ({
                        product_id: c.id, name: c.name, price: c.basePrice,
                        qty: c.pricePerKg ? c.weightKg : c.qty, subtotal: itemTotal(c),
                        pricePerKg: c.pricePerKg, weightLabel: c.weightLabel || null,
                    })),
                    total, client_id: activeClientId || null, client_name: activeClientName || null, status: "pendiente",
                }])
                .select().single();
            if (budgetErr) throw budgetErr;

            const { error: notifErr } = await supabase.from("notifications").insert([{
                user_id: userId, type: "nueva_venta",
                message: `Presupuesto${activeClientName ? ` — ${activeClientName}` : ""}: ${formatARS(total)}`,
                data: JSON.stringify({
                    sale_id: budget.id, budget_id: budget.id, is_budget: true,
                    total, subtotal, client_id: activeClientId, client_name: activeClientName,
                    special_discount_pct: activeSpecialDiscount,
                    items: cart.map(c => ({ name: c.name, qty: c.pricePerKg ? c.weightLabel : c.qty, subtotal: itemTotal(c) })),
                }),
                read: false,
            }]);
            if (notifErr) throw notifErr;

            closeConfirmModal(); clearCart(); closeMobileCart();
            document.querySelectorAll<HTMLSelectElement>(".client-select").forEach(s => s.value = "");
            document.querySelectorAll<HTMLInputElement>(".client-manual-input").forEach(i => i.value = "");
            document.querySelectorAll<HTMLButtonElement>(".clear-manual-btn").forEach(b => b.classList.add("hidden"));
            activeClientId = null; activeClientName = null; activeSpecialDiscount = 0;
            document.querySelectorAll<HTMLElement>(".special-discount-badge").forEach(b => { b.classList.add("hidden"); b.classList.remove("flex"); });

            const toast = document.createElement("div");
            toast.className = "fixed bottom-6 left-1/2 -translate-x-1/2 z-50 flex items-center gap-2 bg-slate-800 text-white text-sm font-medium px-4 py-3 rounded-2xl shadow-xl";
            toast.innerHTML = `<svg class="w-4 h-4 text-emerald-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg> Presupuesto enviado a caja`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 3000);

        } catch (err: any) {
            alert("Error al enviar: " + (err?.message ?? "Error desconocido"));
        } finally {
            confirmSend.disabled = false; sendBtnText.textContent = "Enviar a caja"; sendSpinner.classList.add("hidden");
        }
    });
</script>