---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabaseClient.js";

const { data: clients } = await supabase.from("clients").select("*");
const { data: debts } = await supabase
    .from("debts")
    .select("*, clients(name), sales(created_at, payment_method, sale_items(quantity, price, products(name)))")
    .eq("paid", false);

const formatMoney = (amount: number | null) => {
    if (amount == null) return "—";
    return new Intl.NumberFormat("es-AR", { style: "currency", currency: "ARS" }).format(amount);
};

const getInitials = (name: string) => {
    return name.split(" ").slice(0, 2).map((n) => n[0]).join("").toUpperCase();
};

const totalDeuda = clients?.reduce((acc, c) => acc + (c.debt ?? 0), 0) ?? 0;
const conDeuda = clients?.filter((c) => (c.debt ?? 0) > 0).length ?? 0;

const debtsByClient = debts?.reduce((acc, d) => {
    const cid = d.client_id;
    if (!acc[cid]) acc[cid] = [];
    acc[cid].push(d);
    return acc;
}, {} as Record<string, any[]>) ?? {};
---

<Layout>
    <div class="min-h-screen bg-slate-50 px-4 sm:px-6 py-6 sm:py-8 pt-20 lg:pt-6 sm:pt-20 lg:pt-8">
        <div class="max-w-4xl mx-auto">

            <!-- Header -->
            <div class="flex items-center justify-between gap-3 mb-6 sm:mb-8">
                <div class="flex items-center gap-3 min-w-0">
                    <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-blue-600 flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                        </svg>
                    </div>
                    <div class="min-w-0">
                        <h1 class="text-xl sm:text-2xl font-bold text-slate-800 leading-tight">Clientes</h1>
                        <p class="text-xs sm:text-sm text-slate-500 truncate">Listado general y estado de deudas</p>
                    </div>
                </div>
                <button
                    id="open-client-modal"
                    class="inline-flex items-center gap-1.5 sm:gap-2 bg-blue-600 hover:bg-blue-700 active:scale-95 text-white text-xs sm:text-sm font-semibold px-3 sm:px-4 py-2 sm:py-2.5 rounded-xl transition-all shrink-0"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    <span class="hidden xs:inline">Nuevo cliente</span>
                    <span class="xs:hidden">Nuevo</span>
                </button>
            </div>

            <!-- Stats -->
            <div class="grid grid-cols-3 gap-2 sm:gap-4 mb-5 sm:mb-6">
                <div class="bg-white border border-slate-200 rounded-xl px-3 sm:px-5 py-3 sm:py-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wide font-semibold mb-1 leading-tight">Total</p>
                    <p class="text-xl sm:text-2xl font-bold text-slate-800">{clients?.length ?? 0}</p>
                </div>
                <div class="bg-white border border-slate-200 rounded-xl px-3 sm:px-5 py-3 sm:py-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wide font-semibold mb-1 leading-tight">Con deuda</p>
                    <p class="text-xl sm:text-2xl font-bold text-orange-600">{conDeuda}</p>
                </div>
                <div class="bg-white border border-slate-200 rounded-xl px-3 sm:px-5 py-3 sm:py-4">
                    <p class="text-xs text-slate-500 uppercase tracking-wide font-semibold mb-1 leading-tight">Deuda total</p>
                    <p class="text-xl sm:text-2xl font-bold text-red-600 break-all">{formatMoney(totalDeuda)}</p>
                </div>
            </div>

            <!-- Lista clientes -->
            <div class="space-y-3">
                {clients && clients.length > 0 ? clients.map((c) => {
                    const hasDebt = (c.debt ?? 0) > 0;
                    const clientDebts = debtsByClient[c.id] ?? [];
                    const isSpecial = c.special_discount != null && c.special_discount > 0;
                    return (
                        <div class={`bg-white border rounded-2xl shadow-sm overflow-hidden transition-all ${hasDebt ? "border-red-200" : "border-slate-200"}`}>

                            <div class="flex items-center gap-3 sm:gap-4 px-4 sm:px-5 py-3.5 sm:py-4">
                                <!-- Avatar -->
                                <div class={`w-9 h-9 sm:w-10 sm:h-10 rounded-full flex items-center justify-center shrink-0 ${hasDebt ? "bg-red-100" : isSpecial ? "bg-violet-100" : "bg-blue-100"}`}>
                                    <span class={`text-xs sm:text-sm font-bold ${hasDebt ? "text-red-700" : isSpecial ? "text-violet-700" : "text-blue-700"}`}>
                                        {getInitials(c.name ?? "?")}
                                    </span>
                                </div>

                                <!-- Info -->
                                <div class="flex-1 min-w-0">
                                    <div class="flex items-center gap-1.5 flex-wrap">
                                        <p class="font-semibold text-slate-800 truncate text-sm sm:text-base">{c.name}</p>
                                        {hasDebt && (
                                            <span class="inline-block px-1.5 sm:px-2 py-0.5 rounded-full text-xs font-semibold bg-red-100 text-red-600">
                                                Deudor
                                            </span>
                                        )}
                                        {isSpecial && (
                                            <span class="hidden sm:inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-violet-100 text-violet-700">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                                                </svg>
                                                -{c.special_discount}% especial
                                            </span>
                                        )}
                                    </div>
                                    <p class="text-xs text-slate-500 flex items-center gap-1 mt-0.5">
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
                                        </svg>
                                        <span class="truncate">{c.phone ?? "Sin teléfono"}</span>
                                    </p>
                                </div>

                                <!-- Acciones -->
                                <div class="flex items-center gap-1.5 sm:gap-2 shrink-0">
                                    {hasDebt ? (
                                        <div class="text-right">
                                            <p class="text-xs text-slate-400 mb-0.5 hidden sm:block">Deuda</p>
                                            <span class="inline-block px-2 sm:px-2.5 py-1 rounded-lg text-xs sm:text-sm font-bold bg-red-50 text-red-700 whitespace-nowrap">
                                                {formatMoney(c.debt)}
                                            </span>
                                        </div>
                                    ) : (
                                        <span class="hidden sm:inline-block px-2.5 py-1 rounded-lg text-xs font-medium bg-emerald-50 text-emerald-700">
                                            Al día
                                        </span>
                                    )}

                                    <button
                                        class="edit-client-btn w-7 h-7 rounded-lg bg-slate-100 hover:bg-blue-100 flex items-center justify-center transition-colors"
                                        data-client-id={c.id}
                                        data-client-name={c.name}
                                        data-client-phone={c.phone ?? ""}
                                        data-client-notes={c.notes ?? ""}
                                        data-client-special-discount={c.special_discount ?? ""}
                                    >
                                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500 hover:text-blue-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M11 5H6a2 2 0 00-2 2v11a2 2 0 002 2h11a2 2 0 002-2v-5m-1.414-9.414a2 2 0 112.828 2.828L11.828 15H9v-2.828l8.586-8.586z" />
                                        </svg>
                                    </button>

                                    {clientDebts.length > 0 && (
                                        <button
                                            class="toggle-debts w-7 h-7 rounded-lg bg-slate-100 hover:bg-slate-200 flex items-center justify-center transition-colors"
                                            data-client-id={c.id}
                                        >
                                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500 chevron transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                                            </svg>
                                        </button>
                                    )}
                                </div>
                            </div>

                            {clientDebts.length > 0 && (
                            <div class="debt-detail hidden border-t border-red-100 bg-red-50/50" data-for-client={c.id}>
                                <div class="px-4 sm:px-5 py-3 space-y-3">
                                    <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Detalle de deudas</p>
                                    {clientDebts.map((d: any) => (
                                        <div class="bg-white border border-red-100 rounded-xl p-3">
                                            <div class="flex items-center justify-between mb-2">
                                                <p class="text-xs text-slate-500">
                                                    {d.sales?.created_at
                                                        ? new Date(d.sales.created_at).toLocaleDateString("es-AR", {
                                                            day: "2-digit", month: "2-digit", year: "numeric"
                                                        })
                                                        : "—"
                                                    }
                                                </p>
                                                <span class="text-sm font-bold text-red-700">{formatMoney(d.current_total)}</span>
                                            </div>
                                            {d.sales?.sale_items && d.sales.sale_items.length > 0 && (
                                                <div class="border-t border-slate-100 pt-2 space-y-1">
                                                    {d.sales.sale_items.map((item: any) => (
                                                        <div class="flex items-center justify-between gap-2">
                                                            <span class="text-xs text-slate-600 truncate">
                                                                {item.products?.name ?? "Producto"} × {item.quantity}
                                                            </span>
                                                            <span class="text-xs font-medium text-slate-700 shrink-0">
                                                                {formatMoney(item.price * item.quantity)}
                                                            </span>
                                                        </div>
                                                    ))}
                                                </div>
                                            )}
                                            <div class="mt-2 pt-2 border-t border-slate-100 flex justify-end">
                                                <button
                                                    class="mark-paid-btn px-3 py-1.5 bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold rounded-lg transition-colors"
                                                    data-debt-id={d.id}
                                                    data-client-id={c.id}
                                                    data-amount={d.current_total}
                                                >
                                                    Marcar pagado
                                                </button>
                                            </div>
                                        </div>
                                    ))}
                                </div>
                            </div>
                            )}
                        </div>
                    );
                }) : (
                    <div class="flex flex-col items-center justify-center py-14 sm:py-16 text-center bg-white border border-slate-200 rounded-2xl px-4">
                        <div class="w-12 h-12 rounded-2xl bg-slate-100 flex items-center justify-center mb-3">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </div>
                        <p class="text-slate-500 text-sm">No hay clientes registrados todavía</p>
                        <p class="text-slate-400 text-xs mt-1">Hacé click en "Nuevo cliente" para agregar uno</p>
                    </div>
                )}
            </div>

            {clients && clients.length > 0 && (
                <p class="text-xs text-slate-400 mt-4 text-right">
                    {clients.length} {clients.length === 1 ? "cliente" : "clientes"} en total
                </p>
            )}

        </div>
    </div>

    <!-- Modal nuevo cliente -->
    <div id="client-modal-overlay" class="hidden fixed inset-0 bg-black/40 z-50 flex items-end sm:items-center justify-center sm:px-4">
        <div class="bg-white rounded-t-2xl sm:rounded-2xl shadow-xl w-full sm:max-w-md max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between px-5 sm:px-6 py-4 border-b border-slate-100 sticky top-0 bg-white z-10">
                <h2 class="text-base font-semibold text-slate-800">Nuevo cliente</h2>
                <button id="close-client-modal" class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="px-5 sm:px-6 py-5 space-y-4">
                <div id="modal-client-error" class="hidden px-3 py-2 rounded-xl bg-red-50 border border-red-200 text-red-700 text-xs"></div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Nombre *</label>
                    <input id="client-name" type="text" placeholder="Nombre completo"
                        class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                    />
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Teléfono</label>
                    <input id="client-phone" type="tel" placeholder="Ej: 351 123 4567"
                        class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                    />
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Observaciones</label>
                    <textarea id="client-notes" rows="3" placeholder="Notas adicionales..."
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
                    ></textarea>
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-violet-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                        </svg>
                        Descuento especial
                    </label>
                    <div class="relative">
                        <input id="client-special-discount" type="number" min="0" max="100" step="0.01" placeholder="Dejar vacío si no tiene"
                            class="w-full px-3 py-2.5 pr-8 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
                        />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-slate-400 pointer-events-none">%</span>
                    </div>
                    <p class="text-xs text-slate-400">Se aplica sobre el total de cada compra. Reemplaza los descuentos por cantidad.</p>
                </div>
            </div>
            <div class="px-5 sm:px-6 py-4 border-t border-slate-100 flex gap-3">
                <button id="cancel-client-modal" class="flex-1 py-2.5 rounded-xl text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors">Cancelar</button>
                <button id="save-client-btn" class="flex-1 py-2.5 rounded-xl text-sm font-semibold bg-blue-600 hover:bg-blue-700 text-white transition-colors flex items-center justify-center gap-2 disabled:bg-blue-300 disabled:cursor-not-allowed">
                    <span id="save-client-text">Guardar</span>
                    <svg id="save-client-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 0v4a8 8 0 00-8 8H0z"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <!-- Modal editar cliente -->
    <div id="edit-client-modal-overlay" class="hidden fixed inset-0 bg-black/40 z-50 flex items-end sm:items-center justify-center sm:px-4">
        <div class="bg-white rounded-t-2xl sm:rounded-2xl shadow-xl w-full sm:max-w-md max-h-[90vh] overflow-y-auto">
            <div class="flex items-center justify-between px-5 sm:px-6 py-4 border-b border-slate-100 sticky top-0 bg-white z-10">
                <h2 class="text-base font-semibold text-slate-800">Editar cliente</h2>
                <button id="close-edit-client-modal" class="w-8 h-8 flex items-center justify-center rounded-lg text-slate-400 hover:text-slate-600 hover:bg-slate-100 transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                    </svg>
                </button>
            </div>
            <div class="px-5 sm:px-6 py-5 space-y-4">
                <div id="edit-client-error" class="hidden px-3 py-2 rounded-xl bg-red-50 border border-red-200 text-red-700 text-xs"></div>
                <input id="edit-client-id" type="hidden" />
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Nombre *</label>
                    <input id="edit-client-name" type="text" placeholder="Nombre completo"
                        class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                    />
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Teléfono</label>
                    <input id="edit-client-phone" type="tel" placeholder="Ej: 351 123 4567"
                        class="w-full px-3 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"
                    />
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Observaciones</label>
                    <textarea id="edit-client-notes" rows="3" placeholder="Notas adicionales..."
                        class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition resize-none"
                    ></textarea>
                </div>
                <div class="space-y-1.5">
                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide flex items-center gap-1.5">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-violet-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" />
                        </svg>
                        Descuento especial
                    </label>
                    <div class="relative">
                        <input id="edit-client-special-discount" type="number" min="0" max="100" step="0.01" placeholder="Dejar vacío si no tiene"
                            class="w-full px-3 py-2.5 pr-8 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
                        />
                        <span class="absolute right-3 top-1/2 -translate-y-1/2 text-sm text-slate-400 pointer-events-none">%</span>
                    </div>
                    <p class="text-xs text-slate-400">Se aplica sobre el total de cada compra. Reemplaza los descuentos por cantidad.</p>
                </div>
            </div>
            <div class="px-5 sm:px-6 py-4 border-t border-slate-100 flex gap-2 sm:gap-3">
                <button id="cancel-edit-client-modal" class="flex-1 py-2.5 rounded-xl text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors">Cancelar</button>
                <button id="delete-client-btn" class="py-2.5 px-3 sm:px-4 rounded-xl text-sm font-semibold bg-red-50 hover:bg-red-100 text-red-600 transition-colors">Eliminar</button>
                <button id="update-client-btn" class="flex-1 py-2.5 rounded-xl text-sm font-semibold bg-blue-600 hover:bg-blue-700 text-white transition-colors flex items-center justify-center gap-2 disabled:bg-blue-300 disabled:cursor-not-allowed">
                    <span id="update-client-text">Guardar</span>
                    <svg id="update-client-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 0v4a8 8 0 00-8 8H0z"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

</Layout>

<script>
    import { supabase } from "../lib/supabaseClient.js";

    // --- Toggle deudas ---
    document.querySelectorAll<HTMLButtonElement>(".toggle-debts").forEach((btn) => {
        btn.addEventListener("click", () => {
            const clientId = btn.dataset.clientId!;
            const detail = document.querySelector<HTMLElement>(`.debt-detail[data-for-client="${clientId}"]`);
            const chevron = btn.querySelector<HTMLElement>(".chevron");
            if (!detail) return;
            const isHidden = detail.classList.contains("hidden");
            detail.classList.toggle("hidden", !isHidden);
            if (chevron) chevron.style.transform = isHidden ? "rotate(180deg)" : "";
        });
    });

    // --- Marcar pagado ---
    document.querySelectorAll<HTMLButtonElement>(".mark-paid-btn").forEach((btn) => {
        btn.addEventListener("click", async () => {
            const debtId = btn.dataset.debtId!;
            const clientId = btn.dataset.clientId!;
            const amount = Number(btn.dataset.amount);

            btn.disabled = true;
            btn.textContent = "Guardando...";

            try {
                const { error: debtError } = await supabase
                    .from("debts").update({ paid: true }).eq("id", debtId);
                if (debtError) throw debtError;

                const { data: clientData } = await supabase
                    .from("clients").select("debt").eq("id", clientId).single();
                const newDebt = Math.max(0, (clientData?.debt ?? 0) - amount);
                await supabase.from("clients").update({ debt: newDebt }).eq("id", clientId);

                window.location.reload();
            } catch (err: any) {
                alert("Error: " + (err?.message ?? "No se pudo marcar como pagado"));
                btn.disabled = false;
                btn.textContent = "Marcar pagado";
            }
        });
    });

    // --- Modal nuevo cliente ---
    const overlay        = document.getElementById("client-modal-overlay")!;
    const nameInput      = document.getElementById("client-name")             as HTMLInputElement;
    const phoneInput     = document.getElementById("client-phone")            as HTMLInputElement;
    const notesInput     = document.getElementById("client-notes")            as HTMLTextAreaElement;
    const discountInput  = document.getElementById("client-special-discount") as HTMLInputElement;
    const saveBtn        = document.getElementById("save-client-btn")         as HTMLButtonElement;
    const saveText       = document.getElementById("save-client-text")!;
    const saveSpinner    = document.getElementById("save-client-spinner")!;
    const errorEl        = document.getElementById("modal-client-error")!;

    function openModal() {
        nameInput.value     = "";
        phoneInput.value    = "";
        notesInput.value    = "";
        discountInput.value = "";
        errorEl.classList.add("hidden");
        overlay.classList.remove("hidden");
        setTimeout(() => nameInput.focus(), 100);
    }

    function closeModal() { overlay.classList.add("hidden"); }

    function setLoading(loading: boolean) {
        saveBtn.disabled = loading;
        saveText.textContent = loading ? "Guardando..." : "Guardar";
        saveSpinner.classList.toggle("hidden", !loading);
    }

    document.getElementById("open-client-modal")?.addEventListener("click", openModal);
    document.getElementById("close-client-modal")?.addEventListener("click", closeModal);
    document.getElementById("cancel-client-modal")?.addEventListener("click", closeModal);
    overlay.addEventListener("click", (e) => { if (e.target === overlay) closeModal(); });

    saveBtn.addEventListener("click", async () => {
        errorEl.classList.add("hidden");
        const name     = nameInput.value.trim();
        const phone    = phoneInput.value.trim();
        const notes    = notesInput.value.trim();
        const rawDisc  = discountInput.value.trim();
        const special_discount = rawDisc !== "" ? parseFloat(rawDisc) : null;

        if (!name) {
            errorEl.textContent = "El nombre es obligatorio.";
            errorEl.classList.remove("hidden");
            return;
        }
        if (special_discount !== null && (isNaN(special_discount) || special_discount < 0 || special_discount > 100)) {
            errorEl.textContent = "El descuento especial debe estar entre 0 y 100.";
            errorEl.classList.remove("hidden");
            return;
        }

        setLoading(true);
        try {
            const { error } = await supabase
                .from("clients")
                .insert([{ name, phone: phone || null, notes: notes || null, special_discount }]);
            if (error) throw error;
            closeModal();
            window.location.reload();
        } catch (err: any) {
            errorEl.textContent = err?.message ?? "Error al guardar el cliente.";
            errorEl.classList.remove("hidden");
        } finally {
            setLoading(false);
        }
    });

    [nameInput, phoneInput].forEach((input) => {
        input.addEventListener("keydown", (e) => { if (e.key === "Enter") saveBtn.click(); });
    });

    // --- Editar cliente ---
    const editOverlay         = document.getElementById("edit-client-modal-overlay")!;
    const editIdInput         = document.getElementById("edit-client-id")              as HTMLInputElement;
    const editNameInput       = document.getElementById("edit-client-name")            as HTMLInputElement;
    const editPhoneInput      = document.getElementById("edit-client-phone")           as HTMLInputElement;
    const editNotesInput      = document.getElementById("edit-client-notes")           as HTMLTextAreaElement;
    const editDiscountInput   = document.getElementById("edit-client-special-discount") as HTMLInputElement;
    const updateBtn           = document.getElementById("update-client-btn")           as HTMLButtonElement;
    const updateText          = document.getElementById("update-client-text")!;
    const updateSpinner       = document.getElementById("update-client-spinner")!;
    const editErrorEl         = document.getElementById("edit-client-error")!;

    function openEditModal(id: string, name: string, phone: string, notes: string, specialDiscount: string) {
        editIdInput.value       = id;
        editNameInput.value     = name;
        editPhoneInput.value    = phone;
        editNotesInput.value    = notes;
        editDiscountInput.value = specialDiscount;
        editErrorEl.classList.add("hidden");
        editOverlay.classList.remove("hidden");
        setTimeout(() => editNameInput.focus(), 100);
    }

    function closeEditModal() { editOverlay.classList.add("hidden"); }

    function setUpdateLoading(loading: boolean) {
        updateBtn.disabled = loading;
        updateText.textContent = loading ? "Guardando..." : "Guardar";
        updateSpinner.classList.toggle("hidden", !loading);
    }

    document.querySelectorAll<HTMLButtonElement>(".edit-client-btn").forEach((btn) => {
        btn.addEventListener("click", () => {
            openEditModal(
                btn.dataset.clientId!,
                btn.dataset.clientName!,
                btn.dataset.clientPhone!,
                btn.dataset.clientNotes!,
                btn.dataset.clientSpecialDiscount ?? "",
            );
        });
    });

    document.getElementById("close-edit-client-modal")?.addEventListener("click", closeEditModal);
    document.getElementById("cancel-edit-client-modal")?.addEventListener("click", closeEditModal);
    editOverlay.addEventListener("click", (e) => { if (e.target === editOverlay) closeEditModal(); });

    updateBtn.addEventListener("click", async () => {
        editErrorEl.classList.add("hidden");
        const id       = editIdInput.value;
        const name     = editNameInput.value.trim();
        const phone    = editPhoneInput.value.trim();
        const notes    = editNotesInput.value.trim();
        const rawDisc  = editDiscountInput.value.trim();
        const special_discount = rawDisc !== "" ? parseFloat(rawDisc) : null;

        if (!name) {
            editErrorEl.textContent = "El nombre es obligatorio.";
            editErrorEl.classList.remove("hidden");
            return;
        }
        if (special_discount !== null && (isNaN(special_discount) || special_discount < 0 || special_discount > 100)) {
            editErrorEl.textContent = "El descuento especial debe estar entre 0 y 100.";
            editErrorEl.classList.remove("hidden");
            return;
        }

        setUpdateLoading(true);
        try {
            const { error } = await supabase
                .from("clients")
                .update({ name, phone: phone || null, notes: notes || null, special_discount })
                .eq("id", id);
            if (error) throw error;
            closeEditModal();
            window.location.reload();
        } catch (err: any) {
            editErrorEl.textContent = err?.message ?? "Error al actualizar el cliente.";
            editErrorEl.classList.remove("hidden");
        } finally {
            setUpdateLoading(false);
        }
    });

    // --- Eliminar cliente ---
    const deleteClientBtn = document.getElementById("delete-client-btn") as HTMLButtonElement;

    deleteClientBtn.addEventListener("click", async () => {
        const id = editIdInput.value;
        if (!id) return;
        if (!confirm("¿Eliminar este cliente? Esta acción no se puede deshacer.")) return;

        deleteClientBtn.disabled = true;
        deleteClientBtn.textContent = "Eliminando...";

        try {
            const { error } = await supabase.from("clients").delete().eq("id", id);
            if (error) throw error;
            closeEditModal();
            window.location.reload();
        } catch (err: any) {
            editErrorEl.textContent = err?.message ?? "Error al eliminar el cliente.";
            editErrorEl.classList.remove("hidden");
            deleteClientBtn.disabled = false;
            deleteClientBtn.textContent = "Eliminar";
        }
    });
</script>