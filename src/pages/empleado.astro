---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabaseClient.js";

const { data: { user } } = await supabase.auth.getUser();
const role = user?.user_metadata?.role ?? "empleado";
const isEmployee = role !== "admin";
const { data: products } = await supabase.from("products").select("*");
const { data: allDiscounts } = await supabase.from("product_discounts").select("*");
const { data: clients } = await supabase
    .from("clients")
    .select("id, name, special_discount")
    .order("name");

const discountsByProduct: Record<string, any[]> = {};
allDiscounts?.forEach((d) => {
    if (!discountsByProduct[d.product_id]) discountsByProduct[d.product_id] = [];
    discountsByProduct[d.product_id].push(d);
});
Object.values(discountsByProduct).forEach((arr) =>
    arr.sort((a, b) => b.min_qty - a.min_qty)
);

const formatMoney = (amount: number | null) => {
    if (amount == null) return "—";
    return "$ " + new Intl.NumberFormat("es-AR", {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
    }).format(amount);
};

const EMPLEADAS = ["Rocío", "Victoria", "Valeria"];

const clientsJSON = JSON.stringify(
    (clients ?? []).map((c) => ({
        id: c.id,
        name: c.name,
        special_discount: c.special_discount ?? null,
    }))
);

// Categorías únicas extraídas de los productos
const categoryNames = [...new Set((products ?? []).map((p: any) => p.category).filter(Boolean))].sort();
---

<Layout isEmployee={isEmployee}>
    <div class="min-h-screen bg-slate-50 px-4 sm:px-6 py-6 sm:py-8 pt-20 lg:pt-6 sm:pt-20 lg:pt-8">
        <div class="max-w-5xl mx-auto">

            <!-- Header con selector de empleada -->
            <div class="flex flex-col sm:flex-row sm:items-center gap-3 sm:gap-4 mb-6 sm:mb-8">
                <div class="flex items-center gap-3 sm:gap-4 flex-1">
                    <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-indigo-600 flex items-center justify-center shrink-0">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
                        </svg>
                    </div>
                    <div>
                        <h1 class="text-xl sm:text-2xl font-bold text-slate-800 leading-tight">Panel Empleado</h1>
                        <p class="text-xs sm:text-sm text-slate-500">Seleccioná productos para registrar una venta</p>
                    </div>
                </div>

                <!-- Selector de empleada -->
                <div class="flex items-center gap-2 bg-white border border-slate-200 rounded-xl px-3 py-2 shadow-sm self-start sm:self-auto">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-400 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                    </svg>
                    <select id="seller-select" class="text-sm font-medium text-slate-700 bg-transparent focus:outline-none pr-1 cursor-pointer">
                        <option value="">— Quién vende —</option>
                        {EMPLEADAS.map((e) => <option value={e}>{e}</option>)}
                    </select>
                </div>
            </div>

            <div class="flex gap-6">

                <!-- Productos -->
                <div class="flex-1 min-w-0">

                    <!-- Buscador -->
                    <div class="relative mb-3 sm:mb-4">
                        <span class="absolute inset-y-0 left-3 flex items-center text-slate-400 pointer-events-none">
                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                            </svg>
                        </span>
                        <input id="search" type="text" placeholder="Buscar producto..."
                            class="w-full pl-9 pr-4 py-2.5 bg-white border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-transparent transition"
                        />
                    </div>

                    <!-- Filtros por categoría -->
                    {categoryNames.length > 0 && (
                        <div id="category-filters" class="flex flex-wrap gap-2 mb-4 sm:mb-5">
                            <button
                                class="category-filter-btn text-xs font-semibold px-3 py-1.5 rounded-xl border border-transparent bg-indigo-600 text-white transition-all"
                                data-category=""
                            >
                                Todos
                            </button>
                            {categoryNames.map((cat) => (
                                <button
                                    class="category-filter-btn text-xs font-semibold px-3 py-1.5 rounded-xl border border-slate-200 bg-white text-slate-600 hover:border-indigo-400 transition-all"
                                    data-category={cat}
                                >
                                    {cat}
                                </button>
                            ))}
                        </div>
                    )}

                    {products && products.length > 0 ? (
                        <div id="products-grid" class="grid grid-cols-2 sm:grid-cols-3 gap-2 sm:gap-3">
                            {products.map((p) => {
                                const discounts = discountsByProduct[p.id] ?? [];
                                return (
                                    <button type="button"
                                        class="product-card text-left bg-white border border-slate-200 rounded-2xl p-3 sm:p-4 hover:border-indigo-400 hover:shadow-md active:scale-95 transition-all duration-150 focus:outline-none focus:ring-2 focus:ring-indigo-500"
                                        data-id={p.id}
                                        data-name={p.name}
                                        data-price={p.price}
                                        data-category={p.category ?? ""}
                                        data-discounts={JSON.stringify(discounts)}>
                                        <div class="w-8 h-8 sm:w-9 sm:h-9 rounded-xl bg-indigo-50 flex items-center justify-center mb-2 sm:mb-3">
                                            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-indigo-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" />
                                            </svg>
                                        </div>
                                        <p class="text-xs sm:text-sm font-semibold text-slate-800 leading-tight mb-1 truncate">{p.name}</p>
                                        <p class="text-xs sm:text-sm font-bold text-indigo-600">{formatMoney(p.price)}</p>
                                        {p.stock != null && (
                                            <p class={`text-xs mt-1.5 font-medium ${p.stock <= 5 ? "text-red-500" : "text-slate-400"}`}>
                                                Stock: {p.stock}
                                            </p>
                                        )}
                                        {p.category && (
                                            <span class="inline-block mt-1.5 text-xs px-1.5 py-0.5 rounded-md bg-slate-100 text-slate-500 font-medium truncate max-w-full">
                                                {p.category}
                                            </span>
                                        )}
                                        {discounts.length > 0 && (
                                            <div class="flex flex-wrap gap-1 mt-2">
                                                {discounts.slice().reverse().map((d: any) => (
                                                    <span class="text-xs px-1.5 py-0.5 rounded-md bg-violet-50 text-violet-600 font-medium">
                                                        {d.label || `x${d.min_qty}`} -{d.discount_pct}%
                                                    </span>
                                                ))}
                                            </div>
                                        )}
                                    </button>
                                );
                            })}
                        </div>

                        <!-- Mensaje sin resultados del filtro -->
                        <div id="no-results" class="hidden flex flex-col items-center justify-center py-12 text-center">
                            <div class="w-10 h-10 rounded-2xl bg-slate-100 flex items-center justify-center mb-3">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.172 16.172a4 4 0 015.656 0M9 10h.01M15 10h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                                </svg>
                            </div>
                            <p class="text-slate-400 text-sm">No hay productos en esta categoría</p>
                        </div>
                    ) : (
                        <div class="flex flex-col items-center justify-center py-16 text-center bg-white border border-slate-200 rounded-2xl">
                            <p class="text-slate-400 text-sm">No hay productos disponibles</p>
                        </div>
                    )}
                    <div class="h-24 lg:hidden"></div>
                </div>

                <!-- Carrito desktop -->
                <div class="hidden lg:block w-72 shrink-0">
                    <div class="bg-white border border-slate-200 rounded-2xl shadow-sm sticky top-6">
                        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100">
                            <h2 class="font-semibold text-slate-800 text-sm">Venta actual</h2>
                            <button id="clear-cart-desktop" class="text-xs text-slate-400 hover:text-red-500 transition-colors">Limpiar</button>
                        </div>
                        <div class="px-5 pt-4 pb-3 border-b border-slate-100 space-y-2" id="client-section-desktop"></div>
                        <div id="cart-items-desktop" class="divide-y divide-slate-100 min-h-[120px]">
                            <p id="cart-empty-desktop" class="text-sm text-slate-400 text-center py-8">El carrito está vacío</p>
                        </div>
                        <div class="px-5 py-4 border-t border-slate-100 space-y-2" id="cart-footer-desktop"></div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- FAB mobile -->
    <button id="open-cart-mobile"
        class="lg:hidden fixed bottom-6 right-4 z-40 flex items-center gap-2 bg-indigo-600 hover:bg-indigo-700 active:scale-95 text-white font-semibold text-sm px-4 py-3 rounded-2xl shadow-lg transition-all">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" />
        </svg>
        <span>Venta actual</span>
        <span id="cart-badge" class="hidden bg-white text-indigo-600 text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center">0</span>
    </button>

    <!-- Overlay mobile -->
    <div id="cart-mobile-overlay" class="lg:hidden fixed inset-0 z-40 bg-black/40 opacity-0 pointer-events-none transition-opacity duration-200"></div>

    <!-- Drawer mobile -->
    <div id="cart-mobile-drawer"
        class="lg:hidden fixed bottom-0 left-0 right-0 z-50 bg-white rounded-t-2xl shadow-2xl translate-y-full transition-transform duration-300 ease-in-out max-h-[85vh] flex flex-col">
        <div class="flex items-center justify-between px-5 py-4 border-b border-slate-100 shrink-0">
            <h2 class="font-semibold text-slate-800 text-sm">Venta actual</h2>
            <div class="flex items-center gap-3">
                <button id="clear-cart-mobile" class="text-xs text-slate-400 hover:text-red-500 transition-colors">Limpiar</button>
                <button id="close-cart-mobile" class="w-7 h-7 rounded-lg bg-slate-100 hover:bg-slate-200 flex items-center justify-center transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-slate-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
                    </svg>
                </button>
            </div>
        </div>
        <div class="overflow-y-auto flex-1">
            <div class="px-5 pt-4 pb-3 border-b border-slate-100 space-y-2" id="client-section-mobile"></div>
            <div id="cart-items-mobile" class="divide-y divide-slate-100 min-h-[80px]">
                <p id="cart-empty-mobile" class="text-sm text-slate-400 text-center py-8">El carrito está vacío</p>
            </div>
        </div>
        <div class="px-5 py-4 border-t border-slate-100 space-y-2 shrink-0 bg-white" id="cart-footer-mobile"></div>
    </div>

    <!-- Modal confirmación de cobro -->
    <div id="confirm-sale-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm px-4">
        <div class="bg-white rounded-2xl shadow-xl w-full max-w-sm p-6 space-y-4">
            <div class="flex items-center gap-3">
                <div class="w-11 h-11 rounded-xl bg-indigo-50 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-indigo-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-bold text-slate-800">Confirmar cobro</p>
                    <p class="text-xs text-slate-400">Revisá el resumen antes de confirmar</p>
                </div>
            </div>

            <div class="bg-slate-50 rounded-xl px-4 py-3 space-y-2">
                <div class="flex justify-between items-center">
                    <span class="text-xs text-slate-500">Vendedora</span>
                    <span id="modal-seller-name" class="text-xs font-semibold text-slate-700">—</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-xs text-slate-500">Cliente</span>
                    <span id="modal-client-name" class="text-xs font-semibold text-slate-700">Sin cliente</span>
                </div>
                <div class="flex justify-between items-center">
                    <span class="text-xs text-slate-500">Productos</span>
                    <span id="modal-items-count" class="text-xs font-semibold text-slate-700">—</span>
                </div>
                <div class="border-t border-slate-200 pt-2 flex justify-between items-center">
                    <span class="text-sm font-medium text-slate-600">Total a cobrar</span>
                    <span id="modal-total" class="text-base font-bold text-indigo-600">$ 0,00</span>
                </div>
            </div>

            <p class="text-sm text-slate-600 text-center">¿Deseás registrar el cobro de esta nueva venta?</p>

            <div class="flex gap-2 pt-1">
                <button id="confirm-sale-cancel" type="button"
                    class="flex-1 py-2.5 rounded-xl text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors">
                    No, cancelar
                </button>
                <button id="confirm-sale-ok" type="button"
                    class="flex-1 py-2.5 rounded-xl text-sm font-semibold bg-indigo-600 hover:bg-indigo-700 text-white transition-colors flex items-center justify-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                    </svg>
                    <span id="confirm-ok-text">Sí, cobrar</span>
                    <svg id="confirm-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 0v4a8 8 0 00-8 8H0z"></path>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    <script type="application/json" id="clients-data" set:html={clientsJSON}></script>
</Layout>

<script>
    import { supabase } from "../lib/supabaseClient.js";

    interface Client   { id: string; name: string; special_discount: number | null; }
    interface Discount { id: string; min_qty: number; discount_pct: number; label?: string; }
    interface CartItem { id: string; name: string; basePrice: number; discounts: Discount[]; qty: number; appliedDiscount: number; }

    const cart: CartItem[] = [];
    let activeClientId:        string | null = null;
    let activeClientName:      string | null = null;
    let activeSpecialDiscount: number        = 0;
    let activeCategoryFilter:  string        = "";
    let activeSearchQuery:     string        = "";

    const clientsRaw: Client[] = JSON.parse(
        document.getElementById("clients-data")!.textContent ?? "[]"
    );

    const sellerSelect  = document.getElementById("seller-select") as HTMLSelectElement;
    const getSellerName = () => sellerSelect?.value ?? "";

    const formatARS = (n: number) =>
        "$ " + new Intl.NumberFormat("es-AR", {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2,
        }).format(n);

    function getApplicableDiscount(discounts: Discount[], qty: number): number {
        for (const d of discounts) { if (qty >= d.min_qty) return d.discount_pct; }
        return 0;
    }
    function effectiveUnitPrice(item: CartItem): number {
        if (activeSpecialDiscount > 0) return item.basePrice;
        return item.basePrice * (1 - item.appliedDiscount / 100);
    }
    function calcSubtotal() { return cart.reduce((acc, c) => acc + effectiveUnitPrice(c) * c.qty, 0); }
    function calcTotal() {
        const sub = calcSubtotal();
        return activeSpecialDiscount > 0 ? sub * (1 - activeSpecialDiscount / 100) : sub;
    }

    // ── Filtro combinado: categoría + búsqueda ──────────────────────────────
    function applyFilters() {
        let visibleCount = 0;
        document.querySelectorAll<HTMLElement>(".product-card").forEach(card => {
            const matchesCategory = !activeCategoryFilter || card.dataset.category === activeCategoryFilter;
            const matchesSearch   = !activeSearchQuery || (card.dataset.name ?? "").toLowerCase().includes(activeSearchQuery);
            const visible = matchesCategory && matchesSearch;
            card.style.display = visible ? "" : "none";
            if (visible) visibleCount++;
        });
        const noResults = document.getElementById("no-results");
        if (noResults) {
            noResults.classList.toggle("hidden", visibleCount > 0);
            noResults.classList.toggle("flex", visibleCount === 0);
        }
    }

    // ── Filtros por categoría ───────────────────────────────────────────────
    document.getElementById("category-filters")?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".category-filter-btn") as HTMLElement | null;
        if (!btn) return;
        document.querySelectorAll(".category-filter-btn").forEach(b => {
        b.classList.remove("bg-indigo-600", "text-white", "border-indigo-600");
        b.classList.add("bg-white", "text-slate-600", "border-slate-200");
    });

    btn.classList.add("bg-indigo-600", "text-white", "border-indigo-600");
    btn.classList.remove("bg-white", "text-slate-600", "border-slate-200");
    document.querySelectorAll(".category-filter-btn").forEach(b => {
        b.classList.remove("bg-indigo-600", "text-white", "border-indigo-600");
        b.classList.add("bg-white", "text-slate-600", "border-slate-200");
    });

    btn.classList.add("bg-indigo-600", "text-white", "border-indigo-600");
    btn.classList.remove("bg-white", "text-slate-600", "border-slate-200");

        activeCategoryFilter = btn.dataset.category ?? "";
        applyFilters();
    });

    // ── Búsqueda ────────────────────────────────────────────────────────────
    document.getElementById("search")?.addEventListener("input", (e) => {
        activeSearchQuery = (e.target as HTMLInputElement).value.toLowerCase();
        applyFilters();
    });

    // ── Cart UI ─────────────────────────────────────────────────────────────
    function buildClientSectionHTML(): string {
        const opts = clientsRaw.map(c =>
            `<option value="${c.id}" data-name="${c.name}" data-special-discount="${c.special_discount ?? ''}">${c.name}${c.special_discount ? ` (−${c.special_discount}%)` : ''}</option>`
        ).join('');
        return `
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Cliente</label>
        <div class="client-select-wrapper">
            <div class="relative">
                <select class="client-select w-full py-2 pl-3 pr-8 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-indigo-400 transition appearance-none">
                    <option value="">— Sin cliente —</option>
                    ${opts}
                </select>
            </div>
            <button class="switch-to-manual mt-1.5 text-xs text-indigo-500 hover:text-indigo-700 font-medium transition-colors">+ Escribir nombre nuevo</button>
        </div>
        <div class="client-manual-mode hidden">
            <div class="relative">
                <input type="text" class="client-manual-input w-full px-3 py-2 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-indigo-400 transition" placeholder="Nombre del cliente..." />
                <button class="clear-manual-btn absolute right-2.5 top-1/2 -translate-y-1/2 text-slate-300 hover:text-slate-500 transition-colors hidden">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
            <button class="switch-to-select mt-1.5 text-xs text-indigo-500 hover:text-indigo-700 font-medium transition-colors">← Elegir de la lista</button>
        </div>
        <div class="special-discount-badge hidden items-center gap-1.5 px-2.5 py-1.5 rounded-lg bg-violet-50 border border-violet-100">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5 text-violet-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 7h.01M7 3h5c.512 0 1.024.195 1.414.586l7 7a2 2 0 010 2.828l-7 7a2 2 0 01-2.828 0l-7-7A1.994 1.994 0 013 12V7a4 4 0 014-4z" /></svg>
            <span class="special-discount-text text-xs font-semibold text-violet-700"></span>
        </div>`;
    }

    function buildFooterHTML(): string {
        return `
        <div class="subtotal-row hidden items-center justify-between">
            <span class="text-xs text-slate-400">Subtotal</span>
            <span class="cart-subtotal text-xs font-medium text-slate-600">$ 0,00</span>
        </div>
        <div class="special-discount-row hidden items-center justify-between">
            <span class="special-discount-label text-xs text-violet-600 font-medium">Descuento especial</span>
            <span class="cart-discount-amount text-xs font-semibold text-violet-600"></span>
        </div>
        <div class="flex items-center justify-between">
            <span class="text-sm text-slate-500">Total</span>
            <span class="cart-total text-lg font-bold text-slate-800">$ 0,00</span>
        </div>
        <button class="confirm-sale-btn w-full bg-indigo-600 hover:bg-indigo-700 disabled:bg-slate-200 disabled:text-slate-400 disabled:cursor-not-allowed text-white font-semibold py-2.5 rounded-xl transition-all text-sm flex items-center justify-center gap-2" disabled>
            <span class="confirm-text">Confirmar venta</span>
        </button>`;
    }

    document.getElementById("client-section-desktop")!.innerHTML = buildClientSectionHTML();
    document.getElementById("client-section-mobile")!.innerHTML  = buildClientSectionHTML();
    document.getElementById("cart-footer-desktop")!.innerHTML    = buildFooterHTML();
    document.getElementById("cart-footer-mobile")!.innerHTML     = buildFooterHTML();

    // Mobile drawer
    const fabBtn         = document.getElementById("open-cart-mobile")!;
    const closeDrawerBtn = document.getElementById("close-cart-mobile")!;
    const mobileOverlay  = document.getElementById("cart-mobile-overlay")!;
    const mobileDrawer   = document.getElementById("cart-mobile-drawer")!;
    const cartBadge      = document.getElementById("cart-badge")!;

    function openMobileCart() {
        mobileDrawer.classList.remove("translate-y-full");
        mobileOverlay.classList.remove("opacity-0", "pointer-events-none");
        mobileOverlay.classList.add("opacity-100");
        document.body.style.overflow = "hidden";
    }
    function closeMobileCart() {
        mobileDrawer.classList.add("translate-y-full");
        mobileOverlay.classList.add("opacity-0", "pointer-events-none");
        mobileOverlay.classList.remove("opacity-100");
        document.body.style.overflow = "";
    }
    fabBtn.addEventListener("click", openMobileCart);
    closeDrawerBtn.addEventListener("click", closeMobileCart);
    mobileOverlay.addEventListener("click", closeMobileCart);

    function updateBadge() {
        const total = cart.reduce((acc, c) => acc + c.qty, 0);
        if (total > 0) {
            cartBadge.textContent = String(total);
            cartBadge.classList.remove("hidden");
            cartBadge.classList.add("flex");
        } else {
            cartBadge.classList.add("hidden");
            cartBadge.classList.remove("flex");
        }
    }

    function updateTotal() {
        const subtotal   = calcSubtotal();
        const total      = calcTotal();
        const hasSpecial = activeSpecialDiscount > 0 && cart.length > 0;

        document.querySelectorAll<HTMLElement>(".cart-total").forEach(el => el.textContent = formatARS(total));
        document.querySelectorAll<HTMLElement>(".cart-subtotal").forEach(el => el.textContent = formatARS(subtotal));
        document.querySelectorAll<HTMLElement>(".cart-discount-amount").forEach(el => el.textContent = `−${formatARS(subtotal - total)}`);
        document.querySelectorAll<HTMLElement>(".special-discount-label").forEach(el => el.textContent = `Desc. especial (${activeSpecialDiscount}%)`);
        document.querySelectorAll<HTMLElement>(".subtotal-row").forEach(el => {
            el.classList.toggle("hidden", !hasSpecial);
            el.classList.toggle("flex", hasSpecial);
        });
        document.querySelectorAll<HTMLElement>(".special-discount-row").forEach(el => {
            el.classList.toggle("hidden", !hasSpecial);
            el.classList.toggle("flex", hasSpecial);
        });
        document.querySelectorAll<HTMLButtonElement>(".confirm-sale-btn").forEach(btn => {
            btn.disabled = cart.length === 0;
        });
        updateBadge();
    }

    function refreshCartRow(item: CartItem) {
        document.querySelectorAll<HTMLElement>(`[data-row-id="${item.id}"]`).forEach(row => {
            const unitPrice = effectiveUnitPrice(item);
            const unitLabel = row.querySelector<HTMLElement>(".unit-price-label")!;
            if (item.appliedDiscount > 0 && activeSpecialDiscount === 0) {
                unitLabel.innerHTML = `
                    <span class="line-through text-slate-300">${formatARS(item.basePrice)}</span>
                    <span class="text-emerald-600 font-semibold">${formatARS(unitPrice)}</span>
                    <span class="ml-1 px-1.5 py-0.5 rounded-md bg-emerald-50 text-emerald-600 text-xs font-bold">-${item.appliedDiscount}%</span>`;
            } else {
                unitLabel.innerHTML = `<span class="text-slate-400">${formatARS(item.basePrice)} c/u</span>`;
            }
            row.querySelector<HTMLElement>(".subtotal-label")!.textContent = formatARS(unitPrice * item.qty);
            const input = row.querySelector<HTMLInputElement>(".qty-input");
            if (input && input.value !== String(item.qty)) input.value = String(item.qty);
        });
    }
    function refreshAllCartRows() { cart.forEach(refreshCartRow); }

    function buildCartRowHTML(item: CartItem): string {
        const unitPrice = effectiveUnitPrice(item);
        return `
            <div class="flex items-center justify-between mb-1.5">
                <p class="text-xs font-semibold text-slate-700 truncate flex-1 pr-2">${item.name}</p>
                <button class="remove-btn w-5 h-5 rounded-md bg-red-50 hover:bg-red-100 text-red-400 hover:text-red-600 text-xs flex items-center justify-center transition-colors shrink-0">✕</button>
            </div>
            <div class="flex items-center gap-2 flex-wrap">
                <div class="unit-price-label flex items-center gap-1 text-xs shrink-0">
                    <span class="text-slate-400">${formatARS(item.basePrice)} c/u</span>
                </div>
                <div class="flex-1"></div>
                <input type="number" min="1" value="${item.qty}"
                    class="qty-input w-16 text-center py-1 px-1 border border-slate-200 rounded-lg text-xs font-semibold text-slate-800 focus:outline-none focus:ring-2 focus:ring-indigo-400 transition"/>
                <span class="text-xs font-bold text-indigo-600 w-20 text-right subtotal-label">${formatARS(unitPrice * item.qty)}</span>
            </div>`;
    }

    function addCartRowToPanel(item: CartItem, containerId: string, emptyId: string) {
        const container = document.getElementById(containerId)!;
        const emptyEl   = document.getElementById(emptyId);
        if (emptyEl) emptyEl.style.display = "none";

        const row = document.createElement("div");
        row.className     = "px-5 py-3";
        row.dataset.rowId = item.id;
        row.innerHTML     = buildCartRowHTML(item);

        row.querySelector<HTMLInputElement>(".qty-input")!.addEventListener("input", (e) => {
            const val = parseInt((e.target as HTMLInputElement).value);
            if (isNaN(val) || val < 1) return;
            const cartItem = cart.find(c => c.id === item.id);
            if (!cartItem) return;
            cartItem.qty = val;
            cartItem.appliedDiscount = getApplicableDiscount(cartItem.discounts, val);
            refreshCartRow(cartItem);
            updateTotal();
        });

        row.querySelector<HTMLButtonElement>(".remove-btn")!.addEventListener("click", () => {
            const idx = cart.findIndex(c => c.id === item.id);
            if (idx !== -1) cart.splice(idx, 1);
            document.querySelectorAll<HTMLElement>(`[data-row-id="${item.id}"]`).forEach(r => r.remove());
            if (cart.length === 0) {
                ["cart-empty-desktop", "cart-empty-mobile"].forEach(id => {
                    const el = document.getElementById(id);
                    if (el) el.style.display = "block";
                });
            }
            updateTotal();
        });

        container.appendChild(row);
    }

    function addToCart(item: CartItem) {
        addCartRowToPanel(item, "cart-items-desktop", "cart-empty-desktop");
        addCartRowToPanel(item, "cart-items-mobile",  "cart-empty-mobile");
    }

    function clearCart() {
        cart.length = 0;
        ["cart-items-desktop", "cart-items-mobile"].forEach(id => {
            const suffix = id === "cart-items-desktop" ? "desktop" : "mobile";
            document.getElementById(id)!.innerHTML =
                `<p id="cart-empty-${suffix}" class="text-sm text-slate-400 text-center py-8">El carrito está vacío</p>`;
        });
        document.querySelectorAll<HTMLElement>(".cart-total").forEach(el => el.textContent = "$ 0,00");
        document.querySelectorAll<HTMLElement>(".subtotal-row").forEach(el => el.classList.add("hidden"));
        document.querySelectorAll<HTMLElement>(".special-discount-row").forEach(el => el.classList.add("hidden"));
        document.querySelectorAll<HTMLButtonElement>(".confirm-sale-btn").forEach(btn => btn.disabled = true);
        updateBadge();
    }

    function initClientSection(container: HTMLElement) {
        const selectWrapper = container.querySelector<HTMLElement>(".client-select-wrapper")!;
        const clientSelect  = container.querySelector<HTMLSelectElement>(".client-select")!;
        const manualMode    = container.querySelector<HTMLElement>(".client-manual-mode")!;
        const manualInput   = container.querySelector<HTMLInputElement>(".client-manual-input")!;
        const clearBtn      = container.querySelector<HTMLButtonElement>(".clear-manual-btn")!;
        const switchManual  = container.querySelector<HTMLButtonElement>(".switch-to-manual")!;
        const switchSelect  = container.querySelector<HTMLButtonElement>(".switch-to-select")!;

        function showBadge(pct: number) {
            document.querySelectorAll<HTMLElement>(".special-discount-badge").forEach(b => {
                if (pct > 0) { b.classList.remove("hidden"); b.classList.add("flex"); }
                else { b.classList.add("hidden"); b.classList.remove("flex"); }
            });
            document.querySelectorAll<HTMLElement>(".special-discount-text").forEach(t => {
                t.textContent = pct > 0 ? `−${pct}% sobre el total` : "";
            });
        }
        function setDiscount(pct: number) {
            activeSpecialDiscount = pct;
            showBadge(pct);
            refreshAllCartRows();
            updateTotal();
        }
        function resetClient() {
            activeClientId = null; activeClientName = null; activeSpecialDiscount = 0;
            showBadge(0); refreshAllCartRows(); updateTotal();
        }

        switchManual?.addEventListener("click", () => {
            selectWrapper.classList.add("hidden");
            manualMode.classList.remove("hidden");
            clientSelect.value = "";
            resetClient();
            setTimeout(() => manualInput.focus(), 50);
            document.querySelectorAll<HTMLElement>(".client-manual-mode").forEach(m => m.classList.remove("hidden"));
            document.querySelectorAll<HTMLElement>(".client-select-wrapper").forEach(w => w.classList.add("hidden"));
        });

        switchSelect?.addEventListener("click", () => {
            selectWrapper.classList.remove("hidden");
            manualMode.classList.add("hidden");
            manualInput.value = "";
            clearBtn.classList.add("hidden");
            resetClient();
            document.querySelectorAll<HTMLElement>(".client-manual-mode").forEach(m => m.classList.add("hidden"));
            document.querySelectorAll<HTMLElement>(".client-select-wrapper").forEach(w => w.classList.remove("hidden"));
        });

        clientSelect.addEventListener("change", () => {
            const sel = clientSelect.options[clientSelect.selectedIndex];
            activeClientId   = clientSelect.value || null;
            activeClientName = activeClientId ? (sel.dataset.name ?? sel.text.split(" (")[0]) : null;
            const raw = sel.dataset.specialDiscount ?? "";
            document.querySelectorAll<HTMLSelectElement>(".client-select").forEach(s => s.value = clientSelect.value);
            setDiscount(raw !== "" ? parseFloat(raw) : 0);
        });

        manualInput.addEventListener("input", () => {
            const val = manualInput.value.trim();
            activeClientId = null; activeClientName = val || null;
            clearBtn.classList.toggle("hidden", !val);
            document.querySelectorAll<HTMLInputElement>(".client-manual-input").forEach(i => { if (i !== manualInput) i.value = manualInput.value; });
            setDiscount(0);
        });

        clearBtn.addEventListener("click", () => {
            manualInput.value = "";
            document.querySelectorAll<HTMLInputElement>(".client-manual-input").forEach(i => i.value = "");
            clearBtn.classList.add("hidden");
            document.querySelectorAll<HTMLButtonElement>(".clear-manual-btn").forEach(b => b.classList.add("hidden"));
            activeClientName = null;
            setDiscount(0);
        });
    }

    initClientSection(document.getElementById("client-section-desktop")!);
    initClientSection(document.getElementById("client-section-mobile")!);

    document.getElementById("clear-cart-desktop")?.addEventListener("click", clearCart);
    document.getElementById("clear-cart-mobile")?.addEventListener("click", clearCart);

    document.getElementById("products-grid")?.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".product-card") as HTMLElement | null;
        if (!btn) return;
        const id        = btn.dataset.id!;
        const name      = btn.dataset.name!;
        const basePrice = Number(btn.dataset.price);
        let discounts: Discount[] = [];
        try { discounts = JSON.parse(btn.dataset.discounts ?? "[]"); } catch {}

        const existing = cart.find(c => c.id === id);
        if (existing) {
            existing.qty++;
            existing.appliedDiscount = getApplicableDiscount(existing.discounts, existing.qty);
            refreshCartRow(existing);
            updateTotal();
        } else {
            const newItem: CartItem = { id, name, basePrice, discounts, qty: 1, appliedDiscount: getApplicableDiscount(discounts, 1) };
            cart.push(newItem);
            addToCart(newItem);
            updateTotal();
        }
    });

    // Modal de confirmación
    const confirmModal   = document.getElementById("confirm-sale-modal")!;
    const confirmCancel  = document.getElementById("confirm-sale-cancel")!;
    const confirmOk      = document.getElementById("confirm-sale-ok") as HTMLButtonElement;
    const confirmOkText  = document.getElementById("confirm-ok-text")!;
    const confirmSpinner = document.getElementById("confirm-spinner")!;

    function openConfirmModal() {
        const sellerName = getSellerName();
        if (!sellerName) {
            alert("Primero seleccioná quién está vendiendo.");
            sellerSelect?.focus();
            return;
        }
        const totalItems = cart.reduce((a, c) => a + c.qty, 0);
        document.getElementById("modal-seller-name")!.textContent = sellerName;
        document.getElementById("modal-client-name")!.textContent = activeClientName || "Sin cliente";
        document.getElementById("modal-items-count")!.textContent = `${totalItems} ítem${totalItems !== 1 ? "s" : ""}`;
        document.getElementById("modal-total")!.textContent       = formatARS(calcTotal());
        confirmModal.classList.remove("hidden");
    }
    function closeConfirmModal() { confirmModal.classList.add("hidden"); }

    confirmCancel.addEventListener("click", closeConfirmModal);
    confirmModal.addEventListener("click", (e) => { if (e.target === confirmModal) closeConfirmModal(); });

    document.querySelectorAll<HTMLButtonElement>(".confirm-sale-btn").forEach(btn => {
        btn.addEventListener("click", () => { if (cart.length > 0) openConfirmModal(); });
    });

    confirmOk.addEventListener("click", async () => { await processSale(getSellerName()); });

    async function processSale(sellerName: string) {
        confirmOkText.textContent = "Procesando...";
        confirmSpinner.classList.remove("hidden");
        confirmOk.disabled = true;

        try {
            const subtotal = calcSubtotal();
            const total    = calcTotal();
            const { data: sessionData } = await supabase.auth.getSession();
            const userId = sessionData?.session?.user?.id;

            const { data: sale, error: saleError } = await supabase
                .from("sales")
                .insert([{
                    user_id:        userId,
                    total,
                    payment_method: "pendiente",
                    client_id:      activeClientId || null,
                    client_name:    activeClientName || null,
                    seller_name:    sellerName,
                }])
                .select()
                .single();

            if (saleError) throw saleError;

            const items = cart.map(c => ({
                sale_id:      sale.id,
                product_id:   c.id,
                quantity:     c.qty,
                price:        activeSpecialDiscount > 0 ? c.basePrice : effectiveUnitPrice(c),
                discount_pct: activeSpecialDiscount > 0 ? 0 : c.appliedDiscount,
            }));

            const { error: itemsError } = await supabase.from("sale_items").insert(items);
            if (itemsError) throw itemsError;

            await supabase.from("notifications").insert([{
                user_id: userId,
                type:    "nueva_venta",
                message: `Nueva venta por ${formatARS(total)} — ${cart.length} producto${cart.length > 1 ? "s" : ""}${activeClientName ? ` · ${activeClientName}` : ""}`,
                data: JSON.stringify({
                    sale_id: sale.id, total, subtotal,
                    client_id: activeClientId, client_name: activeClientName,
                    special_discount_pct: activeSpecialDiscount, seller_name: sellerName,
                    items: cart.map(c => ({ name: c.name, qty: c.qty, subtotal: effectiveUnitPrice(c) * c.qty }))
                }),
                read: false,
            }]);

            for (const item of cart) {
                const { error: stockError } = await supabase.rpc("decrement_stock", { product_id: item.id, quantity: item.qty });
                if (stockError) console.error("Error al descontar stock:", stockError.message);
            }

            closeConfirmModal();
            clearCart();
            document.querySelectorAll<HTMLSelectElement>(".client-select").forEach(s => s.value = "");
            document.querySelectorAll<HTMLInputElement>(".client-manual-input").forEach(i => i.value = "");
            document.querySelectorAll<HTMLButtonElement>(".clear-manual-btn").forEach(b => b.classList.add("hidden"));
            activeClientId = null; activeClientName = null; activeSpecialDiscount = 0;
            document.querySelectorAll<HTMLElement>(".special-discount-badge").forEach(b => { b.classList.add("hidden"); b.classList.remove("flex"); });
            closeMobileCart();

        } catch (err: any) {
            alert("Error al confirmar la venta: " + (err?.message ?? "Error desconocido"));
        } finally {
            confirmOkText.textContent = "Sí, cobrar";
            confirmSpinner.classList.add("hidden");
            confirmOk.disabled = false;
        }
    }
</script>