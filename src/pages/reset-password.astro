---
import Layout from "../layouts/Layout.astro";
---

<Layout>
    <div class="h-screen overflow-y-auto flex items-center justify-center px-4 py-6 relative" style="background-color: #0f172a;">

        <!-- Fondo geométrico SVG -->
        <div class="absolute inset-0 overflow-hidden pointer-events-none" aria-hidden="true">
            <svg class="absolute inset-0 w-full h-full" xmlns="http://www.w3.org/2000/svg" preserveAspectRatio="xMidYMid slice">
                <defs>
                    <pattern id="grid" width="60" height="60" patternUnits="userSpaceOnUse">
                        <path d="M 60 0 L 0 0 0 60" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                    </pattern>
                    <radialGradient id="glow1" cx="20%" cy="30%" r="50%">
                        <stop offset="0%" stop-color="rgba(34,197,94,0.15)"/>
                        <stop offset="100%" stop-color="transparent"/>
                    </radialGradient>
                    <radialGradient id="glow2" cx="80%" cy="70%" r="50%">
                        <stop offset="0%" stop-color="rgba(16,185,129,0.10)"/>
                        <stop offset="100%" stop-color="transparent"/>
                    </radialGradient>
                </defs>
                <rect width="100%" height="100%" fill="url(#grid)"/>
                <rect width="100%" height="100%" fill="url(#glow1)"/>
                <rect width="100%" height="100%" fill="url(#glow2)"/>
                <g fill="none" stroke="rgba(34,197,94,0.12)" stroke-width="1.5">
                    <polygon points="80,20 110,37 110,72 80,89 50,72 50,37" />
                    <polygon points="820,80 870,109 870,167 820,196 770,167 770,109" />
                    <polygon points="650,420 690,442 690,488 650,510 610,488 610,442" />
                    <polygon points="120,500 155,519 155,559 120,578 85,559 85,519" />
                    <polygon points="900,300 930,317 930,352 900,369 870,352 870,317" />
                </g>
                <circle cx="15%" cy="85%" r="120" fill="none" stroke="rgba(255,255,255,0.04)" stroke-width="1"/>
                <circle cx="85%" cy="15%" r="180" fill="none" stroke="rgba(255,255,255,0.03)" stroke-width="1"/>
                <circle cx="85%" cy="15%" r="100" fill="none" stroke="rgba(34,197,94,0.08)" stroke-width="1"/>
                <g stroke="rgba(34,197,94,0.07)" stroke-width="1">
                    <line x1="0" y1="100%" x2="30%" y2="0"/>
                    <line x1="70%" y1="100%" x2="100%" y2="20%"/>
                </g>
                <g fill="rgba(34,197,94,0.3)">
                    <circle cx="5%" cy="20%" r="2"/>
                    <circle cx="92%" cy="45%" r="1.5"/>
                    <circle cx="60%" cy="90%" r="2"/>
                    <circle cx="35%" cy="8%" r="1.5"/>
                    <circle cx="78%" cy="88%" r="2"/>
                    <circle cx="18%" cy="60%" r="1.5"/>
                </g>
            </svg>
        </div>

        <div class="w-full max-w-md relative z-10">

            <!-- Header -->
            <div class="mb-8 text-center">
                <div class="inline-flex items-center justify-center w-14 h-14 rounded-2xl bg-green-500 mb-4 shadow-lg shadow-green-500/30">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-7 h-7 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                    </svg>
                </div>
                <h1 class="text-2xl font-bold text-white">Nueva contraseña</h1>
                <p class="text-slate-400 text-sm mt-1">Elegí una contraseña segura para tu cuenta</p>
            </div>

            <!-- Card -->
            <div class="bg-white/5 backdrop-blur-md border border-white/10 rounded-2xl shadow-xl p-8">

                <!-- Link inválido / expirado -->
                <div id="invalid-msg" class="hidden text-center py-4">
                    <div class="w-12 h-12 rounded-2xl bg-red-500/10 flex items-center justify-center mx-auto mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-red-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                        </svg>
                    </div>
                    <p class="text-white font-semibold text-sm mb-1">Link inválido o expirado</p>
                    <p class="text-slate-400 text-xs mb-4">El link de recuperación ya no es válido. Solicitá uno nuevo.</p>
                    <a href="/forgot-password" class="inline-block px-4 py-2 rounded-xl bg-green-500 hover:bg-green-400 text-white text-sm font-semibold transition-colors">
                        Solicitar nuevo link
                    </a>
                </div>

                <!-- Error -->
                <div id="error-msg" class="hidden mb-4 px-4 py-3 rounded-xl bg-red-500/10 border border-red-500/30 text-red-300 text-sm flex items-center gap-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
                    </svg>
                    <span id="error-text"></span>
                </div>

                <!-- Formulario -->
                <div id="form-section" class="space-y-5">

                    <div class="space-y-1.5">
                        <label class="block text-sm font-medium text-slate-300">Nueva contraseña</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-3 flex items-center text-slate-500 pointer-events-none">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                </svg>
                            </span>
                            <input id="password" type="password" placeholder="Mínimo 6 caracteres"
                                class="w-full pl-9 pr-10 py-2.5 bg-white/5 border border-white/10 rounded-xl text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2 focus:ring-green-500/50 focus:border-green-500/50 transition"/>
                            <button id="toggle-password" type="button" class="absolute inset-y-0 right-3 flex items-center text-slate-500 hover:text-slate-300 transition-colors">
                                <svg id="eye-icon" xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <div class="space-y-1.5">
                        <label class="block text-sm font-medium text-slate-300">Repetir contraseña</label>
                        <div class="relative">
                            <span class="absolute inset-y-0 left-3 flex items-center text-slate-500 pointer-events-none">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z" />
                                </svg>
                            </span>
                            <input id="password-confirm" type="password" placeholder="Repetí la contraseña"
                                class="w-full pl-9 pr-4 py-2.5 bg-white/5 border border-white/10 rounded-xl text-white placeholder-slate-500 text-sm focus:outline-none focus:ring-2 focus:ring-green-500/50 focus:border-green-500/50 transition"/>
                        </div>
                    </div>

                    <button id="reset-btn"
                        class="w-full bg-green-500 hover:bg-green-400 active:scale-[0.98] disabled:opacity-40 disabled:cursor-not-allowed text-white font-semibold py-2.5 rounded-xl transition-all duration-150 text-sm flex items-center justify-center gap-2 shadow-lg shadow-green-500/20">
                        <span id="btn-text">Guardar nueva contraseña</span>
                        <svg id="btn-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 14.627 0 12 0v4a8 8 0 00-8 8H0z"></path>
                        </svg>
                    </button>

                </div>

                <!-- Éxito -->
                <div id="success-section" class="hidden text-center py-4">
                    <div class="w-12 h-12 rounded-2xl bg-green-500/10 flex items-center justify-center mx-auto mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-green-400" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                    </div>
                    <p class="text-white font-semibold text-sm mb-1">¡Contraseña actualizada!</p>
                    <p class="text-slate-400 text-xs mb-4">Ya podés ingresar con tu nueva contraseña.</p>
                    <a href="/login" class="inline-block px-4 py-2 rounded-xl bg-green-500 hover:bg-green-400 text-white text-sm font-semibold transition-colors">
                        Ir al login
                    </a>
                </div>

            </div>

        </div>
    </div>
</Layout>

<script>
    import { supabase } from "../lib/supabaseClient.js";

    const passwordInput  = document.getElementById("password")         as HTMLInputElement;
    const confirmInput   = document.getElementById("password-confirm") as HTMLInputElement;
    const resetBtn       = document.getElementById("reset-btn")        as HTMLButtonElement;
    const btnText        = document.getElementById("btn-text")!;
    const btnSpinner     = document.getElementById("btn-spinner")!;
    const errorMsg       = document.getElementById("error-msg")!;
    const errorText      = document.getElementById("error-text")!;
    const formSection    = document.getElementById("form-section")!;
    const successSection = document.getElementById("success-section")!;
    const invalidMsg     = document.getElementById("invalid-msg")!;
    const togglePassword = document.getElementById("toggle-password")!;

    // Mostrar/ocultar contraseña
    let passwordVisible = false;
    togglePassword.addEventListener("click", () => {
        passwordVisible = !passwordVisible;
        passwordInput.type = passwordVisible ? "text" : "password";
        document.getElementById("eye-icon")!.innerHTML = passwordVisible
            ? `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.88 9.88l-3.29-3.29m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21"/>`
            : `<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z"/>`;
    });

    function showError(msg: string) {
        errorText.textContent = msg;
        errorMsg.classList.remove("hidden");
    }

    function setLoading(on: boolean) {
        resetBtn.disabled = on;
        btnText.textContent = on ? "Guardando..." : "Guardar nueva contraseña";
        btnSpinner.classList.toggle("hidden", !on);
    }

    // Supabase pone el token en el hash de la URL cuando el usuario llega desde el email
    // Necesitamos intercambiarlo por una sesión activa antes de poder cambiar la contraseña
    async function init() {
        const hash   = window.location.hash;
        const params = new URLSearchParams(hash.replace("#", "?").replace("#", "&"));

        const accessToken  = params.get("access_token");
        const refreshToken = params.get("refresh_token");
        const type         = params.get("type"); // "recovery"

        if (!accessToken || type !== "recovery") {
            // No hay token válido → mostrar mensaje de link inválido
            formSection.classList.add("hidden");
            invalidMsg.classList.remove("hidden");
            return;
        }

        // Establecer la sesión con el token del link
        const { error } = await supabase.auth.setSession({
            access_token:  accessToken,
            refresh_token: refreshToken ?? "",
        });

        if (error) {
            formSection.classList.add("hidden");
            invalidMsg.classList.remove("hidden");
        }
    }

    init();

    resetBtn.addEventListener("click", async () => {
        errorMsg.classList.add("hidden");

        const password = passwordInput.value;
        const confirm  = confirmInput.value;

        if (!password) { showError("Ingresá una contraseña."); return; }
        if (password.length < 6) { showError("La contraseña debe tener al menos 6 caracteres."); return; }
        if (password !== confirm) { showError("Las contraseñas no coinciden."); return; }

        setLoading(true);

        const { error } = await supabase.auth.updateUser({ password });

        setLoading(false);

        if (error) {
            showError(error.message);
            return;
        }

        // Cerrar sesión después del reset para que el usuario haga login limpio
        await supabase.auth.signOut();

        formSection.classList.add("hidden");
        successSection.classList.remove("hidden");
    });

    [passwordInput, confirmInput].forEach((input) => {
        input.addEventListener("keydown", (e) => {
            if (e.key === "Enter") resetBtn.click();
        });
    });
</script>