---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabaseClient.js";

const { data: clients } = await supabase.from("clients").select("id, name").order("name");
const { data: notifications } = await supabase
    .from("notifications")
    .select("*")
    .eq("read", false)
    .eq("type", "nueva_venta")
    .order("created_at", { ascending: false });

const formatMoney = (amount: number | null) => {
    if (amount == null) return "вҖ”";
    return "$ " + new Intl.NumberFormat("es-AR", {
        minimumFractionDigits: 2,
        maximumFractionDigits: 2,
    }).format(amount);
};

const pendingCount = notifications?.length ?? 0;

const { data: categoriesData } = await supabase.from("categories").select("name").order("name");
const CATEGORIAS = categoriesData?.map(c => c.name) ?? [];
const { data: cuentasData } = await supabase.from("cash_register_categories").select("name").order("name");
const CUENTAS = cuentasData?.map(c => c.name) ?? [];
---

<Layout>
    <div class="min-h-screen bg-slate-50 px-4 sm:px-6 py-6 sm:py-8 pt-20 lg:pt-8">
        <div class="max-w-3xl mx-auto">

            <!-- Header -->
            <div class="flex items-center gap-3 sm:gap-4 mb-6 sm:mb-8">
                <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-emerald-600 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z"/>
                    </svg>
                </div>
                <div>
                    <h1 class="text-xl sm:text-2xl font-bold text-slate-800 leading-tight">Cobros</h1>
                    <p class="text-xs sm:text-sm text-slate-500">ProcesГЎ los cobros de las ventas pendientes</p>
                </div>
            </div>

            <!-- Sin pendientes -->
            {pendingCount === 0 && (
                <div id="empty-state" class="bg-white border border-slate-200 rounded-2xl shadow-sm flex flex-col items-center justify-center py-14 sm:py-16 text-center px-4">
                    <div class="w-12 h-12 rounded-2xl bg-emerald-50 flex items-center justify-center mb-3">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/>
                        </svg>
                    </div>
                    <p class="text-slate-700 font-semibold text-sm">Todo al dГӯa</p>
                    <p class="text-slate-400 text-xs mt-1">No hay ventas pendientes de cobro</p>
                </div>
            )}

            <!-- Lista -->
            {pendingCount > 0 && (
                <div id="sales-list" class="space-y-4">
                    <div class="flex items-center justify-between mb-2">
                        <p id="pending-label" class="text-sm font-semibold text-slate-600">
                            {pendingCount} {pendingCount === 1 ? "venta pendiente" : "ventas pendientes"}
                        </p>
                        <button id="mark-all-read" class="text-xs text-slate-400 hover:text-red-500 transition-colors">
                            Descartar todas
                        </button>
                    </div>

                    {notifications?.map((n) => {
                        let parsed: any = null;
                        try { parsed = JSON.parse(n.data ?? "{}"); } catch {}
                        const isBudget = parsed?.is_budget === true;

                        return (
                            <div class="sale-card bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden"
                                data-notification-id={n.id}
                                data-is-budget={isBudget ? "true" : "false"}>

                                <!-- Cabecera -->
                                <div class={`flex items-start sm:items-center justify-between px-4 sm:px-5 py-4 border-b gap-3 ${isBudget ? "border-violet-100 bg-violet-50" : "border-slate-100"}`}>
                                    <div class="min-w-0 flex-1">
                                        <div class="flex items-center gap-2 flex-wrap">
                                            <p class="text-sm font-semibold text-slate-800 leading-snug">{n.message}</p>
                                            {isBudget && (
                                                <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-xs font-semibold bg-violet-100 text-violet-700 border border-violet-200">
                                                    <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                                    Presupuesto
                                                </span>
                                            )}
                                        </div>
                                        <p class="text-xs text-slate-400 mt-0.5">
                                            {new Date(n.created_at).toLocaleString("es-AR", { day:"2-digit", month:"2-digit", year:"numeric", hour:"2-digit", minute:"2-digit" })}
                                        </p>
                                    </div>
                                    <span class={`text-base sm:text-lg font-bold shrink-0 ${isBudget ? "text-violet-600" : "text-emerald-600"}`}>
                                        {formatMoney(parsed?.total ?? 0)}
                                    </span>
                                </div>

                                <!-- Items -->
                                <div class="px-4 sm:px-5 py-3 border-b border-slate-100 space-y-1.5">
                                    {parsed?.items?.map((item: any) => (
                                        <div class="flex items-center justify-between gap-2">
                                            <span class="text-xs text-slate-600 truncate">{item.name} Г— {item.qty}</span>
                                            <span class="text-xs font-medium text-slate-700 shrink-0">{formatMoney(item.subtotal)}</span>
                                        </div>
                                    ))}
                                </div>

                                {isBudget ? (
                                    <div class="budget-panel px-4 sm:px-5 py-4 space-y-3">
                                        <div class="flex items-center gap-2 px-3 py-2.5 bg-violet-50 border border-violet-100 rounded-xl">
                                            <svg class="w-4 h-4 text-violet-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                            <p class="text-xs text-violet-700 font-medium">Este presupuesto no se cobra desde aquГӯ. Solo podГ©s imprimir el ticket o descartarlo.</p>
                                        </div>
                                        <div class="flex gap-2">
                                            <button type="button" class="discard-btn flex-none px-3 py-2.5 rounded-xl text-xs font-semibold border border-slate-200 text-slate-500 hover:bg-slate-50 transition-colors" data-notification-id={n.id}>Descartar</button>
                                            <button type="button" class="budget-print-btn flex-1 py-2.5 rounded-xl text-sm font-semibold border border-violet-200 text-violet-700 hover:bg-violet-50 transition-colors flex items-center justify-center gap-2" data-items={n.data}>
                                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4H9v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                                                Imprimir ticket
                                            </button>
                                        </div>
                                    </div>
                                ) : (
                                    <div class="cobro-form px-4 sm:px-5 py-4 space-y-3">

                                        <!-- Cliente -->
                                        <div>
                                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">Cliente <span class="client-required hidden text-red-500">*</span></label>
                                            <select class="client-select w-full py-2 pl-3 pr-8 bg-slate-50 border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 transition appearance-none">
                                                <option value="">Cliente general</option>
                                                {clients?.map((c) => (<option value={c.id}>{c.name}</option>))}
                                            </select>
                                        </div>

                                        <!-- MГ©todos de pago -->
                                        <div>
                                            <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">
                                                MГ©todo de pago
                                                <span class="ml-1 text-slate-400 font-normal normal-case">(podГ©s elegir hasta 2)</span>
                                            </label>
                                            <div class="grid grid-cols-2 gap-2">
                                                {[
                                                    { value:"efectivo",      label:"Efectivo",      surcharge:"0",  span:false },
                                                    { value:"transferencia", label:"Transferencia", surcharge:"0",  span:false },
                                                    { value:"debito",        label:"DГ©bito +8%",    surcharge:"8",  span:false },
                                                    { value:"credito",       label:"CrГ©dito +15%",  surcharge:"15", span:false },
                                                    { value:"deudor",        label:"Deudor",        surcharge:"0",  span:true  },
                                                ].map((m) => (
                                                    <button type="button"
                                                        class={`payment-btn py-2.5 rounded-xl text-xs font-semibold border transition-all relative
                                                        ${m.span ? "col-span-2" : ""}
                                                        ${m.value === "deudor" ? "border-red-200 text-red-500 hover:bg-red-50 hover:border-red-400" : "border-slate-200 text-slate-600 hover:border-emerald-400 hover:text-emerald-700 hover:bg-emerald-50"}`}
                                                        data-method={m.value}
                                                        data-surcharge={m.surcharge}>
                                                        {m.label}
                                                        <span class="payment-badge hidden absolute -top-1.5 -right-1.5 w-4 h-4 rounded-full bg-emerald-600 text-white text-[9px] font-bold flex items-center justify-center leading-none"></span>
                                                    </button>
                                                ))}
                                            </div>
                                        </div>

                                        <!-- Panel pago simple -->
                                        <div class="single-payment-panel hidden space-y-2 rounded-xl border border-slate-200 bg-slate-50 px-3 py-3">
                                            <p class="text-xs font-semibold text-slate-500 uppercase tracking-wide">Rubro <span class="ml-1 font-normal normal-case text-slate-400">(para el cierre de caja)</span></p>
                                            <select class="rubro-single w-full py-2 pl-3 pr-8 bg-white border border-slate-200 rounded-xl text-sm text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 transition appearance-none">
                                                <option value="">вҖ” Sin rubro especГӯfico вҖ”</option>
                                                {CATEGORIAS.map((c) => (<option value={c}>{c}</option>))}
                                            </select>
                                        </div>

                                        <!-- Panel pago mixto -->
                                        <div class="mixed-payment-panel hidden space-y-2 bg-blue-50 border border-blue-200 rounded-xl px-3 py-3">
                                            <div class="flex items-center gap-2 mb-1">
                                                <svg class="w-4 h-4 text-blue-500 shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7h12m0 0l-4-4m4 4l-4 4m0 6H4m0 0l4 4m-4-4l4-4"/></svg>
                                                <p class="text-xs text-blue-700 font-semibold">Pago combinado вҖ” asignГЎ monto y rubro a cada mГ©todo</p>
                                            </div>

                                            <!-- MГ©todo 1 -->
                                            <div class="rounded-xl border border-slate-200 bg-white p-3 space-y-2">
                                                <p class="text-xs font-bold text-slate-600 uppercase tracking-wide mixed-label-1"></p>
                                                <div class="flex gap-2">
                                                    <div class="relative w-36 shrink-0">
                                                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs text-slate-400 pointer-events-none font-medium">$</span>
                                                        <input type="number" min="0" step="1" placeholder="0"
                                                            class="mixed-amount-1 w-full pl-6 pr-2 py-2 border border-slate-200 rounded-xl text-sm font-semibold text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition"/>
                                                    </div>
                                                    <select class="abono-mixed-1 py-2 pl-3 pr-2 bg-slate-50 border border-slate-200 rounded-xl text-xs text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 transition appearance-none w-28 shrink-0">
                                                        <option value="">Sin abono</option>
                                                    </select>
                                                    <select class="rubro-mixed-1 flex-1 py-2 pl-3 pr-2 bg-slate-50 border border-slate-200 rounded-xl text-xs text-slate-700 focus:outline-none focus:ring-2 focus:ring-emerald-500 transition appearance-none">
                                                        <option value="">Sin rubro</option>
                                                        {CATEGORIAS.map((c) => (<option value={c}>{c}</option>))}
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- MГ©todo 2 -->
                                            <div class="rounded-xl border border-blue-200 bg-white p-3 space-y-2">
                                                <p class="text-xs font-bold text-blue-600 uppercase tracking-wide mixed-label-2"></p>
                                                <div class="flex gap-2">
                                                    <div class="relative w-36 shrink-0">
                                                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs text-slate-400 pointer-events-none font-medium">$</span>
                                                        <input type="number" min="0" step="1" placeholder="0"
                                                            class="mixed-amount-2 w-full pl-6 pr-2 py-2 border border-blue-200 rounded-xl text-sm font-semibold text-blue-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-blue-500 focus:border-transparent transition"/>
                                                    </div>
                                                    <select class="abono-mixed-2 py-2 pl-3 pr-2 bg-slate-50 border border-blue-200 rounded-xl text-xs text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition appearance-none w-28 shrink-0">
                                                        <option value="">Sin abono</option>
                                                    </select>
                                                    <select class="rubro-mixed-2 flex-1 py-2 pl-3 pr-2 bg-slate-50 border border-blue-200 rounded-xl text-xs text-slate-700 focus:outline-none focus:ring-2 focus:ring-blue-500 transition appearance-none">
                                                        <option value="">Sin rubro</option>
                                                        {CATEGORIAS.map((c) => (<option value={c}>{c}</option>))}
                                                    </select>
                                                </div>
                                            </div>

                                            <!-- ValidaciГіn suma -->
                                            <div class="flex items-center justify-between px-2 py-1.5 rounded-lg bg-white border border-slate-200">
                                                <span class="text-xs text-slate-500">Resta asignar</span>
                                                <span class="mixed-diff-amount text-xs font-bold text-slate-700">вҖ”</span>
                                            </div>
                                        </div>

                                        <!-- Info recargo -->
                                        <div class="surcharge-info hidden px-3 py-2 bg-amber-50 border border-amber-200 rounded-xl">
                                            <p class="surcharge-label text-xs text-amber-700 font-medium"></p>
                                        </div>

                                        <!-- Info deudor -->
                                        <div class="debtor-info hidden px-3 py-2 bg-red-50 border border-red-200 rounded-xl">
                                            <p class="text-xs text-red-700 font-medium">Se registrarГЎ como deuda. SeleccionГЎ un cliente.</p>
                                        </div>

                                        <!-- Resumen totales -->
                                        <div class="bg-slate-50 rounded-xl px-4 py-3 space-y-1">
                                            <div class="flex items-center justify-between">
                                                <span class="text-xs text-slate-400">Subtotal</span>
                                                <span class="subtotal-display text-xs text-slate-600">{formatMoney(parsed?.total ?? 0)}</span>
                                            </div>
                                            <div class="surcharge-row hidden flex items-center justify-between">
                                                <span class="surcharge-row-label text-xs text-amber-600"></span>
                                                <span class="surcharge-amount text-xs font-medium text-amber-600"></span>
                                            </div>
                                            <div class="flex items-center justify-between">
                                                <span class="text-sm font-semibold text-slate-700">Total</span>
                                                <span class="total-display text-base font-bold text-slate-800">{formatMoney(parsed?.total ?? 0)}</span>
                                            </div>
                                        </div>

                                        <!-- SecciГіn efectivo -->
                                        <div class="cash-section hidden space-y-3">
                                            <div class="flex items-center gap-3">
                                                <div class="flex-1 space-y-1">
                                                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Entregado en efectivo</label>
                                                    <div class="relative">
                                                        <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs text-slate-400 pointer-events-none font-medium">$</span>
                                                        <input type="number" min="0" step="1" placeholder="0" class="cash-received w-full pl-6 pr-3 py-2.5 border border-slate-200 rounded-xl text-sm font-semibold text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition"/>
                                                    </div>
                                                </div>
                                                <div class="flex-1 space-y-1">
                                                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Vuelto</label>
                                                    <div class="change-display flex items-center justify-center py-2.5 px-3 rounded-xl bg-emerald-50 border border-emerald-100 min-h-[42px]">
                                                        <span class="change-amount text-sm font-bold text-emerald-700">вҖ”</span>
                                                    </div>
                                                </div>
                                            </div>
                                            <div class="insufficient-alert hidden px-3 py-1.5 rounded-lg bg-red-50 border border-red-200">
                                                <p class="text-xs text-red-600 font-medium">El monto entregado es menor al total en efectivo.</p>
                                            </div>
                                            <div class="total-cobrado-section hidden space-y-1.5">
                                                <div class="border-t border-slate-100 pt-2.5">
                                                    <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide mb-1.5">
                                                        Total cobrado <span class="ml-1 text-slate-400 font-normal normal-case">(lo que quedГі en caja)</span>
                                                    </label>
                                                    <div class="flex items-center gap-2">
                                                        <div class="relative flex-1">
                                                            <span class="absolute left-3 top-1/2 -translate-y-1/2 text-xs text-slate-400 pointer-events-none font-medium">$</span>
                                                            <input type="number" min="0" step="1" placeholder="0" class="cash-kept w-full pl-6 pr-3 py-2.5 border border-emerald-300 rounded-xl text-sm font-bold text-emerald-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-emerald-500 focus:border-transparent transition bg-emerald-50"/>
                                                        </div>
                                                        <button type="button" class="use-total-btn shrink-0 text-xs font-semibold px-3 py-2.5 rounded-xl border border-emerald-200 text-emerald-700 hover:bg-emerald-100 transition-colors">Usar total</button>
                                                    </div>
                                                    <p class="text-xs text-slate-400 mt-1">Si el cliente dejГі el vuelto, ingresГЎ el monto total. Si se le dio vuelto, ya estГЎ calculado automГЎticamente.</p>
                                                </div>
                                            </div>
                                        </div>

                                        <!-- Error -->
                                        <div class="cobro-error hidden px-3 py-2 rounded-xl bg-red-50 border border-red-200 text-red-700 text-xs"></div>

                                        <!-- Acciones -->
                                        <div class="flex gap-2">
                                            <button type="button" class="discard-btn flex-none px-3 py-2.5 rounded-xl text-xs font-semibold border border-slate-200 text-slate-500 hover:bg-slate-50 transition-colors" data-notification-id={n.id}>
                                                Descartar
                                            </button>
                                            <button type="button"
                                                class="cobrar-btn flex-1 py-2.5 rounded-xl text-sm font-semibold bg-emerald-600 hover:bg-emerald-700 text-white transition-colors flex items-center justify-center gap-2 disabled:bg-slate-200 disabled:text-slate-400 disabled:cursor-not-allowed"
                                                data-notification-id={n.id} data-sale-id={parsed?.sale_id} data-base-total={parsed?.total} data-items={n.data}>
                                                <span class="cobrar-text">Confirmar cobro</span>
                                                <svg class="cobrar-spinner hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                                                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"/>
                                                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 0v4a8 8 0 00-8 8H0z"/>
                                                </svg>
                                            </button>
                                        </div>

                                        <!-- в”Җв”Җ CANCELAR VENTA в”Җв”Җ -->
                                        <div class="border-t border-slate-100 pt-3">
                                            <button type="button"
                                                class="cancel-sale-btn w-full py-2.5 rounded-xl text-xs font-semibold border border-red-200 text-red-500 hover:bg-red-50 transition-colors flex items-center justify-center gap-2"
                                                data-notification-id={n.id}
                                                data-sale-id={parsed?.sale_id}
                                                data-items={n.data}>
                                                <svg xmlns="http://www.w3.org/2000/svg" class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                                                </svg>
                                                Cancelar venta y devolver stock
                                            </button>
                                        </div>

                                    </div>
                                )}

                                <!-- Panel Г©xito -->
                                <div class="success-panel hidden px-4 sm:px-5 py-4 space-y-3">
                                    <div class="success-msg flex items-center gap-3"></div>
                                    <div class="border-t border-slate-100 pt-3">
                                        <p class="text-xs font-semibold text-slate-400 uppercase tracking-wide mb-2">Comprobante</p>
                                        <div class="grid grid-cols-3 gap-2">
                                            <button type="button" class="ticket-print-btn flex flex-col items-center justify-center gap-1.5 py-3 rounded-xl text-xs font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 17h2a2 2 0 002-2v-4a2 2 0 00-2-2H5a2 2 0 00-2 2v4a2 2 0 002 2h2m2 4h6a2 2 0 002-2v-4H9v4a2 2 0 002 2zm8-12V5a2 2 0 00-2-2H9a2 2 0 00-2 2v4h10z"/></svg>
                                                Imprimir
                                            </button>
                                            <button type="button" class="ticket-pdf-btn flex flex-col items-center justify-center gap-1.5 py-3 rounded-xl text-xs font-semibold border border-emerald-200 text-emerald-700 hover:bg-emerald-50 transition-colors">
                                                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                                                Descargar
                                            </button>
                                            <button type="button" class="ticket-wa-btn flex flex-col items-center justify-center gap-1.5 py-3 rounded-xl text-xs font-semibold border border-green-200 text-green-700 hover:bg-green-50 transition-colors">
