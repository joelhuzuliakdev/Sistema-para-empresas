</Layout>

<script>
    import { supabase } from "../lib/supabaseClient.js";
    declare const qz: any;

    const EMPRESA_NOMBRE   = "El Mundo Del Descartable";
    const EMPRESA_TELEFONO = "5493572549909";
    const METODOS: Record<string, string> = {
        efectivo:"Efectivo", transferencia:"Transferencia",
        debito:"DГ©bito", credito:"CrГ©dito", deudor:"Deuda",
    };
    const fmt = (n: number) => "$ " + new Intl.NumberFormat("es-AR",{minimumFractionDigits:2,maximumFractionDigits:2}).format(n);

    type PaymentEntry = { method: string; amount: number; rubro: string|null; transferAccount?: string|null; abono?: string|null; };
    type TicketData = {
        items: {name:string;qty:number;subtotal:number}[];
        total: number; paymentMethod: string; clientName: string|null;
        sellerName: string|null; fecha: string; surcharge: number;
        transferAccount: string|null; isBudget?: boolean;
        payments?: PaymentEntry[];
    };

    // в”Җв”Җ Ticket HTML в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    function buildTicketHTML(td: TicketData): string {
        const rows = td.items.map(it=>`<tr>
            <td style="padding:4px 0;font-size:12px;color:#111;vertical-align:top;">${it.name}</td>
            <td style="padding:4px 8px;font-size:12px;color:#111;text-align:center;">${it.qty}</td>
            <td style="padding:4px 0;font-size:12px;color:#111;text-align:right;white-space:nowrap;">${fmt(it.subtotal)}</td></tr>`).join("");
        const srRow = td.surcharge>0 ? (()=>{ const base=td.total/(1+td.surcharge/100); return `<tr><td colspan="2" style="padding:3px 0;font-size:11px;color:#b45309;">Recargo ${td.surcharge}%</td><td style="padding:3px 0;font-size:11px;color:#b45309;text-align:right;">+${fmt(td.total-base)}</td></tr>`; })() : "";
        let pagoLines = "";
        if (td.payments && td.payments.length>0) {
            pagoLines = td.payments.map(p=>{
                const rubroTag = p.rubro?` <span style="color:#888;font-size:10px;">[${p.rubro}]</span>`:"";
                const abonoTag = p.abono?` <span style="color:#888;font-size:10px;">вҶ’ ${METODOS[p.abono]??p.abono}</span>`:"";
                return `<p style="font-size:11px;color:#555;margin-bottom:2px;font-family:Arial,sans-serif;">${METODOS[p.method]??p.method}: ${fmt(p.amount)}${rubroTag}${abonoTag}</p>`;
            }).join("");
        } else {
            pagoLines=`<p style="font-size:11px;color:#555;margin-bottom:2px;font-family:Arial,sans-serif;">Pago: ${METODOS[td.paymentMethod]??td.paymentMethod}</p>`;
        }
        const hc=td.isBudget?"#7c3aed":"#059669";
        const hLabel=td.isBudget?`<p style="margin-top:5px;font-size:13px;font-weight:bold;letter-spacing:2px;color:#7c3aed;font-family:Arial,sans-serif;">PRESUPUESTO</p>`:"";
        const footer=td.isBudget?`<p style="text-align:center;font-size:10px;color:#aaa;font-style:italic;font-family:Arial,sans-serif;">Este presupuesto no constituye una factura</p>`:"";
        return `<!DOCTYPE html><html lang="es"><head><meta charset="utf-8"><title>Ticket</title>
    <style>*{margin:0;padding:0;box-sizing:border-box;}body{font-family:"Courier New",Courier,monospace;background:#fff;}
    @page{margin:0;size:80mm auto;}@media print{html,body{width:80mm;}.no-print{display:none!important;}}</style></head>
    <body><div style="width:300px;max-width:100%;padding:14px 12px;margin:0 auto;">
    <div style="text-align:center;margin-bottom:10px;">
    <div style="display:inline-block;background:${hc};color:#fff;font-size:10px;font-weight:bold;padding:5px 14px;border-radius:5px;font-family:Arial,sans-serif;">${EMPRESA_NOMBRE.toUpperCase()}</div>
    <p style="margin-top:6px;font-size:11px;color:#555;font-family:Arial,sans-serif;">Tel: +${EMPRESA_TELEFONO}</p>
    <p style="font-size:11px;color:#555;font-family:Arial,sans-serif;">${td.fecha}</p>${hLabel}</div>
    <div style="border-top:1px dashed #bbb;margin-bottom:8px;"></div>
    <table style="width:100%;border-collapse:collapse;"><thead><tr style="border-bottom:1px solid #ddd;">
    <th style="padding:2px 0;font-size:10px;color:#888;text-align:left;font-family:Arial,sans-serif;">PRODUCTO</th>
    <th style="padding:2px 8px;font-size:10px;color:#888;text-align:center;font-family:Arial,sans-serif;">CANT</th>
    <th style="padding:2px 0;font-size:10px;color:#888;text-align:right;font-family:Arial,sans-serif;">IMPORTE</th>
    </tr></thead><tbody>${rows}${srRow}</tbody></table>
    <div style="border-top:1px dashed #bbb;margin:8px 0;"></div>
    <div style="display:flex;justify-content:space-between;align-items:baseline;margin-bottom:6px;">
    <span style="font-size:14px;font-weight:bold;font-family:Arial,sans-serif;">TOTAL</span>
    <span style="font-size:16px;font-weight:bold;color:${hc};font-family:Arial,sans-serif;">${fmt(td.total)}</span></div>
    ${!td.isBudget?pagoLines:""}
    ${td.clientName?`<p style="font-size:11px;color:#555;margin-bottom:2px;font-family:Arial,sans-serif;">Cliente: ${td.clientName}</p>`:""}
    ${td.sellerName?`<p style="font-size:11px;color:#555;margin-bottom:2px;font-family:Arial,sans-serif;">Vendido por: <strong>${td.sellerName}</strong></p>`:""}
    <div style="border-top:1px dashed #bbb;margin:10px 0 8px;"></div>${footer}
    <p style="text-align:center;font-size:11px;color:#aaa;font-style:italic;font-family:Arial,sans-serif;">ВЎGracias por su compra!</p>
    <div class="no-print" style="margin-top:18px;text-align:center;display:flex;gap:8px;justify-content:center;">
    <button onclick="window.print()" style="background:${hc};color:#fff;border:none;padding:9px 22px;border-radius:8px;font-size:13px;cursor:pointer;font-family:Arial,sans-serif;font-weight:600;">рҹ–ЁпёҸ Imprimir</button>
    <button onclick="window.close()" style="background:#e2e8f0;color:#475569;border:none;padding:9px 18px;border-radius:8px;font-size:13px;cursor:pointer;font-family:Arial,sans-serif;">Cerrar</button>
    </div></div></body></html>`;
    }

    // в”Җв”Җ QZ Tray в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    async function imprimirTicket(td: TicketData) {
        try {
            if(!qz.websocket.isActive()) await qz.websocket.connect();
            const config=qz.configs.create("Generic / Text Only");
            const sa=(s:string)=>s.replace(/[ГЎГ ГӨГў]/g,"a").replace(/[Г©ГЁГ«ГӘ]/g,"e").replace(/[ГӯГ¬ГҜГ®]/g,"i").replace(/[ГіГІГ¶Гҙ]/g,"o").replace(/[ГәГ№ГјГ»]/g,"u")
                .replace(/[ГҒГҖГ„ГӮ]/g,"A").replace(/[ГүГҲГӢГҠ]/g,"E").replace(/[ГҚГҢГҸГҺ]/g,"I").replace(/[Г“Г’Г–Г”]/g,"O").replace(/[ГҡГҷГңГӣ]/g,"U")
                .replace(/Гұ/g,"n").replace(/Г‘/g,"N").replace(/[^\x20-\x7E]/g,"");
            const W=32;
            const ctr=(s:string)=>{ const t=sa(s).slice(0,W); const p=Math.max(0,Math.floor((W-t.length)/2)); return " ".repeat(p)+t; };
            const raw=(n:number)=>{ const [e,d]=n.toFixed(2).split("."); return "$"+e.replace(/\B(?=(\d{3})+(?!\d))/g,".")+","+d; };
            const f2=(l:string,r:string)=>{ const a=sa(l),b=sa(r),sp=W-a.length-b.length; return sp>=1?a+" ".repeat(sp)+b:a.slice(0,W-b.length-1)+" "+b; };
            const fp=(nom:string,imp:string)=>{ const n=sa(nom),sp=W-n.length-imp.length; return sp>=1?n+" ".repeat(sp)+imp:n.slice(0,W-imp.length-1)+" "+imp; };
            const sep="-".repeat(W), sep2="=".repeat(W);
            let t="\x1B\x40\x1B\x61\x01\x1B\x21\x30EL MUNDO\nDEL DESCARTABLE\n\x1B\x21\x00"+ctr("Tel: +5493572549909")+"\n"+ctr(td.fecha)+"\n";
            if(td.isBudget) t+=ctr("** PRESUPUESTO **")+"\n";
            t+="\x1B\x61\x00"+sep+"\n";
            if(td.sellerName) t+="Vendedor: "+sa(td.sellerName)+"\n";
            if(td.clientName)  t+="Cliente:  "+sa(td.clientName)+"\n";
            t+=sep+"\n";
            td.items.forEach(it=>{ t+=sa(it.name)+"\n"; t+="  "+fp("x"+it.qty+(it.qty>0?"  "+raw(it.subtotal/it.qty):""),raw(it.subtotal))+"\n"; });
            t+=sep2+"\n";
            if(td.surcharge>0){ const base=td.total/(1+td.surcharge/100); t+=f2("Recargo "+td.surcharge+"%",raw(td.total-base))+"\n"; }
            t+="\x1B\x61\x00\x1B\x21\x10"+(td.isBudget?"PRESUPUESTO\n":"TOTAL\n")+raw(td.total)+"\n\x1B\x21\x00"+sep+"\n";
            if(!td.isBudget){
                const MP:Record<string,string>={efectivo:"Efectivo",transferencia:"Transf.",debito:"Debito",credito:"Credito",deudor:"Deuda"};
                if(td.payments&&td.payments.length>0){
                    td.payments.forEach(p=>{
                        const rb=p.rubro?" ["+sa(p.rubro)+"]":"";
                        const ab=p.abono?" ->"+sa(MP[p.abono]??p.abono):"";
                        t+=f2((MP[p.method]??p.method)+rb+ab,raw(p.amount))+"\n";
                    });
                } else {
                    t+="Pago: "+(MP[td.paymentMethod]??td.paymentMethod)+"\n";
                }
                t+=sep+"\n";
            } else { t+=ctr("No constituye factura")+"\n"+sep+"\n"; }
            t+="\x1B\x61\x01Gracias por su compra!\n\n\n\x1D\x56\x41\x00";
            await qz.print(config,[{type:"raw",format:"plain",data:t}]);
        } catch(e){ console.error(e); alert("Error al imprimir. Revisa QZ Tray o la impresora."); }
    }

    function descargarTicket(td:TicketData){
        const a=Object.assign(document.createElement("a"),{href:URL.createObjectURL(new Blob([buildTicketHTML(td)],{type:"text/html;charset=utf-8"})),download:`ticket-${td.fecha.replace(/[/:, ]/g,"-")}.html`,style:"display:none"});
        document.body.appendChild(a);a.click();setTimeout(()=>{URL.revokeObjectURL(a.href);a.remove();},1500);
    }

    function buildWAText(td:TicketData):string{
        const lineas=td.items.map(i=>`вҖў ${i.name} x${i.qty}: ${fmt(i.subtotal)}`).join("\n");
        let pagoWA="";
        if(td.payments&&td.payments.length>0){
            pagoWA=td.payments.map(p=>{
                let s=`рҹ’і ${METODOS[p.method]??p.method}: ${fmt(p.amount)}`;
                if(p.rubro) s+=` [${p.rubro}]`;
                if(p.abono) s+=` вҶ’ abona ${METODOS[p.abono]??p.abono}`;
                return s;
            }).join("\n");
        } else { pagoWA=`рҹ’і Pago: ${METODOS[td.paymentMethod]??td.paymentMethod}`; }
        return [`рҹ§ҫ *Ticket de compra*`,`рҹ“… ${td.fecha}`,`рҹҸӘ ${EMPRESA_NOMBRE}`,``,lineas,``,`*TOTAL: ${fmt(td.total)}*`,pagoWA,td.clientName?`рҹ‘Ө ${td.clientName}`:null,td.sellerName?`рҹ§‘вҖҚрҹ’ј Vendido por: ${td.sellerName}`:null,``,`рҹ“һ Consultas: +${EMPRESA_TELEFONO}`].filter(l=>l!==null).join("\n");
    }

    // в”Җв”Җ Modal WhatsApp в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    let waRes:((v:string|null)=>void)|null=null;
    const waModal=document.getElementById("wa-modal")!,waInput=document.getElementById("wa-phone-input") as HTMLInputElement,waErr=document.getElementById("wa-modal-error")!,waCfm=document.getElementById("wa-confirm-btn")!,waCncl=document.getElementById("wa-cancel-btn")!;
    const askPhone=():Promise<string|null>=>new Promise(r=>{ waRes=r;waInput.value="";waErr.classList.add("hidden");waModal.classList.remove("hidden");waModal.classList.add("flex");setTimeout(()=>waInput.focus(),80); });
    const closeWA=(v:string|null)=>{ waModal.classList.add("hidden");waModal.classList.remove("flex");waRes?.(v);waRes=null; };
    waCncl.addEventListener("click",()=>closeWA(null));
    waModal.addEventListener("click",e=>{if(e.target===waModal)closeWA(null);});
    waCfm.addEventListener("click",()=>{ const p=waInput.value.replace(/\D/g,""); if(p.length<10){waErr.textContent="IngresГЎ un nГәmero vГЎlido.";waErr.classList.remove("hidden");return;} closeWA(p); });
    waInput.addEventListener("keydown",e=>{if(e.key==="Enter")waCfm.click();if(e.key==="Escape")closeWA(null);});

    // в”Җв”Җ Modal cancelar venta в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    const cancelModal     = document.getElementById("cancel-modal")!;
    const cancelModalNo   = document.getElementById("cancel-modal-no")!;
    const cancelModalYes  = document.getElementById("cancel-modal-yes") as HTMLButtonElement;
    const cancelModalText = document.getElementById("cancel-modal-text")!;
    const cancelSpinner   = document.getElementById("cancel-modal-spinner")!;
    const cancelModalErr  = document.getElementById("cancel-modal-error")!;

    let pendingCancelCard: HTMLElement | null = null;
    let pendingCancelData: { notificationId: string; saleId: string; items: any[] } | null = null;

    function openCancelModal(card: HTMLElement, notificationId: string, saleId: string, items: any[]) {
        pendingCancelCard = card;
        pendingCancelData = { notificationId, saleId, items };
        cancelModalErr.classList.add("hidden");
        cancelModalText.textContent = "SГӯ, cancelar";
        cancelSpinner.classList.add("hidden");
        cancelModalYes.disabled = false;
        cancelModal.classList.remove("hidden");
        cancelModal.classList.add("flex");
    }
    function closeCancelModal() {
        cancelModal.classList.add("hidden");
        cancelModal.classList.remove("flex");
        pendingCancelCard = null;
        pendingCancelData = null;
    }
    cancelModalNo.addEventListener("click", closeCancelModal);
    cancelModal.addEventListener("click", e => { if (e.target === cancelModal) closeCancelModal(); });

    cancelModalYes.addEventListener("click", async () => {
        if (!pendingCancelData) return;
        const { notificationId, saleId, items } = pendingCancelData;

        cancelModalText.textContent = "Cancelando...";
        cancelSpinner.classList.remove("hidden");
        cancelModalYes.disabled = true;
        cancelModalErr.classList.add("hidden");

        try {
            // 1. Marcar venta como cancelada
            const { error: saleErr } = await supabase
                .from("sales")
                .update({ status: "cancelada" })
                .eq("id", saleId);
            if (saleErr) throw saleErr;

            // 2. Marcar notificaciГіn como leГӯda
            await supabase.from("notifications").update({ read: true }).eq("id", notificationId);

            // 3. Devolver stock por cada item
            for (const item of items) {
                if (!item.product_id && !item.productId) continue;
                const productId = item.product_id ?? item.productId;
                const qty = item.qty ?? item.quantity ?? 1;

                // Obtener stock actual
                const { data: prod } = await supabase
                    .from("products")
                    .select("stock, name")
                    .eq("id", productId)
                    .single();

                if (!prod) continue;

                const stockAntes = prod.stock ?? 0;
                const stockDespues = stockAntes + qty;

                // Actualizar stock
                await supabase
                    .from("products")
                    .update({ stock: stockDespues })
                    .eq("id", productId);

                // Registrar movimiento
                await supabase.from("stock_movements").insert({
                    product_id:   productId,
                    product_name: prod.name ?? item.name ?? null,
                    type:         "entrada",
                    quantity:     qty,
                    stock_before: stockAntes,
                    stock_after:  stockDespues,
                    reason:       "DevoluciГіn por cancelaciГіn de venta",
                });
            }

            closeCancelModal();
            pendingCancelCard?.remove();
            updateLabel();

        } catch (err: any) {
            cancelModalErr.textContent = err?.message ?? "Error al cancelar la venta.";
            cancelModalErr.classList.remove("hidden");
            cancelModalText.textContent = "SГӯ, cancelar";
            cancelSpinner.classList.add("hidden");
            cancelModalYes.disabled = false;
        }
    });

    function bindTicketButtons(card:HTMLElement,td:TicketData){
        card.querySelector(".ticket-print-btn")?.addEventListener("click",()=>imprimirTicket(td));
        card.querySelector(".ticket-pdf-btn")?.addEventListener("click",()=>descargarTicket(td));
        card.querySelector(".ticket-wa-btn")?.addEventListener("click",async()=>{ const p=await askPhone();if(!p)return;window.open(`https://wa.me/${p}?text=${encodeURIComponent(buildWAText(td))}`,"_blank"); });
    }

    function showSuccess(card:HTMLElement,total:number,td:TicketData){
        card.querySelector(".cobro-form")?.classList.add("hidden");
        const panel=card.querySelector<HTMLElement>(".success-panel")!;
        panel.classList.remove("hidden");
        let metodoTexto="";
        if(td.payments&&td.payments.length>0){
            metodoTexto=td.payments.map(p=>{
                let s=`${METODOS[p.method]??p.method} ${fmt(p.amount)}`;
                if(p.rubro) s+=` [${p.rubro}]`;
                if(p.abono) s+=` вҶ’ ${METODOS[p.abono]??p.abono}`;
                return s;
            }).join(" + ");
        } else { metodoTexto=METODOS[td.paymentMethod]??td.paymentMethod; }
        panel.querySelector<HTMLElement>(".success-msg")!.innerHTML=`
            <div class="w-8 h-8 rounded-full bg-emerald-100 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-emerald-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
            </div>
            <div>
                <p class="text-sm font-semibold text-slate-800">Cobro registrado por ${fmt(total)}</p>
                <p class="text-xs text-slate-400">${metodoTexto}${td.clientName?` вҖ” ${td.clientName}`:""}${td.sellerName?` В· Vendido por ${td.sellerName}`:""}</p>
            </div>`;
        bindTicketButtons(card,td);
        panel.querySelector(".done-btn")?.addEventListener("click",()=>{card.remove();updateLabel();});
    }

    function updateLabel(){
        const n=document.querySelectorAll(".sale-card").length;
        const lbl=document.getElementById("pending-label");
        if(lbl) lbl.textContent=`${n} ${n===1?"venta pendiente":"ventas pendientes"}`;
        if(n===0) document.getElementById("sales-list")!.innerHTML=`
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm flex flex-col items-center justify-center py-14 text-center px-4">
                <div class="w-12 h-12 rounded-2xl bg-emerald-50 flex items-center justify-center mb-3">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6 text-emerald-500" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"/></svg>
                </div>
                <p class="text-slate-700 font-semibold text-sm">Todo al dГӯa</p>
                <p class="text-slate-400 text-xs mt-1">No hay ventas pendientes de cobro</p>
            </div>`;
    }

    // в”Җв”Җ Presupuestos в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    document.querySelectorAll<HTMLElement>(".sale-card[data-is-budget='true']").forEach(card=>{
        card.querySelector<HTMLButtonElement>(".discard-btn")?.addEventListener("click",async()=>{
            await supabase.from("notifications").update({read:true}).eq("id",card.dataset.notificationId!);
            card.remove();updateLabel();
        });
        card.querySelector<HTMLButtonElement>(".budget-print-btn")?.addEventListener("click",async()=>{
            let p:any={};try{p=JSON.parse(card.querySelector<HTMLButtonElement>(".budget-print-btn")!.dataset.items??"{}");}catch{}
            const fecha=new Date().toLocaleString("es-AR",{day:"2-digit",month:"2-digit",year:"numeric",hour:"2-digit",minute:"2-digit"});
            const td:TicketData={items:p.items??[],total:p.total??0,paymentMethod:"efectivo",clientName:p.client_name??null,sellerName:p.seller_name??null,fecha,surcharge:0,transferAccount:null,isBudget:true};
            try{await imprimirTicket(td);}catch{const w=window.open("","_blank","width=400,height=600");if(w){w.document.write(buildTicketHTML(td));w.document.close();setTimeout(()=>w.print(),500);}}
        });
    });

    // в”Җв”Җ Ventas normales в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
    document.querySelectorAll<HTMLElement>(".sale-card[data-is-budget='false']").forEach(card=>{
        const clientSel       = card.querySelector<HTMLSelectElement>(".client-select")!;
        const cobrarBtn       = card.querySelector<HTMLButtonElement>(".cobrar-btn")!;
        const totalDisp       = card.querySelector<HTMLElement>(".total-display")!;
        const srRow           = card.querySelector<HTMLElement>(".surcharge-row")!;
        const srLbl           = card.querySelector<HTMLElement>(".surcharge-row-label")!;
        const srAmt           = card.querySelector<HTMLElement>(".surcharge-amount")!;
        const cashSec         = card.querySelector<HTMLElement>(".cash-section")!;
        const cashIn          = card.querySelector<HTMLInputElement>(".cash-received")!;
        const cashKept        = card.querySelector<HTMLInputElement>(".cash-kept")!;
        const useTotalBtn     = card.querySelector<HTMLButtonElement>(".use-total-btn")!;
        const totalCobradoSec = card.querySelector<HTMLElement>(".total-cobrado-section")!;
        const changeEl        = card.querySelector<HTMLElement>(".change-amount")!;
        const changeDsp       = card.querySelector<HTMLElement>(".change-display")!;
        const insuf           = card.querySelector<HTMLElement>(".insufficient-alert")!;
        const errorEl         = card.querySelector<HTMLElement>(".cobro-error")!;
        const baseTotal       = Number(cobrarBtn.dataset.baseTotal??0);

        const singlePanel  = card.querySelector<HTMLElement>(".single-payment-panel")!;
        const rubroSingle  = card.querySelector<HTMLSelectElement>(".rubro-single")!;
        const mixedPanel   = card.querySelector<HTMLElement>(".mixed-payment-panel")!;
        const mixedLabel1  = card.querySelector<HTMLElement>(".mixed-label-1")!;
        const mixedLabel2  = card.querySelector<HTMLElement>(".mixed-label-2")!;
        const mixedAmt1    = card.querySelector<HTMLInputElement>(".mixed-amount-1")!;
        const mixedAmt2    = card.querySelector<HTMLInputElement>(".mixed-amount-2")!;
        const mixedDiff    = card.querySelector<HTMLElement>(".mixed-diff-amount")!;
        const rubroMixed1  = card.querySelector<HTMLSelectElement>(".rubro-mixed-1")!;
        const rubroMixed2  = card.querySelector<HTMLSelectElement>(".rubro-mixed-2")!;
        const abonoMixed1  = card.querySelector<HTMLSelectElement>(".abono-mixed-1")!;
        const abonoMixed2  = card.querySelector<HTMLSelectElement>(".abono-mixed-2")!;

        let sel: {method:string;surcharge:number}[] = [];
        const LABELS:Record<string,string>={efectivo:"Efectivo",transferencia:"Transferencia",debito:"DГ©bito",credito:"CrГ©dito",deudor:"Deuda"};
        const SOLO=["deudor","debito","credito"];

        const getTotal=()=>{ const sr=sel.reduce((mx,m)=>Math.max(mx,m.surcharge),0); return baseTotal+baseTotal*(sr/100); };
        const getSR=()=>sel.reduce((mx,m)=>Math.max(mx,m.surcharge),0);

        function refreshDiff(){
            const total=getTotal(),a1=parseFloat(mixedAmt1.value)||0,a2=parseFloat(mixedAmt2.value)||0,r=total-a1-a2;
            if(Math.abs(r)<0.01){mixedDiff.textContent="вң“ OK";mixedDiff.className="mixed-diff-amount text-xs font-bold text-emerald-600";}
            else if(r>0){mixedDiff.textContent=fmt(r);mixedDiff.className="mixed-diff-amount text-xs font-bold text-amber-600";}
            else{mixedDiff.textContent=`Excede ${fmt(Math.abs(r))}`;mixedDiff.className="mixed-diff-amount text-xs font-bold text-red-600";}
        }
        mixedAmt1.addEventListener("input",()=>{ const total=getTotal(),a1=parseFloat(mixedAmt1.value)||0,resto=Math.max(0,total-a1); mixedAmt2.value=resto>0?String(Math.round(resto)):""; refreshDiff(); });
        mixedAmt2.addEventListener("input",refreshDiff);

        function updateUI(){
            const total=getTotal(),isMixed=sel.length===2;
            const hasEf=sel.some(m=>m.method==="efectivo"),hasDeb=sel.some(m=>m.method==="deudor");
            const sr=getSR(),amt=baseTotal*(sr/100);

            if(sr>0){ srRow.classList.remove("hidden");srLbl.textContent=`Recargo ${sr}%`;srAmt.textContent=`+ ${fmt(amt)}`; card.querySelector(".surcharge-info")?.classList.remove("hidden"); const sl=card.querySelector<HTMLElement>(".surcharge-label");if(sl)sl.textContent=`Se aplica un recargo del ${sr}%`; }
            else { srRow.classList.add("hidden");card.querySelector(".surcharge-info")?.classList.add("hidden"); }
            totalDisp.textContent=fmt(total);

            const showSingle=sel.length===1&&!hasDeb;
            singlePanel.classList.toggle("hidden",!showSingle);
            if(!showSingle) rubroSingle.value="";

            if(isMixed){
                mixedPanel.classList.remove("hidden");
                mixedLabel1.textContent=LABELS[sel[0].method]??sel[0].method;
                mixedLabel2.textContent=LABELS[sel[1].method]??sel[1].method;
                const prevA1=abonoMixed1.value, prevA2=abonoMixed2.value;
                [abonoMixed1, abonoMixed2].forEach(s=>{
                    s.innerHTML=`<option value="">Sin abono</option>`+
                        sel.map(m=>`<option value="${m.method}">${LABELS[m.method]??m.method}</option>`).join("");
                });
                abonoMixed1.value=prevA1;
                abonoMixed2.value=prevA2;
                if(!mixedAmt1.value&&!mixedAmt2.value){ const h=Math.round(total/2); mixedAmt1.value=String(h);mixedAmt2.value=String(total-h); refreshDiff(); }
            } else {
                mixedPanel.classList.add("hidden");
                mixedAmt1.value="";mixedAmt2.value="";
                rubroMixed1.value="";rubroMixed2.value="";
                abonoMixed1.innerHTML=`<option value="">Sin abono</option>`;
                abonoMixed2.innerHTML=`<option value="">Sin abono</option>`;
            }

            const showCash=hasEf&&!isMixed;
            cashSec.classList.toggle("hidden",!showCash);
            if(showCash){ cashIn.value="";cashKept.value="";totalCobradoSec.classList.add("hidden");refreshChange();setTimeout(()=>cashIn.focus(),50); }

            card.querySelector(".debtor-info")?.classList.toggle("hidden",!hasDeb);
            card.querySelector<HTMLElement>(".client-required")?.classList.toggle("hidden",!hasDeb);
            clientSel.classList.toggle("border-red-400",hasDeb);clientSel.classList.toggle("border-slate-200",!hasDeb);
        }

        card.querySelectorAll<HTMLButtonElement>(".payment-btn").forEach(btn=>{
            btn.addEventListener("click",()=>{
                const m=btn.dataset.method!,sr=Number(btn.dataset.surcharge??0),idx=sel.findIndex(s=>s.method===m);
                if(idx!==-1){ sel.splice(idx,1); }
                else { const nSolo=SOLO.includes(m),hSolo=sel.some(s=>SOLO.includes(s.method)); if(nSolo||hSolo||sel.length>=2) sel=[{method:m,surcharge:sr}]; else sel.push({method:m,surcharge:sr}); }
                card.querySelectorAll<HTMLButtonElement>(".payment-btn").forEach(b=>{
                    const bm=b.dataset.method!,bDeb=bm==="deudor",bidx=sel.findIndex(s=>s.method===bm);
                    const badge=b.querySelector<HTMLElement>(".payment-badge")!;
                    b.classList.remove("bg-emerald-600","border-emerald-600","text-white","shadow-sm","bg-red-600","border-red-600");
                    b.classList.add(bDeb?"border-red-200":"border-slate-200",bDeb?"text-red-500":"text-slate-600");
                    badge.classList.add("hidden");badge.textContent="";
                    if(bidx!==-1){
                        if(bDeb){b.classList.remove("border-red-200","text-red-500");b.classList.add("bg-red-600","border-red-600","text-white","shadow-sm");}
                        else{b.classList.remove("border-slate-200","text-slate-600");b.classList.add("bg-emerald-600","border-emerald-600","text-white","shadow-sm");}
                        if(sel.length===2){badge.classList.remove("hidden");badge.textContent=String(bidx+1);}
                    }
                });
                updateUI();
            });
        });

        useTotalBtn.addEventListener("click",()=>{cashKept.value=String(Math.round(getTotal()));});

        function refreshChange(){
            const total=getTotal(),recv=parseFloat(cashIn.value);
            if(!cashIn.value||isNaN(recv)){ changeEl.textContent="вҖ”";changeEl.className="change-amount text-sm font-bold text-emerald-700";changeDsp.className="change-display flex items-center justify-center py-2.5 px-3 rounded-xl bg-emerald-50 border border-emerald-100 min-h-[42px]";insuf.classList.add("hidden");totalCobradoSec.classList.add("hidden");return; }
            const diff=recv-total;changeEl.textContent=fmt(Math.abs(diff));
            if(diff<0){ changeEl.className="change-amount text-sm font-bold text-red-600";changeDsp.className="change-display flex items-center justify-center py-2.5 px-3 rounded-xl bg-red-50 border border-red-200 min-h-[42px]";insuf.classList.remove("hidden");totalCobradoSec.classList.add("hidden"); }
            else { changeEl.className="change-amount text-sm font-bold text-emerald-700";changeDsp.className="change-display flex items-center justify-center py-2.5 px-3 rounded-xl bg-emerald-50 border border-emerald-100 min-h-[42px]";insuf.classList.add("hidden");totalCobradoSec.classList.remove("hidden");if(!cashKept.value) cashKept.value=String(Math.round(total)); }
        }
        cashIn.addEventListener("input",refreshChange);

        card.querySelector<HTMLButtonElement>(".discard-btn")?.addEventListener("click",async()=>{
            await supabase.from("notifications").update({read:true}).eq("id",cobrarBtn.dataset.notificationId!);
            card.remove();updateLabel();
        });

        // в”Җв”Җ Cancelar venta в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        card.querySelector<HTMLButtonElement>(".cancel-sale-btn")?.addEventListener("click", () => {
            let rawItems: any[] = [];
            try {
                const parsed = JSON.parse(cobrarBtn.dataset.items ?? "{}");
                rawItems = parsed.items ?? [];
            } catch {}
            openCancelModal(
                card,
                cobrarBtn.dataset.notificationId!,
                cobrarBtn.dataset.saleId!,
                rawItems
            );
        });

        // в”Җв”Җ Confirmar cobro в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
        cobrarBtn.addEventListener("click",async()=>{
            const nid=cobrarBtn.dataset.notificationId!,saleId=cobrarBtn.dataset.saleId!,rawData=cobrarBtn.dataset.items??"{}";
            const clientId=clientSel.value||null;
            const cobTxt=cobrarBtn.querySelector<HTMLElement>(".cobrar-text")!,spinner=cobrarBtn.querySelector<HTMLElement>(".cobrar-spinner")!;
            const isMixed=sel.length===2,hasDeb=sel.some(m=>m.method==="deudor"),hasEf=sel.some(m=>m.method==="efectivo");
            const sr=getSR(),totalFinal=getTotal(),pm=sel[0]?.method??"";

            errorEl.classList.add("hidden");
            if(sel.length===0){errorEl.textContent="SeleccionГЎ un mГ©todo de pago.";errorEl.classList.remove("hidden");return;}
            if(hasDeb&&!clientId){errorEl.textContent="Para registrar una deuda debГ©s seleccionar un cliente.";errorEl.classList.remove("hidden");clientSel.focus();return;}
            if(isMixed){ const a1=parseFloat(mixedAmt1.value)||0,a2=parseFloat(mixedAmt2.value)||0; if(Math.abs(a1+a2-totalFinal)>1){errorEl.textContent=`Los montos no suman el total. Falta: ${fmt(totalFinal-a1-a2)}`;errorEl.classList.remove("hidden");return;} }
            if(hasEf&&!isMixed){ const recv=parseFloat(cashIn.value); if(!isNaN(recv)&&recv<totalFinal){errorEl.textContent="El monto entregado es menor al total a cobrar.";errorEl.classList.remove("hidden");return;} }

            cobrarBtn.disabled=true;cobTxt.textContent="Procesando...";spinner.classList.remove("hidden");

            try {
                let clientName:string|null=null;
                if(clientId){const{data:cd}=await supabase.from("clients").select("name").eq("id",clientId).single();clientName=cd?.name??null;}

                let finalTotal=totalFinal;
                if(hasEf&&!isMixed){ const recv=parseFloat(cashIn.value); if(!isNaN(recv)&&recv>=totalFinal){const kept=parseFloat(cashKept.value);if(!isNaN(kept)&&kept>0) finalTotal=kept;} }

                // Construir array de pagos
                let paymentsData: PaymentEntry[];
                if(isMixed){
                    const a1=parseFloat(mixedAmt1.value)||0,a2=parseFloat(mixedAmt2.value)||0;
                    paymentsData=[
                        {method:sel[0].method,amount:a1,rubro:rubroMixed1.value||null,transferAccount:null,abono:abonoMixed1.value||null},
                        {method:sel[1].method,amount:a2,rubro:rubroMixed2.value||null,transferAccount:null,abono:abonoMixed2.value||null},
                    ];
                } else {
                    paymentsData=[{method:pm,amount:finalTotal,rubro:rubroSingle.value||null,transferAccount:null,abono:null}];
                }

                const nota=paymentsData.map(p=>{ let s=`${LABELS[p.method]??p.method}: $${p.amount}`; if(p.rubro) s+=` [${p.rubro}]`; if(p.abono) s+=` вҶ’ ${LABELS[p.abono]??p.abono}`; return s; }).join(" | ");
                const pmGuardar=isMixed?sel.map(m=>m.method).join("/"):pm;

                // 1. Actualizar venta
                const{error:upErr}=await supabase.from("sales").update({
                    client_id:clientId,client_name:clientName,final_total:finalTotal,
                    payment_method:pmGuardar,surcharge:sr,transfer_account:null,
                    note:nota,status:hasDeb?"deuda":"pagado",
                }).eq("id",saleId);
                if(upErr) throw upErr;

                // 2. в”Җв”Җ NUEVO: insertar en sale_payments в”Җв”Җ
                const salePaymentRows = paymentsData.map(p => ({
                    sale_id: saleId,
                    method:  p.method,
                    amount:  p.amount,
                    rubro:   p.rubro ?? null,
                    abono:   p.abono ?? null,
                }));
                const { error: spErr } = await supabase
                    .from("sale_payments")
                    .insert(salePaymentRows);
                if (spErr) throw spErr;

                if(hasDeb&&clientId){
                    const{data:cd}=await supabase.from("clients").select("debt").eq("id",clientId).single();
                    await supabase.from("clients").update({debt:(cd?.debt??0)+totalFinal}).eq("id",clientId);
                    await supabase.from("debts").insert([{client_id:clientId,sale_id:saleId,original_total:totalFinal,current_total:totalFinal,paid:false}]);
                }
                await supabase.from("notifications").update({read:true}).eq("id",nid);

                let parsed:any={};try{parsed=JSON.parse(rawData);}catch{}
                const fecha=new Date().toLocaleString("es-AR",{day:"2-digit",month:"2-digit",year:"numeric",hour:"2-digit",minute:"2-digit"});
                const td:TicketData={items:parsed.items??[],total:finalTotal,paymentMethod:pm,clientName,sellerName:parsed.seller_name??null,fecha,surcharge:sr,transferAccount:null,payments:paymentsData};
                showSuccess(card,finalTotal,td);
                if(!hasDeb) await imprimirTicket(td);

            } catch(err:any){
                errorEl.textContent=err?.message??"Error al procesar el cobro.";errorEl.classList.remove("hidden");
                cobrarBtn.disabled=false;cobTxt.textContent="Confirmar cobro";spinner.classList.add("hidden");
            }
        });
    });

    document.getElementById("mark-all-read")?.addEventListener("click",async()=>{
        await supabase.from("notifications").update({read:true}).eq("type","nueva_venta").eq("read",false);
        document.querySelectorAll<HTMLElement>(".sale-card").forEach(c=>c.remove());
        updateLabel();
    });
</script>