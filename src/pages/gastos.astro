---
import Layout from "../layouts/Layout.astro";
import { supabase } from "../lib/supabaseClient.js";

const { data: { session } } = await supabase.auth.getSession();
const userId = session?.user?.id;

const hoy = new Date();

// Gastos del día
const inicioDia = new Date(hoy.getFullYear(), hoy.getMonth(), hoy.getDate()).toISOString();
const { data: gastosDia } = await supabase
    .from("expenses")
    .select("*")
    .gte("created_at", inicioDia)
    .order("created_at", { ascending: false });

const totalDia = gastosDia?.reduce((acc, g) => acc + (g.amount ?? 0), 0) ?? 0;

// Gastos del mes
const inicioMes = new Date(hoy.getFullYear(), hoy.getMonth(), 1).toISOString();
const { data: gastosMes } = await supabase
    .from("expenses")
    .select("amount, category")
    .gte("created_at", inicioMes);

const totalMes = gastosMes?.reduce((acc, g) => acc + (g.amount ?? 0), 0) ?? 0;

// Historial completo
const { data: historial } = await supabase
    .from("expenses")
    .select("*")
    .order("created_at", { ascending: false });

// Días únicos para el filtro
const diasUnicos = [...new Set(
    (historial ?? []).map(g => g.created_at.slice(0, 10))
)].sort((a: string, b: string) => b.localeCompare(a));

const CATEGORIAS = [
    { value: "Compra a proveedor",   label: "Compra a proveedor",   icon: "🏭" },
    { value: "Compra a cliente",     label: "Compra a cliente",     icon: "🤝" },
    { value: "Luz",                  label: "Luz",                  icon: "💡" },
    { value: "Alquiler",             label: "Alquiler",             icon: "🏠" },
    { value: "Reparación",           label: "Reparación / rotura",  icon: "🔧" },
    { value: "Gasto operativo",      label: "Gasto operativo",      icon: "📋" },
    { value: "Otros",                label: "Otros",                icon: "📦" },
];

const BADGE: Record<string, string> = {
    "Compra a proveedor": "bg-blue-50 text-blue-700 border-blue-100",
    "Compra a cliente":   "bg-purple-50 text-purple-700 border-purple-100",
    "Luz":                "bg-yellow-50 text-yellow-700 border-yellow-100",
    "Alquiler":           "bg-orange-50 text-orange-700 border-orange-100",
    "Reparación":         "bg-red-50 text-red-700 border-red-100",
    "Gasto operativo":    "bg-sky-50 text-sky-700 border-sky-100",
    "Otros":              "bg-slate-100 text-slate-600 border-slate-200",
};

const ICON: Record<string, string> = {
    "Compra a proveedor": "🏭",
    "Compra a cliente":   "🤝",
    "Luz":                "💡",
    "Alquiler":           "🏠",
    "Reparación":         "🔧",
    "Gasto operativo":    "📋",
    "Otros":              "📦",
};

// Totales del mes por categoría
const totalesPorCat: Record<string, number> = {};
for (const g of gastosMes ?? []) {
    totalesPorCat[g.category] = (totalesPorCat[g.category] ?? 0) + (g.amount ?? 0);
}

const formatDate = (dateStr: string | null) => {
    if (!dateStr) return "—";
    return new Date(dateStr).toLocaleString("es-AR", {
        day: "2-digit", month: "2-digit", year: "numeric",
        hour: "2-digit", minute: "2-digit",
    });
};

const formatMoney = (amount: number | null) => {
    if (amount == null) return "—";
    return new Intl.NumberFormat("es-AR", { style: "currency", currency: "ARS" }).format(amount);
};

const historialJSON  = JSON.stringify(historial ?? []);
const badgeJSON      = JSON.stringify(BADGE);
const iconJSON       = JSON.stringify(ICON);
---

<Layout>
    <div class="min-h-screen bg-slate-50 px-4 sm:px-6 py-6 sm:py-8 pt-20 lg:pt-8">
        <div class="max-w-5xl mx-auto">

            <!-- Header -->
            <div class="flex items-center justify-between gap-3 mb-6 sm:mb-8">
                <div class="flex items-center gap-3 min-w-0">
                    <div class="w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-rose-500 flex items-center justify-center shrink-0 shadow-sm">
                        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 sm:w-5 sm:h-5 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 10h18M7 15h1m4 0h1m-7 4h12a3 3 0 003-3V8a3 3 0 00-3-3H6a3 3 0 00-3 3v8a3 3 0 003 3z" />
                        </svg>
                    </div>
                    <div class="min-w-0">
                        <h1 class="text-xl sm:text-2xl font-bold text-slate-800 leading-tight">Gastos</h1>
                        <p class="text-xs sm:text-sm text-slate-500 truncate">
                            {new Date().toLocaleDateString("es-AR", { weekday: "long", day: "numeric", month: "long" })}
                        </p>
                    </div>
                </div>
                <button
                    id="nuevo-gasto-btn"
                    class="inline-flex items-center gap-1.5 sm:gap-2 bg-rose-500 hover:bg-rose-600 active:scale-95 text-white text-xs sm:text-sm font-semibold px-3 sm:px-4 py-2 sm:py-2.5 rounded-xl transition-all shrink-0 shadow-sm"
                >
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                    <span class="hidden xs:inline">Nuevo gasto</span>
                    <span class="xs:hidden">Nuevo</span>
                </button>
            </div>

            <!-- KPIs -->
            <div class="grid grid-cols-2 gap-3 sm:gap-4 mb-5 sm:mb-6">
                <div class="bg-white border border-slate-200 rounded-2xl px-4 sm:px-5 py-4 shadow-sm">
                    <p class="text-xs text-slate-400 uppercase tracking-wide font-semibold mb-1">Gastos hoy</p>
                    <p class="text-xl sm:text-2xl font-bold text-rose-500 break-all">{formatMoney(totalDia)}</p>
                    <p class="text-xs text-slate-400 mt-1">{gastosDia?.length ?? 0} {(gastosDia?.length ?? 0) === 1 ? "gasto" : "gastos"}</p>
                </div>
                <div class="bg-white border border-slate-200 rounded-2xl px-4 sm:px-5 py-4 shadow-sm">
                    <p class="text-xs text-slate-400 uppercase tracking-wide font-semibold mb-1">Gastos del mes</p>
                    <p class="text-xl sm:text-2xl font-bold text-slate-800 break-all">{formatMoney(totalMes)}</p>
                    <p class="text-xs text-slate-400 mt-1">{gastosMes?.length ?? 0} {(gastosMes?.length ?? 0) === 1 ? "gasto" : "gastos"}</p>
                </div>
            </div>

            <!-- Desglose del mes por categoría -->
            {Object.keys(totalesPorCat).length > 0 && (
                <div class="bg-white border border-slate-200 rounded-2xl p-4 sm:p-5 mb-5 sm:mb-6 shadow-sm">
                    <h3 class="text-sm font-semibold text-slate-700 mb-3">Este mes por categoría</h3>
                    <div class="grid grid-cols-2 sm:grid-cols-3 gap-2">
                        {CATEGORIAS.filter(c => totalesPorCat[c.value]).map(c => (
                            <div class={`rounded-xl px-3 py-2.5 border ${BADGE[c.value]}`}>
                                <p class="text-xs font-medium mb-0.5">{c.icon} {c.label}</p>
                                <p class="text-sm font-bold">{formatMoney(totalesPorCat[c.value] ?? 0)}</p>
                            </div>
                        ))}
                    </div>
                </div>
            )}

            <!-- Historial -->
            <div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">

                <!-- Encabezado + filtro -->
                <div class="px-4 sm:px-5 py-3.5 sm:py-4 border-b border-slate-100 flex flex-col sm:flex-row sm:items-center justify-between gap-3">
                    <h2 class="text-sm font-semibold text-slate-800">Historial de gastos</h2>
                    {diasUnicos.length > 0 && (
                        <div class="flex items-center gap-2">
                            <label for="filtro-fecha" class="text-xs text-slate-400 shrink-0">Filtrar:</label>
                            <select
                                id="filtro-fecha"
                                class="text-xs border border-slate-200 rounded-lg px-2.5 py-1.5 bg-white text-slate-700 focus:outline-none focus:ring-2 focus:ring-rose-400 cursor-pointer"
                            >
                                <option value="">Todos los días</option>
                                {diasUnicos.map((d: string) => {
                                    const label = new Date(d + "T12:00:00").toLocaleDateString("es-AR", {
                                        day: "2-digit", month: "2-digit", year: "numeric"
                                    });
                                    return <option value={d}>{label}</option>;
                                })}
                            </select>
                        </div>
                    )}
                </div>

                {(historial?.length ?? 0) > 0 ? (
                    <>
                        <!-- Vista tabla (sm+) -->
                        <div class="hidden sm:block overflow-x-auto">
                            <table class="w-full text-sm">
                                <thead>
                                    <tr class="border-b border-slate-100 bg-slate-50/70">
                                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wide">Fecha</th>
                                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wide">Categoría</th>
                                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wide">Descripción</th>
                                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wide">Relacionado</th>
                                        <th class="text-left px-5 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wide">Método</th>
                                        <th class="text-right px-5 py-3 text-xs font-semibold text-slate-400 uppercase tracking-wide">Monto</th>
                                        <th class="px-5 py-3"></th>
                                    </tr>
                                </thead>
                                <tbody class="divide-y divide-slate-100" id="historial-tbody">
                                    {historial?.map((g) => (
                                        <tr
                                            class="hover:bg-slate-50 transition-colors historial-row"
                                            data-fecha={g.created_at.slice(0, 10)}
                                            data-id={g.id}
                                        >
                                            <td class="px-5 py-3.5 text-slate-400 text-xs whitespace-nowrap">{formatDate(g.created_at)}</td>
                                            <td class="px-5 py-3.5">
                                                <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium border ${BADGE[g.category] ?? "bg-slate-100 text-slate-600 border-slate-200"}`}>
                                                    {ICON[g.category] ?? "📦"} {g.category}
                                                </span>
                                            </td>
                                            <td class="px-5 py-3.5 text-slate-700 max-w-[180px] truncate">{g.description || <span class="text-slate-300">—</span>}</td>
                                            <td class="px-5 py-3.5 text-slate-500 text-xs">{g.related_name || <span class="text-slate-300">—</span>}</td>
                                            <td class="px-5 py-3.5 text-slate-500 text-xs capitalize">{g.payment_method}</td>
                                            <td class="px-5 py-3.5 text-right font-bold text-rose-500">{formatMoney(g.amount)}</td>
                                            <td class="px-5 py-3.5">
                                                <button
                                                    class="eliminar-btn text-slate-200 hover:text-red-400 transition-colors"
                                                    data-id={g.id}
                                                    title="Eliminar"
                                                >
                                                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                    </svg>
                                                </button>
                                            </td>
                                        </tr>
                                    ))}
                                </tbody>
                            </table>
                        </div>

                        <!-- Vista tarjetas (móvil) -->
                        <div class="sm:hidden divide-y divide-slate-100" id="historial-cards">
                            {historial?.map((g) => (
                                <div
                                    class="px-4 py-4 historial-card"
                                    data-fecha={g.created_at.slice(0, 10)}
                                    data-id={g.id}
                                >
                                    <div class="flex items-start justify-between gap-2 mb-2">
                                        <span class={`inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium border ${BADGE[g.category] ?? "bg-slate-100 text-slate-600 border-slate-200"}`}>
                                            {ICON[g.category] ?? "📦"} {g.category}
                                        </span>
                                        <div class="flex items-center gap-2 shrink-0">
                                            <span class="text-base font-bold text-rose-500">{formatMoney(g.amount)}</span>
                                            <button
                                                class="eliminar-btn text-slate-200 hover:text-red-400 transition-colors"
                                                data-id={g.id}
                                            >
                                                <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                                                </svg>
                                            </button>
                                        </div>
                                    </div>
                                    {g.description && (
                                        <p class="text-sm text-slate-700 mb-1">{g.description}</p>
                                    )}
                                    <div class="flex items-center gap-3 text-xs text-slate-400 flex-wrap">
                                        {g.related_name && <span class="font-medium text-slate-500">{g.related_name}</span>}
                                        <span class="capitalize">{g.payment_method}</span>
                                        <span>{formatDate(g.created_at)}</span>
                                    </div>
                                </div>
                            ))}
                        </div>
                    </>
                ) : (
                    <div class="flex flex-col items-center justify-center py-16 text-center px-4">
                        <div class="text-4xl mb-3">💸</div>
                        <p class="text-slate-500 text-sm font-medium">No hay gastos registrados</p>
                        <p class="text-slate-400 text-xs mt-1">Usá el botón "Nuevo gasto" para agregar uno</p>
                    </div>
                )}

                {(historial?.length ?? 0) > 0 && (
                    <div class="px-4 sm:px-5 py-3 border-t border-slate-100 bg-slate-50/50">
                        <p id="historial-count" class="text-xs text-slate-400 text-right">
                            {historial?.length} {historial?.length === 1 ? "registro" : "registros"} en total
                        </p>
                    </div>
                )}
            </div>

        </div>
    </div>
</Layout>

<!-- Datos para scripts -->
<script type="application/json" id="badge-data" set:html={badgeJSON}></script>
<script type="application/json" id="icon-data" set:html={iconJSON}></script>

<!-- Modal nuevo gasto -->
<div id="nuevo-gasto-modal" class="hidden fixed inset-0 z-50 flex items-end sm:items-center justify-center bg-black/40 backdrop-blur-sm">
    <div class="bg-white rounded-t-3xl sm:rounded-2xl shadow-xl w-full sm:max-w-md p-6 space-y-4 max-h-[90vh] overflow-y-auto">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-xl bg-rose-50 flex items-center justify-center shrink-0">
                    <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-rose-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
                    </svg>
                </div>
                <div>
                    <p class="text-sm font-bold text-slate-800">Nuevo gasto</p>
                    <p class="text-xs text-slate-400">Completá los datos</p>
                </div>
            </div>
            <button id="nuevo-modal-cancel-x" class="text-slate-300 hover:text-slate-500 transition-colors p-1">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>

        <div class="space-y-4">
            <!-- Monto -->
            <div>
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1.5">Monto *</label>
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-sm font-medium">$</span>
                    <input
                        id="input-monto"
                        type="number"
                        min="0"
                        step="0.01"
                        placeholder="0,00"
                        class="w-full border border-slate-200 rounded-xl pl-7 pr-3 py-2.5 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-rose-400 focus:border-transparent placeholder:text-slate-300"
                    />
                </div>
            </div>

            <!-- Categoría -->
            <div>
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1.5">Categoría *</label>
                <div class="grid grid-cols-2 gap-2">
                    {[
                        { value: "Compra a proveedor", label: "Compra a proveedor",  icon: "🏭" },
                        { value: "Compra a cliente",   label: "Compra a cliente",    icon: "🤝" },
                        { value: "Luz",                label: "Luz",                 icon: "💡" },
                        { value: "Alquiler",           label: "Alquiler",            icon: "🏠" },
                        { value: "Reparación",         label: "Reparación / rotura", icon: "🔧" },
                        { value: "Gasto operativo",    label: "Gasto operativo",     icon: "📋" },
                        { value: "Otros",              label: "Otros",               icon: "📦" },
                    ].map(c => (
                        <label class="cat-option flex items-center gap-2 border border-slate-200 rounded-xl px-3 py-2.5 cursor-pointer hover:border-rose-300 transition-all has-[:checked]:border-rose-400 has-[:checked]:bg-rose-50">
                            <input type="radio" name="categoria" value={c.value} class="sr-only" />
                            <span class="text-base">{c.icon}</span>
                            <span class="text-xs font-medium text-slate-700 leading-tight">{c.label}</span>
                        </label>
                    ))}
                </div>
            </div>

            <!-- Descripción -->
            <div>
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1.5">Descripción</label>
                <input
                    id="input-descripcion"
                    type="text"
                    placeholder="Ej: Factura de electricidad de marzo"
                    class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-rose-400 focus:border-transparent placeholder:text-slate-300"
                />
            </div>

            <!-- Proveedor / Cliente -->
            <div>
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1.5">Proveedor / Cliente</label>
                <input
                    id="input-relacionado"
                    type="text"
                    placeholder="Nombre opcional"
                    class="w-full border border-slate-200 rounded-xl px-3 py-2.5 text-sm text-slate-800 focus:outline-none focus:ring-2 focus:ring-rose-400 focus:border-transparent placeholder:text-slate-300"
                />
            </div>

            <!-- Método de pago -->
            <div>
                <label class="text-xs font-semibold text-slate-500 uppercase tracking-wide block mb-1.5">Método de pago *</label>
                <div class="grid grid-cols-2 gap-2">
                    {[
                        { value: "efectivo",      label: "Efectivo",      icon: "💵" },
                        { value: "transferencia", label: "Transferencia", icon: "📲" },
                        { value: "debito",        label: "Débito",        icon: "💳" },
                        { value: "credito",       label: "Crédito",       icon: "💳" },
                    ].map(m => (
                        <label class="metodo-option flex items-center gap-2 border border-slate-200 rounded-xl px-3 py-2.5 cursor-pointer hover:border-rose-300 transition-all has-[:checked]:border-rose-400 has-[:checked]:bg-rose-50">
                            <input type="radio" name="metodo" value={m.value} class="sr-only" />
                            <span class="text-base">{m.icon}</span>
                            <span class="text-xs font-medium text-slate-700">{m.label}</span>
                        </label>
                    ))}
                </div>
            </div>
        </div>

        <div id="modal-error" class="hidden text-xs text-red-500 bg-red-50 border border-red-100 rounded-lg px-3 py-2 text-center"></div>

        <button id="nuevo-modal-ok" type="button"
            class="w-full py-3 rounded-xl text-sm font-semibold bg-rose-500 hover:bg-rose-600 text-white transition-colors flex items-center justify-center gap-2">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
            </svg>
            <span id="nuevo-ok-text">Guardar gasto</span>
            <svg id="nuevo-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 0v4a8 8 0 00-8 8H0z"></path>
            </svg>
        </button>
    </div>
</div>

<!-- Modal confirmar eliminación -->
<div id="eliminar-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center bg-black/40 backdrop-blur-sm px-4">
    <div class="bg-white rounded-2xl shadow-xl w-full max-w-xs p-6 space-y-4">
        <div class="text-center">
            <div class="text-3xl mb-2">🗑️</div>
            <p class="text-sm font-bold text-slate-800">Eliminar gasto</p>
            <p class="text-xs text-slate-400 mt-1">Esta acción no se puede deshacer</p>
        </div>
        <div class="flex gap-2">
            <button id="eliminar-cancel" type="button"
                class="flex-1 py-2.5 rounded-xl text-sm font-semibold border border-slate-200 text-slate-600 hover:bg-slate-50 transition-colors">
                Cancelar
            </button>
            <button id="eliminar-ok" type="button"
                class="flex-1 py-2.5 rounded-xl text-sm font-semibold bg-red-500 hover:bg-red-600 text-white transition-colors flex items-center justify-center gap-2">
                <span id="eliminar-ok-text">Eliminar</span>
                <svg id="eliminar-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
                    <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
                    <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 0v4a8 8 0 00-8 8H0z"></path>
                </svg>
            </button>
        </div>
    </div>
</div>

<script>
    import { supabase } from "../lib/supabaseClient.js";

    const $ = (id: string) => document.getElementById(id);

    const BADGE: Record<string, string> = JSON.parse($("badge-data")!.textContent ?? "{}");
    const ICON:  Record<string, string> = JSON.parse($("icon-data")!.textContent  ?? "{}");

    const formatARS = (n: number) =>
        "$ " + new Intl.NumberFormat("es-AR", {
            minimumFractionDigits: 2,
            maximumFractionDigits: 2,
        }).format(n);

    const formatDate = (dateStr: string) =>
        new Date(dateStr).toLocaleString("es-AR", {
            day: "2-digit", month: "2-digit", year: "numeric",
            hour: "2-digit", minute: "2-digit",
        });

    // ── Modal nuevo gasto ──
    const nuevoModal   = $("nuevo-gasto-modal")!;
    const nuevoOkBtn   = $("nuevo-modal-ok") as HTMLButtonElement;
    const nuevoOkText  = $("nuevo-ok-text")!;
    const nuevoSpinner = $("nuevo-spinner")!;
    const modalError   = $("modal-error")!;

    function openNuevoModal() {
        ($("input-monto") as HTMLInputElement).value = "";
        ($("input-descripcion") as HTMLInputElement).value = "";
        ($("input-relacionado") as HTMLInputElement).value = "";
        document.querySelectorAll<HTMLInputElement>("input[name='categoria']").forEach(r => r.checked = false);
        document.querySelectorAll<HTMLInputElement>("input[name='metodo']").forEach(r => r.checked = false);
        modalError.classList.add("hidden");
        nuevoModal.classList.remove("hidden");
        setTimeout(() => ($("input-monto") as HTMLInputElement).focus(), 100);
    }

    function closeNuevoModal() { nuevoModal.classList.add("hidden"); }

    $("nuevo-gasto-btn")?.addEventListener("click", openNuevoModal);
    $("nuevo-modal-cancel-x")?.addEventListener("click", closeNuevoModal);
    nuevoModal.addEventListener("click", (e) => { if (e.target === nuevoModal) closeNuevoModal(); });

    nuevoOkBtn.addEventListener("click", async () => {
        const monto       = parseFloat(($("input-monto") as HTMLInputElement).value);
        const categoria   = document.querySelector<HTMLInputElement>("input[name='categoria']:checked")?.value ?? "";
        const descripcion = ($("input-descripcion") as HTMLInputElement).value.trim();
        const relacionado = ($("input-relacionado") as HTMLInputElement).value.trim();
        const metodo      = document.querySelector<HTMLInputElement>("input[name='metodo']:checked")?.value ?? "";

        if (!monto || monto <= 0) {
            modalError.textContent = "Ingresá un monto válido";
            modalError.classList.remove("hidden");
            return;
        }
        if (!categoria) {
            modalError.textContent = "Seleccioná una categoría";
            modalError.classList.remove("hidden");
            return;
        }
        if (!metodo) {
            modalError.textContent = "Seleccioná un método de pago";
            modalError.classList.remove("hidden");
            return;
        }

        modalError.classList.add("hidden");
        nuevoOkText.textContent = "Guardando...";
        nuevoSpinner.classList.remove("hidden");
        nuevoOkBtn.disabled = true;

        try {
            const { data: sessionData } = await supabase.auth.getSession();
            const userId = sessionData?.session?.user?.id;

            const { data: newGasto, error } = await supabase
                .from("expenses")
                .insert([{
                    user_id:        userId,
                    amount:         monto,
                    category:       categoria,
                    description:    descripcion || null,
                    related_name:   relacionado || null,
                    payment_method: metodo,
                    created_at:     new Date().toISOString(),
                }])
                .select()
                .single();

            if (error) throw error;

            insertarFila(newGasto);
            actualizarContador(1);
            closeNuevoModal();

        } catch (err: any) {
            modalError.textContent = "Error: " + (err?.message ?? "Error desconocido");
            modalError.classList.remove("hidden");
        } finally {
            nuevoOkText.textContent = "Guardar gasto";
            nuevoSpinner.classList.add("hidden");
            nuevoOkBtn.disabled = false;
        }
    });

    // ── Insertar fila en el DOM ──
    function insertarFila(g: any) {
        const badge = BADGE[g.category] ?? "bg-slate-100 text-slate-600 border-slate-200";
        const icon  = ICON[g.category]  ?? "📦";

        const tbody = $("historial-tbody");
        if (tbody) {
            const tr = document.createElement("tr");
            tr.className = "hover:bg-slate-50 transition-colors historial-row";
            tr.dataset.fecha = g.created_at.slice(0, 10);
            tr.dataset.id = g.id;
            tr.innerHTML = `
                <td class="px-5 py-3.5 text-slate-400 text-xs whitespace-nowrap">${formatDate(g.created_at)}</td>
                <td class="px-5 py-3.5">
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium border ${badge}">${icon} ${g.category}</span>
                </td>
                <td class="px-5 py-3.5 text-slate-700 max-w-[180px] truncate">${g.description || '<span class="text-slate-300">—</span>'}</td>
                <td class="px-5 py-3.5 text-slate-500 text-xs">${g.related_name || '<span class="text-slate-300">—</span>'}</td>
                <td class="px-5 py-3.5 text-slate-500 text-xs capitalize">${g.payment_method}</td>
                <td class="px-5 py-3.5 text-right font-bold text-rose-500">${formatARS(g.amount)}</td>
                <td class="px-5 py-3.5">
                    <button class="eliminar-btn text-slate-200 hover:text-red-400 transition-colors" data-id="${g.id}" title="Eliminar">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                    </button>
                </td>
            `;
            tbody.prepend(tr);
        }

        const cards = $("historial-cards");
        if (cards) {
            const div = document.createElement("div");
            div.className = "px-4 py-4 historial-card border-b border-slate-100";
            div.dataset.fecha = g.created_at.slice(0, 10);
            div.dataset.id = g.id;
            div.innerHTML = `
                <div class="flex items-start justify-between gap-2 mb-2">
                    <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full text-xs font-medium border ${badge}">${icon} ${g.category}</span>
                    <div class="flex items-center gap-2 shrink-0">
                        <span class="text-base font-bold text-rose-500">${formatARS(g.amount)}</span>
                        <button class="eliminar-btn text-slate-200 hover:text-red-400 transition-colors" data-id="${g.id}">
                            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                            </svg>
                        </button>
                    </div>
                </div>
                ${g.description ? `<p class="text-sm text-slate-700 mb-1">${g.description}</p>` : ""}
                <div class="flex items-center gap-3 text-xs text-slate-400 flex-wrap">
                    ${g.related_name ? `<span class="font-medium text-slate-500">${g.related_name}</span>` : ""}
                    <span class="capitalize">${g.payment_method}</span>
                    <span>${formatDate(g.created_at)}</span>
                </div>
            `;
            cards.prepend(div);
        }
    }

    // ── Contador ──
    let totalRegistros = parseInt($("historial-count")?.textContent ?? "0");

    function actualizarContador(delta: number) {
        totalRegistros += delta;
        const el = $("historial-count");
        if (el) {
            el.textContent = `${totalRegistros} ${totalRegistros === 1 ? "registro" : "registros"} en total`;
        }
    }

    // ── Eliminar gasto ──
    const eliminarModal   = $("eliminar-modal")!;
    const eliminarOkBtn   = $("eliminar-ok") as HTMLButtonElement;
    const eliminarOkText  = $("eliminar-ok-text")!;
    const eliminarSpinner = $("eliminar-spinner")!;
    let idAEliminar: string | null = null;

    function openEliminarModal(id: string) {
        idAEliminar = id;
        eliminarModal.classList.remove("hidden");
    }
    function closeEliminarModal() {
        eliminarModal.classList.add("hidden");
        idAEliminar = null;
    }

    $("eliminar-cancel")?.addEventListener("click", closeEliminarModal);
    eliminarModal.addEventListener("click", (e) => { if (e.target === eliminarModal) closeEliminarModal(); });

    eliminarOkBtn.addEventListener("click", async () => {
        if (!idAEliminar) return;
        eliminarOkText.textContent = "Eliminando...";
        eliminarSpinner.classList.remove("hidden");
        eliminarOkBtn.disabled = true;

        try {
            const { error } = await supabase.from("expenses").delete().eq("id", idAEliminar);
            if (error) throw error;
            document.querySelectorAll(`[data-id="${idAEliminar}"]`).forEach(el => el.remove());
            actualizarContador(-1);
            closeEliminarModal();
        } catch (err: any) {
            alert("Error al eliminar: " + (err?.message ?? "Error desconocido"));
        } finally {
            eliminarOkText.textContent = "Eliminar";
            eliminarSpinner.classList.add("hidden");
            eliminarOkBtn.disabled = false;
        }
    });

    // Delegación para botones de eliminar dinámicos
    document.addEventListener("click", (e) => {
        const btn = (e.target as HTMLElement).closest(".eliminar-btn");
        if (btn) {
            const id = (btn as HTMLElement).dataset.id;
            if (id) openEliminarModal(id);
        }
    });

    // ── Filtro por fecha ──
    const filtroSelect = $("filtro-fecha") as HTMLSelectElement | null;
    const countEl      = $("historial-count");

    filtroSelect?.addEventListener("change", (e) => {
        const val = (e.target as HTMLSelectElement).value;
        let visible = 0;

        document.querySelectorAll<HTMLElement>(".historial-row").forEach(tr => {
            const match = !val || tr.dataset.fecha === val;
            tr.style.display = match ? "" : "none";
            if (match) visible++;
        });
        document.querySelectorAll<HTMLElement>(".historial-card").forEach(card => {
            const match = !val || card.dataset.fecha === val;
            card.style.display = match ? "" : "none";
        });

        if (countEl) {
            const total = val ? visible : totalRegistros;
            countEl.textContent = `${total} ${total === 1 ? "registro" : "registros"}${val ? " ese día" : " en total"}`;
        }
    });
</script>