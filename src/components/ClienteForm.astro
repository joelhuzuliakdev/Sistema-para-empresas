---
// Componente: src/components/NuevoClienteForm.astro
---

<div class="bg-white border border-slate-200 rounded-2xl shadow-sm overflow-hidden">

    <div class="flex items-center gap-3 px-5 py-4 border-b border-slate-100">
        <div class="w-8 h-8 rounded-lg bg-violet-100 flex items-center justify-center shrink-0">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-violet-600" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M18 9v3m0 0v3m0-3h3m-3 0h-3m-2-5a4 4 0 11-8 0 4 4 0 018 0zM3 20a6 6 0 0112 0v1H3v-1z" />
        </svg>
        </div>
        <h3 class="text-sm font-semibold text-slate-800">Nuevo Cliente</h3>
    </div>

    <div class="px-5 py-4 space-y-4">

        <!-- Error / éxito -->
        <div id="form-error" class="hidden px-3 py-2 rounded-xl bg-red-50 border border-red-200 text-red-700 text-xs"></div>
        <div id="form-success" class="hidden px-3 py-2 rounded-xl bg-emerald-50 border border-emerald-200 text-emerald-700 text-xs font-medium"></div>

        <!-- Nombre -->
        <div class="space-y-1.5">
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Nombre *</label>
        <div class="relative">
            <span class="absolute inset-y-0 left-3 flex items-center text-slate-400 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
            </svg>
            </span>
            <input
            id="client-name"
            type="text"
            placeholder="Nombre completo"
            class="w-full pl-9 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
            />
        </div>
        </div>

        <!-- Teléfono -->
        <div class="space-y-1.5">
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Teléfono</label>
        <div class="relative">
            <span class="absolute inset-y-0 left-3 flex items-center text-slate-400 pointer-events-none">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z" />
            </svg>
            </span>
            <input
            id="client-phone"
            type="tel"
            placeholder="Ej: 351 123 4567"
            class="w-full pl-9 pr-4 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition"
            />
        </div>
        </div>

        <!-- Observaciones -->
        <div class="space-y-1.5">
        <label class="block text-xs font-semibold text-slate-500 uppercase tracking-wide">Observaciones</label>
        <textarea
            id="client-notes"
            rows="3"
            placeholder="Notas adicionales sobre el cliente..."
            class="w-full px-4 py-2.5 border border-slate-200 rounded-xl text-sm text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-violet-500 focus:border-transparent transition resize-none"
        ></textarea>
        </div>

        <!-- Botón -->
        <button
        id="save-client-btn"
        class="w-full bg-violet-600 hover:bg-violet-700 active:scale-[0.98] disabled:bg-slate-200 disabled:text-slate-400 disabled:cursor-not-allowed text-white font-semibold py-2.5 rounded-xl transition-all text-sm flex items-center justify-center gap-2"
        >
        <span id="save-btn-text">Guardar cliente</span>
        <svg id="save-btn-spinner" class="hidden w-4 h-4 animate-spin" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
            <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
            <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 12 0 12 0v4a8 8 0 00-8 8H0z"></path>
        </svg>
        </button>

    </div>
</div>

<script>
    import { supabase } from "../lib/supabaseClient.js";

    const nameInput = document.getElementById("client-name") as HTMLInputElement;
    const phoneInput = document.getElementById("client-phone") as HTMLInputElement;
    const notesInput = document.getElementById("client-notes") as HTMLTextAreaElement;
    const saveBtn = document.getElementById("save-client-btn") as HTMLButtonElement;
    const btnText = document.getElementById("save-btn-text")!;
    const btnSpinner = document.getElementById("save-btn-spinner")!;
    const errorEl = document.getElementById("form-error")!;
    const successEl = document.getElementById("form-success")!;

    function showError(msg: string) {
        errorEl.textContent = msg;
        errorEl.classList.remove("hidden");
        successEl.classList.add("hidden");
    }

    function showSuccess(msg: string) {
        successEl.textContent = msg;
        successEl.classList.remove("hidden");
        errorEl.classList.add("hidden");
    }

    function setLoading(loading: boolean) {
        saveBtn.disabled = loading;
        btnText.textContent = loading ? "Guardando..." : "Guardar cliente";
        btnSpinner.classList.toggle("hidden", !loading);
    }

    function resetForm() {
        nameInput.value = "";
        phoneInput.value = "";
        notesInput.value = "";
    }

    saveBtn.addEventListener("click", async () => {
        errorEl.classList.add("hidden");
        successEl.classList.add("hidden");

        const name = nameInput.value.trim();
        const phone = phoneInput.value.trim();
        const notes = notesInput.value.trim();

        if (!name) return showError("El nombre del cliente es obligatorio.");

        setLoading(true);

        try {
        const { error } = await supabase
            .from("clients")
            .insert([{ name, phone: phone || null, notes: notes || null }]);

        if (error) throw error;

        showSuccess(`Cliente "${name}" guardado correctamente.`);
        resetForm();

        } catch (err: any) {
        showError(err?.message ?? "Ocurrió un error al guardar el cliente.");
        } finally {
        setLoading(false);
        }
    });

    // Submit con Enter en nombre y teléfono
    [nameInput, phoneInput].forEach((input) => {
        input.addEventListener("keydown", (e) => {
        if (e.key === "Enter") saveBtn.click();
        });
    });
</script>