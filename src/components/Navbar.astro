---
import { supabase } from "../lib/supabaseClient.js";

const { data: { session } } = await supabase.auth.getSession();
const user = session?.user;
---

<header class="bg-white border-b border-slate-200 px-6 py-0 flex items-center justify-between h-16 sticky top-0 z-50">

    <!-- Logo -->
    <a href="/dashboard" class="flex items-center gap-2.5 group">
        <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center shrink-0 group-hover:bg-indigo-700 transition-colors">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        </div>
        <span class="text-base font-bold text-slate-800 tracking-tight">POS SaaS</span>
    </a>

    <!-- Nav links -->
    <nav class="hidden md:flex items-center gap-1">
        {[
        { href: "/dashboard",   label: "Dashboard",  icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6" },
        { href: "/sales",       label: "Ventas",     icon: "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z" },
        { href: "/products",    label: "Productos",  icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4" },
        { href: "/clients",     label: "Clientes",   icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" },
        { href: "/cash",        label: "Caja",       icon: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z" },
        { href: "/reports",     label: "Reportes",   icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z" },
        ].map(({ href, label, icon }) => (
        
        <a href={href}
            class={`nav-link flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium transition-colors text-slate-600 hover:text-slate-900 hover:bg-slate-100`}
            data-path={href}
        >
            <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
            </svg>
            {label}
        </a>
        ))}
    </nav>

    <!-- Derecha: usuario + salir -->
    <div class="flex items-center gap-3">

        {user && (
        <div class="hidden sm:flex items-center gap-2.5">
            <div class="w-8 h-8 rounded-full bg-indigo-100 flex items-center justify-center shrink-0">
            <span class="text-xs font-bold text-indigo-700">
                {user.email?.[0].toUpperCase()}
            </span>
            </div>
            <span class="text-sm text-slate-600 max-w-[140px] truncate">{user.email}</span>
        </div>
        )}

        <button
        id="logout-btn"
        class="flex items-center gap-1.5 px-3 py-2 rounded-lg text-sm font-medium text-slate-500 hover:text-red-600 hover:bg-red-50 transition-colors"
        >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        Salir
        </button>

        <!-- Mobile menu button -->
        <button
        id="mobile-menu-btn"
        class="md:hidden flex items-center justify-center w-9 h-9 rounded-lg text-slate-500 hover:bg-slate-100 transition-colors"
        >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
        </button>

    </div>
</header>

<!-- Mobile nav -->
<div id="mobile-menu" class="hidden md:hidden bg-white border-b border-slate-200 px-4 py-3 space-y-1">
    {[
        { href: "/dashboard",  label: "Dashboard" },
        { href: "/sales",      label: "Ventas" },
        { href: "/products",   label: "Productos" },
        { href: "/clients",    label: "Clientes" },
        { href: "/cash",       label: "Caja" },
        { href: "/reports",    label: "Reportes" },
    ].map(({ href, label }) => (
        <a href={href} class="block px-3 py-2 rounded-lg text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-colors">
        {label}
        </a>
    ))}
</div>

<script>
    import { supabase } from "../lib/supabaseClient.js";

    // Logout
    document.getElementById("logout-btn")?.addEventListener("click", async () => {
        await supabase.auth.signOut();
        window.location.href = "/login";
    });

    // Mobile menu toggle
    document.getElementById("mobile-menu-btn")?.addEventListener("click", () => {
        const menu = document.getElementById("mobile-menu");
        menu?.classList.toggle("hidden");
    });

    // Marcar link activo según URL actual
    const currentPath = window.location.pathname;
    document.querySelectorAll<HTMLElement>(".nav-link").forEach((link) => {
        const path = link.dataset.path ?? "";
        if (currentPath === path || (path !== "/dashboard" && currentPath.startsWith(path))) {
        link.classList.add("bg-slate-100", "text-slate-900");
        link.classList.remove("text-slate-600");
        }
    });
</script>