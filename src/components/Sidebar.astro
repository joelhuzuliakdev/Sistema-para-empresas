---
import { supabase } from "../lib/supabaseClient.js";

const { data: settings } = await supabase
    .from("settings")
    .select("company_name, logo_url")
    .single();

const companyName = settings?.company_name ?? "Mi Empresa";
const logoUrl = settings?.logo_url ?? null;
const links = [
    {
        href: "/dashboard",
        label: "Dashboard",
        icon: "M3 12l2-2m0 0l7-7 7 7M5 10v10a1 1 0 001 1h3m10-11l2 2m-2-2v10a1 1 0 01-1 1h-3m-6 0a1 1 0 001-1v-4a1 1 0 011-1h2a1 1 0 011 1v4a1 1 0 001 1m-6 0h6",
    },
    {
        href: "/products",
        label: "Productos",
        icon: "M20 7l-8-4-8 4m16 0l-8 4m8-4v10l-8 4m0-10L4 7m8 4v10M4 7v10l8 4",
    },
    {
        href: "/sales",
        label: "Ventas",
        icon: "M16 11V7a4 4 0 00-8 0v4M5 9h14l1 12H4L5 9z",
    },
    {
        href: "/cash",
        label: "Caja",
        icon: "M17 9V7a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2m2 4h10a2 2 0 002-2v-6a2 2 0 00-2-2H9a2 2 0 00-2 2v6a2 2 0 002 2zm7-5a2 2 0 11-4 0 2 2 0 014 0z",
    },
    {
        href: "/clients",
        label: "Clientes",
        icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z",
    },
    {
        href: "/reports",
        label: "Reportes",
        icon: "M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v14a2 2 0 01-2 2h-2a2 2 0 01-2-2z",
    },
    {
        href: "/employee",
        label: "Panel Empleado",
        icon: "M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z",
    },
    { 
        href: "/team", 
        label: "Equipo", 
        icon: "M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0z" 
    },
];
---

<aside class="w-64 shrink-0 bg-white border-r border-slate-200 h-screen flex flex-col sticky top-0">

    <!-- Logo -->
    <div class="flex items-center gap-2.5 px-5 py-5 border-b border-slate-100">
        {logoUrl ? (
            <img src={logoUrl} class="w-8 h-8 rounded-lg object-cover shrink-0" />
        ) : (
            <div class="w-8 h-8 rounded-lg bg-indigo-600 flex items-center justify-center shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                </svg>
            </div>
        )}
        <a href="/" class="text-base font-bold text-slate-800 tracking-tight">{companyName}</a>
    </div>

    <!-- Links -->
    <nav class="flex-1 px-3 py-4 space-y-0.5 overflow-y-auto">
        {links.map(({ href, label, icon }) => (
        
        <a href={href}
            data-path={href}
            class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-colors"
        >
            <svg
            xmlns="http://www.w3.org/2000/svg"
            class="w-4 h-4 shrink-0 text-slate-400 group-hover:text-slate-600 transition-colors nav-icon"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
            >
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d={icon} />
            </svg>
            {label}
        </a>
        ))}
    </nav>

    <!-- Sección inferior -->
    <div class="px-3 py-4 border-t border-slate-100 space-y-0.5">

        <!-- Configuración -->
        
        <a href="/settings"
        data-path="/settings"
        class="nav-link group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-600 hover:text-slate-900 hover:bg-slate-100 transition-colors"
        >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 text-slate-400 group-hover:text-slate-600 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10.325 4.317c.426-1.756 2.924-1.756 3.35 0a1.724 1.724 0 002.573 1.066c1.543-.94 3.31.826 2.37 2.37a1.724 1.724 0 001.065 2.572c1.756.426 1.756 2.924 0 3.35a1.724 1.724 0 00-1.066 2.573c.94 1.543-.826 3.31-2.37 2.37a1.724 1.724 0 00-2.572 1.065c-.426 1.756-2.924 1.756-3.35 0a1.724 1.724 0 00-2.573-1.066c-1.543.94-3.31-.826-2.37-2.37a1.724 1.724 0 00-1.065-2.572c-1.756-.426-1.756-2.924 0-3.35a1.724 1.724 0 001.066-2.573c-.94-1.543.826-3.31 2.37-2.37.996.608 2.296.07 2.572-1.065z" />
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
        </svg>
        Configuración
        </a>

        <!-- Salir -->
        <button
        id="sidebar-logout"
        class="w-full group flex items-center gap-3 px-3 py-2.5 rounded-xl text-sm font-medium text-slate-600 hover:text-red-600 hover:bg-red-50 transition-colors"
        >
        <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 shrink-0 text-slate-400 group-hover:text-red-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1" />
        </svg>
        Salir
        </button>

    </div>

</aside>

<script>
    import { supabase } from "../lib/supabaseClient.js";

    // Logout
    document.getElementById("sidebar-logout")?.addEventListener("click", async () => {
        await supabase.auth.signOut();
        window.location.href = "/login";
    });

    // Marcar link activo
    const currentPath = window.location.pathname;
    document.querySelectorAll<HTMLElement>(".nav-link").forEach((link) => {
        const path = link.dataset.path ?? "";
        const isActive =
        currentPath === path ||
        (path !== "/dashboard" && currentPath.startsWith(path));

        if (isActive) {
        link.classList.add("bg-indigo-50", "text-indigo-700");
        link.classList.remove("text-slate-600");
        const icon = link.querySelector(".nav-icon");
        icon?.classList.add("text-indigo-500");
        icon?.classList.remove("text-slate-400");
        }
    });
</script>